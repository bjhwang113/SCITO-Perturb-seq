\SweaveOpts{concordance=TRUE}

<<>>=
suppressPackageStartupMessages({
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  library(ggalluvial)
})
set.seed(42)

GENE_RESULTS_DIR <- "/home/ec2-user/scitoseq/results/results_gene_level"
CORR_RESULTS_DIR <- "/home/ec2-user/scitoseq/results/results_correlation"
NMF_DIR          <- "/home/ec2-user/scitoseq/results/semiNMF_v1_analysis"
OUTPUT_DIR       <- "/home/ec2-user/scitoseq/results/bridge/"
fig_dir <-  "/home/ec2-user/scitoseq/fig/fig3/"

modules <- paste0("M", 1:5)
MODULE_NAMES_SHORT <- c(
  M1 = "Adhesion & Immune Reg.", M2 = "Tissue / Innate-like",
  M3 = "Resting / Naive", M4 = "Activation / Prolif.", M5 = "Effector / Exhaustion"
)
MODULE_COLORS <- c(
  M1 = "#da7901", M2 = "#20235b", M3 = "#637b31", M4 = "#7B2D8E", M5 = "#f0be3d"
)
CLUSTER_ANNOTATIONS <- c(
  "1" = "abc transporters", "2" = "calcineurin mediated signaling",
  "3" = "calcineurin signaling",
  "4" = "regulation of calcium ion transmembrane transport",
  "5" = "immunoregulatory interactions", "6" = "detoxification",
  "7" = "TNF receptor signaling", "8" = "t cell receptor signaling pathway",
  "9" = "protein localization to cell periphery",
  "10" = "regulation of bmp signaling pathway"
)

# DATA LOADING AND PROCESSING

gene_zscore_mat <- readRDS(file.path(GENE_RESULTS_DIR, "gene_zscore_mat.rds"))
gene_qval_mat   <- readRDS(file.path(GENE_RESULTS_DIR, "gene_qval_per_protein.rds"))
self_targeted    <- readRDS(file.path(GENE_RESULTS_DIR, "self_targeted_gene.rds"))
prot_cluster_df  <- readRDS(file.path(CORR_RESULTS_DIR, "protein_clusters.rds"))
model_k5         <- readRDS(file.path(NMF_DIR, "model_k5.rds"))

W_raw <- model_k5$W; H_raw <- model_k5$H
colnames(W_raw) <- modules; rownames(H_raw) <- modules

# L2-normalize W and H
d <- sqrt(colSums(W_raw^2))
W <- sweep(W_raw, 2, d, "/")
H <- diag(d) %*% H_raw
rownames(H) <- modules; colnames(H) <- colnames(H_raw)

# Reproduce gene clusters (k=10, Ward.D2)
genes_filtered <- names(which(rowSums(gene_qval_mat < 0.10, na.rm = TRUE) >= 3))
gene_zscore_masked <- gene_zscore_mat
for (i in seq_len(nrow(self_targeted))) {
  g <- self_targeted$gene[i]; p <- self_targeted$protein[i]
  if (g %in% rownames(gene_zscore_masked) && p %in% colnames(gene_zscore_masked))
    gene_zscore_masked[g, p] <- NA
}
zscore_clust <- gene_zscore_masked[genes_filtered, , drop = FALSE]
zscore_clust[is.na(zscore_clust) | !is.finite(zscore_clust)] <- 0
corr_mat <- cor(t(zscore_clust), method = "pearson", use = "pairwise.complete.obs")
corr_mat[is.na(corr_mat)] <- 0
gene_clusters <- cutree(hclust(as.dist(1 - corr_mat), method = "ward.D2"), k = 10)

# Dominant module assignments
gene_dom_module <- modules[apply(abs(W), 1, which.max)]
names(gene_dom_module) <- rownames(W)
prot_dom_module <- modules[apply(H, 2, which.max)]
names(prot_dom_module) <- colnames(H)

# Bridge data frames
genes_both <- intersect(names(gene_clusters), rownames(W))
cluster_vec <- gene_clusters[genes_both]
W_bridge <- W[genes_both, ]

proteins_in_H <- colnames(H)
protein_groups <- sort(unique(prot_cluster_df$cluster_name))

prot_bridge <- data.frame(
  protein = proteins_in_H,
  group = prot_cluster_df$cluster_name[match(proteins_in_H, prot_cluster_df$protein)],
  dom_module = prot_dom_module,
  stringsAsFactors = FALSE
) %>% filter(!is.na(group))

cat(sprintf("Genes in bridge: %d | Proteins in bridge: %d\n\n",
            length(genes_both), nrow(prot_bridge)))
@

<<>>=
# STATISTICAL TESTS - GENE SIDE

# --- Permutation test (global) ---
compute_cluster_module_mat <- function(clusters, W_mat) {
  k <- max(clusters)
  mat <- matrix(NA, nrow = k, ncol = ncol(W_mat))
  for (cl in 1:k) {
    idx <- which(clusters == cl)
    if (length(idx) > 0) mat[cl, ] <- colMeans(W_mat[idx, , drop = FALSE])
  }
  mat
}

obs_mat <- compute_cluster_module_mat(cluster_vec, W_bridge)
obs_frob <- sqrt(sum(obs_mat^2))

N_PERM <- 10000
perm_frob <- numeric(N_PERM)
perm_cluster_norms <- matrix(0, nrow = N_PERM, ncol = 10)

cat(sprintf("Running %d permutations (gene side)...\n", N_PERM))
for (i in 1:N_PERM) {
  shuffled <- sample(cluster_vec)
  perm_mat <- compute_cluster_module_mat(shuffled, W_bridge)
  perm_frob[i] <- sqrt(sum(perm_mat^2))
  perm_cluster_norms[i, ] <- rowSums(perm_mat^2)
}

perm_p <- (sum(perm_frob >= obs_frob) + 1) / (N_PERM + 1)
cat(sprintf("Global permutation test: Z = %.1f, P = %.2e\n",
            (obs_frob - mean(perm_frob)) / sd(perm_frob), perm_p))

# --- Per-cluster permutation test ---
obs_cluster_norms <- rowSums(obs_mat^2)
cluster_pvals <- sapply(1:10, function(cl) {
  (sum(perm_cluster_norms[, cl] >= obs_cluster_norms[cl]) + 1) / (N_PERM + 1)
})
cluster_pvals_adj <- p.adjust(cluster_pvals, method = "BH")
n_sig_clusters <- sum(cluster_pvals_adj < 0.05)
cat(sprintf("Clusters with non-random module profiles: %d/10 (BH P < 0.05)\n", n_sig_clusters))

# --- Fisher's exact test (gene cluster x module) ---
gene_dom_bridge <- gene_dom_module[genes_both]

fisher_gene <- expand.grid(cluster = 1:10, module = modules, stringsAsFactors = FALSE) %>%
  rowwise() %>%
  mutate(
    a = sum(cluster_vec == cluster & gene_dom_bridge == module),
    b = sum(cluster_vec != cluster & gene_dom_bridge == module),
    c = sum(cluster_vec == cluster & gene_dom_bridge != module),
    d = sum(cluster_vec != cluster & gene_dom_bridge != module),
    fisher_p = fisher.test(matrix(c(a, b, c, d), nrow = 2))$p.value,
    odds_ratio = fisher.test(matrix(c(a, b, c, d), nrow = 2))$estimate
  ) %>%
  ungroup() %>%
  mutate(padj = p.adjust(fisher_p, method = "BH"),
         cluster_label = paste0("C", cluster))

cat("\nSignificant gene cluster-module associations (FDR < 0.05):\n")
fisher_gene %>% filter(padj < 0.05) %>% arrange(padj) %>%
  select(cluster_label, module, a, odds_ratio, padj) %>%
  print(n = 20)

# STATISTICAL TESTS - PROTEIN SIDE
fisher_prot <- expand.grid(group = protein_groups, module = modules,
                            stringsAsFactors = FALSE) %>%
  rowwise() %>%
  mutate(
    a = sum(prot_bridge$group == group & prot_bridge$dom_module == module),
    b = sum(prot_bridge$group != group & prot_bridge$dom_module == module),
    c = sum(prot_bridge$group == group & prot_bridge$dom_module != module),
    d = sum(prot_bridge$group != group & prot_bridge$dom_module != module),
    fisher_p = fisher.test(matrix(c(a, b, c, d), nrow = 2))$p.value,
    odds_ratio = fisher.test(matrix(c(a, b, c, d), nrow = 2))$estimate
  ) %>%
  ungroup() %>%
  mutate(padj = p.adjust(fisher_p, method = "BH"))

cat("\nSignificant protein group-module associations (FDR < 0.05):\n")
fisher_prot %>% filter(padj < 0.05) %>% arrange(padj) %>%
  select(group, module, a, odds_ratio, padj) %>%
  print(n = 20)

# Cross-tabs for reference
cat("\nProtein group x module cross-tab (row %):\n")
print(round(prop.table(table(prot_bridge$group, prot_bridge$dom_module), margin = 1) * 100, 1))

cat("\nGene cluster x module cross-tab (row %):\n")
gene_cross <- table(
  Cluster = paste0("C", cluster_vec),
  Module = gene_dom_bridge)
print(round(prop.table(gene_cross, margin = 1) * 100, 1))
@

<<>>=
# ALLUVIAL PLOTS

# Shared data for alluvial plots
gene_flow <- data.frame(
  gene = genes_both,
  cluster_label = factor(paste0("C", cluster_vec), levels = paste0("C", 1:10)),
  module_label = factor(gene_dom_bridge, levels = modules),
  stringsAsFactors = FALSE
) %>%
  group_by(cluster_label, module_label) %>%
  summarise(gene_count = n(), .groups = "drop")

module_protgroup_frac <- expand.grid(module = modules, group = protein_groups,
                                      stringsAsFactors = FALSE) %>%
  rowwise() %>%
  mutate(frac = {
    grp_prots <- intersect(
      prot_cluster_df$protein[prot_cluster_df$cluster_name == group], proteins_in_H
    )
    if (length(grp_prots) > 0) sum(H[module, grp_prots]) / sum(H[module, ]) else 0
  }) %>%
  ungroup()

# --- Shared theme ---
alluvial_theme <- theme_minimal(base_size = 16) +
  theme(
    axis.text.y   = element_blank(),
    axis.text.x = element_text(size = 16),
    axis.ticks.y  = element_blank(),
    panel.grid    = element_blank(),
    plot.title    = element_text(face = "bold", size = 13, hjust = 0.5),
    plot.subtitle = element_text(size = 9, hjust = 0.5, color = "grey40"),
    plot.margin   = margin(10, 15, 10, 15)
  )

# --- Shared strata fill (grey for non-module, module colors for modules) ---
all_strata <- c(paste0("C", 1:10), modules, protein_groups)
strata_fill <- setNames(
  c(rep("grey75", 10), unname(MODULE_COLORS), rep("grey75", length(protein_groups))),
  all_strata
)

# PLOT 1: Joint 3-column alluvial (Gene Clusters -> Modules -> Protein Groups)
unified_3col <- gene_flow %>%
  left_join(module_protgroup_frac,
            by = c("module_label" = "module"),
            relationship = "many-to-many") %>%
  mutate(flow_count = gene_count * frac,
         group_label = factor(group, levels = protein_groups)) %>%
  filter(flow_count > 0.5)

p_joint <- ggplot(unified_3col,
                  aes(axis1 = cluster_label, axis2 = module_label,
                      axis3 = group_label, y = flow_count)) +
  geom_alluvium(aes(fill = module_label), width = 1/4, alpha = 0.55,
                curve_type = "sigmoid") +
  geom_stratum(aes(fill = after_stat(stratum)), width = 1/4,
               color = "grey40", linewidth = 0.3) +
  geom_text(stat = "stratum", aes(label = after_stat(stratum)), size = 4) +
  scale_fill_manual(values = c(MODULE_COLORS, strata_fill), guide = "none") +
  scale_x_discrete(
    limits = c("Gene Cluster\n(Fig 2E)", "Phenotypic Module\n(Fig 3)",
               "Protein Group\n(Fig 2A)"),
    expand = c(0.12, 0.05)
  ) +
  labs(title = "Gene Clusters \u2192 Phenotypic Modules \u2192 Protein Groups",
       subtitle = "Flow colored by phenotypic module; width proportional to gene count \u00d7 H signature fraction",
       y = NULL) +
  alluvial_theme
p_joint
ggsave(file.path(fig_dir, "bridge_alluvial_joint.pdf"),
       p_joint, width = 11, height = 9)
# ggsave(file.path(OUTPUT_DIR, "bridge_alluvial_joint.png"),
#        p_joint, width = 11, height = 9, dpi = 300)

# PLOT 2: Gene Cluster -> Module (separate)
p_gene <- ggplot(gene_flow,
                 aes(axis1 = cluster_label, axis2 = module_label,
                     y = gene_count)) +
  geom_alluvium(aes(fill = module_label), width = 1/4, alpha = 0.55,
                curve_type = "sigmoid") +
  geom_stratum(aes(fill = after_stat(stratum)), width = 1/4,
               color = "grey40", linewidth = 0.3) +
  geom_text(stat = "stratum", aes(label = after_stat(stratum)), size = 6) +
  scale_fill_manual(
    values = c(MODULE_COLORS, setNames(rep("grey75", 10), paste0("C", 1:10))),
    guide = "none"
  ) +
  scale_x_discrete(
    limits = c("Gene Cluster\n(Fig 2E)", "Phenotypic Module\n(Fig 3)"),
    expand = c(0.2, 0.05)
  ) +
  labs(title = "Gene Cluster \u2192 Phenotypic Module Assignment",
       subtitle = sprintf("%d genes, assigned to dominant module by max|W|", length(genes_both)),
       y = "Number of genes") +
  alluvial_theme
p_gene
ggsave(file.path(fig_dir, "bridge_alluvial_gene.pdf"),
       p_gene, width = 8, height = 9)
# ggsave(file.path(OUTPUT_DIR, "bridge_alluvial_gene.png"),
#        p_gene, width = 8, height = 9, dpi = 300)

# PLOT 3: Module -> Protein Group (separate)
prot_flow <- prot_bridge %>%
  mutate(module_label = factor(dom_module, levels = modules),
         group_label = factor(group, levels = protein_groups)) %>%
  group_by(module_label, group_label) %>%
  summarise(prot_count = n(), .groups = "drop")

p_prot <- ggplot(prot_flow,
                 aes(axis1 = module_label, axis2 = group_label,
                     y = prot_count)) +
  geom_alluvium(aes(fill = module_label), width = 1/4, alpha = 0.55,
                curve_type = "sigmoid") +
  geom_stratum(aes(fill = after_stat(stratum)), width = 1/4,
               color = "grey40", linewidth = 0.3) +
  geom_text(stat = "stratum", aes(label = after_stat(stratum)), size = 6) +
  scale_fill_manual(
    values = c(MODULE_COLORS, setNames(rep("grey75", length(protein_groups)), protein_groups)),
    guide = "none"
  ) +
  scale_x_discrete(
    limits = c("Phenotypic Module\n(Fig 3)", "Protein Group\n(Fig 2A)"),
    expand = c(0.2, 0.05)
  ) +
  labs(title = "Phenotypic Module \u2192 Protein Group Assignment",
       subtitle = sprintf("%d proteins, assigned to dominant module by max(H)", nrow(prot_bridge)),
       y = "Number of proteins") +
  alluvial_theme
p_prot
ggsave(file.path(fig_dir, "bridge_alluvial_protein.pdf"),
       p_prot, width = 8, height = 9)
# ggsave(file.path(OUTPUT_DIR, "bridge_alluvial_protein.png"),
#        p_prot, width = 8, height = 9, dpi = 300)
@

