write.csv(
  fisher_gene %>%
    select(cluster_label, module, a, odds_ratio, fisher_p, padj) %>%
    rename(n_genes = a),
  file.path(OUTPUT_DIR, "/bridge/bridge_fisher_gene_cluster_module.csv"), row.names = FALSE
)

write.csv(
  fisher_prot %>%
    select(group, module, a, odds_ratio, fisher_p, padj) %>%
    rename(n_proteins = a),
  file.path(OUTPUT_DIR, "bridge_fisher_protgroup_module.csv"), row.names = FALSE
)

gene_cross_tab <- data.frame(gene = genes_both, cluster = paste0("C", cluster_vec),
                              module = gene_dom_bridge) %>%
  group_by(cluster, module) %>%
  summarise(n = n(), .groups = "drop") %>%
  group_by(cluster) %>%
  mutate(pct = round(100 * n / sum(n), 1)) %>%
  mutate(label = paste0(n, " (", pct, "%)")) %>%
  select(cluster, module, label) %>%
  pivot_wider(names_from = module, values_from = label, values_fill = "0 (0%)")

write.csv(gene_cross_tab,
          file.path(OUTPUT_DIR, "bridge_gene_cluster_module_crosstab.csv"), row.names = FALSE)

prot_cross_tab <- prot_bridge %>%
  group_by(group, dom_module) %>%
  summarise(n = n(), .groups = "drop") %>%
  group_by(group) %>%
  mutate(pct = round(100 * n / sum(n), 1)) %>%
  mutate(label = paste0(n, " (", pct, "%)")) %>%
  select(group, dom_module, label) %>%
  pivot_wider(names_from = dom_module, values_from = label, values_fill = "0 (0%)")

write.csv(prot_cross_tab,
          file.path(OUTPUT_DIR, "bridge_protgroup_module_crosstab.csv"), row.names = FALSE)
@

<<>>=
cat(sprintf("Gene side: %d genes, %d clusters, %d modules\n",
            length(genes_both), 10, 5))
cat(sprintf("  Global permutation: Z = %.1f, P < %.0e\n",
            (obs_frob - mean(perm_frob)) / sd(perm_frob),
            10^ceiling(log10(perm_p))))
cat(sprintf("  Clusters with non-random profiles: %d/10\n", n_sig_clusters))

cat(sprintf("\nProtein side: %d proteins, %d groups, %d modules\n",
            nrow(prot_bridge), length(protein_groups), 5))
cat("  Top positive enrichments:\n")
fisher_prot %>%
  filter(padj < 0.05, odds_ratio > 1) %>%
  arrange(padj) %>%
  head(6) %>%
  rowwise() %>%
  mutate(msg = sprintf("    %s -> %s: %d/%d (OR=%.1f, FDR=%.1e)",
                        group, module, a, a + c, odds_ratio, padj)) %>%
