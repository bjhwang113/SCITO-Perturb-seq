<<>>=
# Reproduce gene clusters
genes_filtered <- names(which(rowSums(gene_qval_mat < 0.10, na.rm = TRUE) >= 3))
gene_zscore_masked <- gene_zscore_mat
for (i in seq_len(nrow(self_targeted))) {
  g <- self_targeted$gene[i]; p <- self_targeted$protein[i]
  if (g %in% rownames(gene_zscore_masked) && p %in% colnames(gene_zscore_masked))
    gene_zscore_masked[g, p] <- NA
}
zscore_clust <- gene_zscore_masked[genes_filtered, , drop = FALSE]
zscore_clust[is.na(zscore_clust) | !is.finite(zscore_clust)] <- 0
corr_mat <- cor(t(zscore_clust), method = "pearson", use = "pairwise.complete.obs")
corr_mat[is.na(corr_mat)] <- 0
gene_clusters <- cutree(hclust(as.dist(1 - corr_mat), method = "ward.D2"), k = 10)

genes_both <- intersect(names(gene_clusters), rownames(W))
proteins_in_H <- colnames(H)
@

UNIFIED TEST: Between-group sum of squares, permutation-based

For each module m, compute:
  SS_between(m) = sum_g [ n_g * (mean_gm - grand_mean_m)^2 ]

Test statistic = sum over all modules of SS_between(m)
This is equivalent to the trace of the between-group SSCP matrix
(i.e., Pillai's trace in MANOVA, without normalization)

Null: permute group labels among items, recompute.

<<>>=
compute_between_ss <- function(values_mat, group_labels) {
  # values_mat: items x modules
  # group_labels: vector of group labels (same length as nrow)
  groups <- unique(group_labels)
  grand_means <- colMeans(values_mat)
  ss <- 0
  for (g in groups) {
    idx <- which(group_labels == g)
    n_g <- length(idx)
    group_means <- colMeans(values_mat[idx, , drop = FALSE])
    ss <- ss + n_g * sum((group_means - grand_means)^2)
  }
  ss
}

N_PERM <- 10000

# GENE SIDE: cluster labels permuted among 299 genes, tested on W matrix
cat("=== GENE SIDE (continuous W coefficients) ===\n\n")

W_bridge <- W[genes_both, ]
cluster_vec <- gene_clusters[genes_both]

obs_ss_gene <- compute_between_ss(W_bridge, cluster_vec)
cat(sprintf("Observed between-cluster SS: %.8f\n", obs_ss_gene))

perm_ss_gene <- numeric(N_PERM)
cat(sprintf("Running %d permutations...\n", N_PERM))
for (i in 1:N_PERM) {
  perm_ss_gene[i] <- compute_between_ss(W_bridge, sample(cluster_vec))
}

perm_p_gene <- (sum(perm_ss_gene >= obs_ss_gene) + 1) / (N_PERM + 1)
z_gene <- (obs_ss_gene - mean(perm_ss_gene)) / sd(perm_ss_gene)

cat(sprintf("Null mean: %.8f, SD: %.8f\n", mean(perm_ss_gene), sd(perm_ss_gene)))
cat(sprintf("Z-score: %.1f\n", z_gene))
cat(sprintf("P-value: %.2e\n\n", perm_p_gene))

# Per-cluster test: is each cluster's mean W vector further from grand mean than expected?
cat("--- Per-cluster tests ---\n")
grand_means_W <- colMeans(W_bridge)

obs_cluster_ss <- sapply(1:10, function(cl) {
  idx <- which(cluster_vec == cl)
  n_g <- length(idx)
  group_means <- colMeans(W_bridge[idx, , drop = FALSE])
  n_g * sum((group_means - grand_means_W)^2)
})

perm_cluster_ss <- matrix(0, nrow = N_PERM, ncol = 10)
for (i in 1:N_PERM) {
  shuffled <- sample(cluster_vec)
  for (cl in 1:10) {
    idx <- which(shuffled == cl)
    n_g <- length(idx)
    group_means <- colMeans(W_bridge[idx, , drop = FALSE])
    perm_cluster_ss[i, cl] <- n_g * sum((group_means - grand_means_W)^2)
  }
}

cluster_pvals <- sapply(1:10, function(cl) {
  (sum(perm_cluster_ss[, cl] >= obs_cluster_ss[cl]) + 1) / (N_PERM + 1)
})
cluster_padj <- p.adjust(cluster_pvals, method = "BH")

gene_cluster_results <- data.frame(
  cluster = paste0("C", 1:10),
  n_genes = as.integer(table(cluster_vec)),
  obs_SS = signif(obs_cluster_ss, 4),
  null_mean = signif(colMeans(perm_cluster_ss), 4),
  z_score = round((obs_cluster_ss - colMeans(perm_cluster_ss)) /
                    apply(perm_cluster_ss, 2, sd), 2),
  pval = signif(cluster_pvals, 3),
  padj = signif(cluster_padj, 3)
)
print(gene_cluster_results)
cat(sprintf("\nClusters with non-random module profiles (BH P < 0.05): %d/10\n",
            sum(cluster_padj < 0.05)))

# PROTEIN SIDE: protein group labels permuted among 201 proteins, tested on H
cat("\n=== PROTEIN SIDE (continuous H protein signatures) ===\n\n")

# H is modules x proteins, we need proteins x modules
H_t <- t(H)  # 201 proteins x 5 modules
prot_group_vec <- prot_cluster_df$cluster_name[match(proteins_in_H, prot_cluster_df$protein)]
names(prot_group_vec) <- proteins_in_H

# Remove any proteins without group assignment
valid <- !is.na(prot_group_vec)
H_bridge <- H_t[valid, ]
prot_groups_vec <- prot_group_vec[valid]

cat(sprintf("Proteins with group assignment: %d\n", sum(valid)))
cat(sprintf("Protein groups: %s\n", paste(sort(unique(prot_groups_vec)), collapse = ", ")))

obs_ss_prot <- compute_between_ss(H_bridge, prot_groups_vec)
cat(sprintf("Observed between-group SS: %.2f\n", obs_ss_prot))

perm_ss_prot <- numeric(N_PERM)
cat(sprintf("Running %d permutations...\n", N_PERM))
for (i in 1:N_PERM) {
  perm_ss_prot[i] <- compute_between_ss(H_bridge, sample(prot_groups_vec))
}

perm_p_prot <- (sum(perm_ss_prot >= obs_ss_prot) + 1) / (N_PERM + 1)
z_prot <- (obs_ss_prot - mean(perm_ss_prot)) / sd(perm_ss_prot)

cat(sprintf("Null mean: %.2f, SD: %.2f\n", mean(perm_ss_prot), sd(perm_ss_prot)))
cat(sprintf("Z-score: %.1f\n", z_prot))
cat(sprintf("P-value: %.2e\n\n", perm_p_prot))

# Per-group test
cat("--- Per-group tests ---\n")
protein_groups <- sort(unique(prot_groups_vec))
grand_means_H <- colMeans(H_bridge)

obs_group_ss <- sapply(protein_groups, function(grp) {
  idx <- which(prot_groups_vec == grp)
  n_g <- length(idx)
  group_means <- colMeans(H_bridge[idx, , drop = FALSE])
  n_g * sum((group_means - grand_means_H)^2)
})

perm_group_ss <- matrix(0, nrow = N_PERM, ncol = length(protein_groups))
for (i in 1:N_PERM) {
  shuffled <- sample(prot_groups_vec)
  for (j in seq_along(protein_groups)) {
    grp <- protein_groups[j]
    idx <- which(shuffled == grp)
    n_g <- length(idx)
    group_means <- colMeans(H_bridge[idx, , drop = FALSE])
    perm_group_ss[i, j] <- n_g * sum((group_means - grand_means_H)^2)
  }
}

group_pvals <- sapply(seq_along(protein_groups), function(j) {
  (sum(perm_group_ss[, j] >= obs_group_ss[j]) + 1) / (N_PERM + 1)
})
group_padj <- p.adjust(group_pvals, method = "BH")

prot_group_results <- data.frame(
  group = protein_groups,
  n_proteins = as.integer(table(prot_groups_vec)[protein_groups]),
  obs_SS = signif(obs_group_ss, 4),
  null_mean = signif(colMeans(perm_group_ss), 4),
  z_score = round((obs_group_ss - colMeans(perm_group_ss)) /
                    apply(perm_group_ss, 2, sd), 2),
  pval = signif(group_pvals, 3),
  padj = signif(group_padj, 3)
)
print(prot_group_results)
cat(sprintf("\nGroups with non-random module profiles (BH P < 0.05): %d/%d\n",
            sum(group_padj < 0.05), length(protein_groups)))


cat(sprintf("GENE SIDE: %d genes, 10 clusters\n", length(genes_both)))
cat(sprintf("  Global: Z = %.1f, P %s\n", z_gene,
            ifelse(perm_p_gene < 1e-4,
                   paste0("< ", format(1/(N_PERM+1), scientific = TRUE)),
                   paste0("= ", format(perm_p_gene, scientific = TRUE)))))
cat(sprintf("  Individual clusters significant: %d/10 (BH P < 0.05)\n\n",
            sum(cluster_padj < 0.05)))

cat(sprintf("PROTEIN SIDE: %d proteins, 5 groups\n", sum(valid)))
cat(sprintf("  Global: Z = %.1f, P %s\n", z_prot,
            ifelse(perm_p_prot < 1e-4,
                   paste0("< ", format(1/(N_PERM+1), scientific = TRUE)),
                   paste0("= ", format(perm_p_prot, scientific = TRUE)))))
cat(sprintf("  Individual groups significant: %d/%d (BH P < 0.05)\n",
            sum(group_padj < 0.05), length(protein_groups)))
@

