\section{Build sgRNA Metadata}

<<sgrna-metadata>>=
# SECTION 6: Build sgRNA Metadata

# Create sgRNA info dataframe
sgrna_info <- meta %>% filter(guide_assignment_clean != "NTC") %>%
  distinct(guide_assignment_clean, guide_target_clean, Batch) %>% rename(
    sgRNA = guide_assignment_clean, gene = guide_target_clean,
    batch = Batch) %>% mutate(
    gene = as.character(gene), sgRNA = as.character(sgRNA),
    batch = as.character(batch))

# Add cell counts
sgrna_info$n_cells <- ncells_per_sgrna[sgrna_info$sgRNA]

cat(sprintf("sgRNA info rows: %d\n", nrow(sgrna_info)))
cat(sprintf("Unique genes: %d\n", length(unique(sgrna_info$gene))))

# Check sgRNAs per gene
sgrnas_per_gene <- sgrna_info %>% group_by(gene) %>%
  summarise(n_sgrnas = n(), .groups = "drop")

cat("\nsgRNAs per gene distribution:\n")
print(table(sgrnas_per_gene$n_sgrnas))

# Genes with exactly 2 sgRNAs
genes_with_2_sgrnas <- sgrnas_per_gene %>% filter(n_sgrnas == 2) %>% pull(gene)

cat(sprintf("\nGenes with exactly 2 sgRNAs: %d\n", length(genes_with_2_sgrnas)))
@

