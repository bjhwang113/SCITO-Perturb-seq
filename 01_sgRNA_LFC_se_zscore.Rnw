## --- Make sure “Mac-2 ” and similar map to clean keys ---
names(map)[names(map) == "Mac-2"] <- "Mac-2"

## --- Construct the output data frame in the same order as input markers ---
gene <- unname(map[markers])
# sanity check: flag any unmapped markers
unmapped <- which(is.na(gene) & !grepl("isotype", markers, ignore.case = TRUE))
if (length(unmapped)) {
  warning("Unmapped markers (non-isotype): ", paste(markers[unmapped], collapse = ", "))
}

marker_gene_df <- data.frame(marker = markers, gene = gene, stringsAsFactors = FALSE)
#saveRDS(marker_gene_df, file = "/home/ec2-user/scitoseq/data/marker_gene_df.rds")
@

<<self-targeted>>=
# SECTION 8: Self-Targeted Validation

# Load marker-gene mapping
marker_gene_df <- readRDS("/home/ec2-user/scitoseq/data/marker_gene_df.rds")

# Build gene-to-marker map
marker_gene_tidy <- marker_gene_df %>%
  mutate(gene_list = str_split(gene, pattern = ";")) %>%
  mutate(gene_list = lapply(gene_list, function(v) {
    v <- v[!is.na(v)]
    v <- trimws(v)
    v <- v[nzchar(v)]
    unique(v)
  }))

gene_to_marker_map <- marker_gene_tidy %>%
  select(marker, gene_list) %>%
  unnest_longer(gene_list, values_to = "gene_single") %>%
  filter(!is.na(gene_single), nzchar(gene_single)) %>%
  distinct(gene_single, marker)

cat(sprintf("Gene-to-marker mappings: %d\n", nrow(gene_to_marker_map)))

# Find self-targeted pairs
self_targeted <- data.frame()

for (i in 1:nrow(sgrna_info)) {
  sg <- sgrna_info$sgRNA[i]
  gene <- sgrna_info$gene[i]
  batch <- sgrna_info$batch[i]
  n_cells <- sgrna_info$n_cells[i]
  
  if (!(sg %in% rownames(lfc_mat))) next
  
  target_proteins <- gene_to_marker_map %>%
    filter(gene_single == gene) %>%
    pull(marker)
  
  target_proteins <- intersect(target_proteins, colnames(lfc_mat))
  
  if (length(target_proteins) == 0) next
  
  for (prot in target_proteins) {
    lfc <- lfc_mat[sg, prot]
    se <- se_mat[sg, prot]
    zscore <- zscore_mat[sg, prot]
    pval <- pval_mat[sg, prot]
    qval <- qval_mat[sg, prot]
    
    self_targeted <- rbind(self_targeted, data.frame(
      sgRNA = sg, gene = gene, protein = prot,
      batch = batch, n_cells = n_cells, lfc = lfc, se = se,
      zscore = zscore, pval = pval, qval = qval,
      stringsAsFactors = FALSE))
  }
}

cat(sprintf("Self-targeted pairs found: %d\n", nrow(self_targeted)))
cat(sprintf("  Unique genes: %d\n", length(unique(self_targeted$gene))))
cat(sprintf("  Unique proteins: %d\n", length(unique(self_targeted$protein))))

# Self-targeted validation metrics
cat("\n--- Self-Targeted Validation Metrics ---\n")
cat("For CRISPRa, ground truth = positive LFC expected\n\n")

cat(sprintf("Mean LFC: %.4f\n", mean(self_targeted$lfc, na.rm = TRUE)))
cat(sprintf("Median LFC: %.4f\n", median(self_targeted$lfc, na.rm = TRUE)))
cat(sprintf("%% Positive: %.1f%%\n", 100 * mean(self_targeted$lfc > 0, na.rm = TRUE)))
cat(sprintf("%% LFC > 0.10: %.1f%%\n", 100 * mean(self_targeted$lfc > 0.10, na.rm = TRUE)))
cat(sprintf("%% LFC > 0.50: %.1f%%\n", 100 * mean(self_targeted$lfc > 0.50, na.rm = TRUE)))

cat(sprintf("\nMean Z-score: %.4f\n", mean(self_targeted$zscore, na.rm = TRUE)))
cat(sprintf("Median Z-score: %.4f\n", median(self_targeted$zscore, na.rm = TRUE)))
cat(sprintf("%% Z > 1.96: %.1f%%\n", 100 * mean(self_targeted$zscore > 1.96, na.rm = TRUE)))
cat(sprintf("%% p < 0.05: %.1f%%\n", 100 * mean(self_targeted$pval < 0.05, na.rm = TRUE)))
cat(sprintf("%% FDR < 0.10: %.1f%%\n", 100 * mean(self_targeted$qval < 0.10, na.rm = TRUE)))
@

