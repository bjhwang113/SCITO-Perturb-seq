\section{Self-Targeted Concordance}

<<self-targeted-concordance>>=
# SECTION 9: Self-Targeted sgRNA Concordance

# Extract self-targeted concordance
self_targeted_paired <- paired_df %>% inner_join(
    gene_to_marker_map %>% 
      rename(gene = gene_single, protein = marker),
    by = c("gene", "protein"))

cat(sprintf("Self-targeted paired comparisons: %d\n", nrow(self_targeted_paired)))

if (nrow(self_targeted_paired) > 0) {
  n_conc_self <- sum(self_targeted_paired$concordant, na.rm = TRUE)
  n_disc_self <- sum(!self_targeted_paired$concordant, na.rm = TRUE)
  
  cat(sprintf("\n--- Self-Targeted Concordance ---\n"))
  cat(sprintf("Concordant: %d (%.1f%%)\n", 
              n_conc_self, 100 * n_conc_self / (n_conc_self + n_disc_self)))
  cat(sprintf("Discordant: %d (%.1f%%)\n", 
              n_disc_self, 100 * n_disc_self / (n_conc_self + n_disc_self)))
  
  # Correlation for self-targeted
  cor_self_lfc <- cor(self_targeted_paired$lfc1, self_targeted_paired$lfc2, 
                      method = "spearman", use = "complete.obs")
  cor_self_z <- cor(self_targeted_paired$z1, self_targeted_paired$z2, 
                    method = "spearman", use = "complete.obs")
  cat(sprintf("Spearman ρ (LFC): %.4f\n", cor_self_lfc))
  cat(sprintf("Spearman ρ (Z-score): %.4f\n", cor_self_z))
  
  # Both positive
  both_positive <- self_targeted_paired %>%
    filter(lfc1 > 0 & lfc2 > 0)
  
  cat(sprintf("\nBoth sgRNAs positive (CRISPRa validation): %d / %d (%.1f%%)\n",
              nrow(both_positive), nrow(self_targeted_paired),
              100 * nrow(both_positive) / nrow(self_targeted_paired)))
}
@

Self-targeted paired comparisons: 122
--- Self-Targeted Concordance ---
Concordant: 92 (75.4%)
Discordant: 30 (24.6%)
Spearman ρ (LFC): 0.5565
Spearman ρ (Z-score): 0.4400

Both sgRNAs positive (CRISPRa validation): 84 / 122 (68.9%)
Both sgRNAs positive (CRISPRa validation): 84 / 122 (68.9%)

\section{Reliability Analysis}

<<reliability>>=
# SECTION 10: Reliability / Correlation Ceiling Analysis

# Calculate reliability per protein
# reliability = sigma²_true / (sigma²_true + sigma²_error)
# sigma²_error = mean(SE²)
# sigma²_total = var(LFC)
# sigma²_true = sigma²_total - sigma²_error

reliability_per_protein <- sapply(all_proteins, function(prot) {
  lfc <- lfc_mat[, prot]
  se <- se_mat[, prot]
  
  # Remove NAs and invalid values
  valid <- !is.na(lfc) & !is.na(se) & se > 0 & is.finite(lfc) & is.finite(se)
  lfc <- lfc[valid]
  se <- se[valid]
  
  if (length(lfc) < 10) return(NA)
  
  # Variance components
  sigma2_total <- var(lfc)                    # Total observed variance
  sigma2_error <- mean(se^2)                  # Average measurement variance
  sigma2_true <- max(0, sigma2_total - sigma2_error)  # True signal variance
  
  # Reliability
  reliability <- sigma2_true / (sigma2_true + sigma2_error)
  return(reliability)
})

cat("--- Reliability Summary (Correlation Ceiling) ---\n")
cat(sprintf("Mean reliability: %.3f\n", mean(reliability_per_protein, na.rm = TRUE)))
cat(sprintf("Median reliability: %.3f\n", median(reliability_per_protein, na.rm = TRUE)))
cat(sprintf("Min reliability: %.3f\n", min(reliability_per_protein, na.rm = TRUE)))
cat(sprintf("Max reliability: %.3f\n", max(reliability_per_protein, na.rm = TRUE)))

# Theoretical maximum concordance
mean_rel <- mean(reliability_per_protein, na.rm = TRUE)
cat(sprintf("\nTheoretical max sgRNA correlation: ~%.3f\n", mean_rel))
cat(sprintf("Observed sgRNA correlation (Spearman): %.3f\n", cor_spearman))
if (mean_rel > 0) {
  cat(sprintf("Observed / Theoretical: %.1f%%\n", 100 * cor_spearman / mean_rel))
}
@

--- Reliability Summary (Correlation Ceiling) ---
Mean reliability: 0.084
Median reliability: 0.069
Min reliability: 0.000
Max reliability: 0.477
Theoretical max sgRNA correlation: ~0.084
Observed sgRNA correlation (Spearman): 0.015
Observed / Theoretical: 17.7%

\section{Visualizations}

<<visualizations, fig.width=14, fig.height=12>>=
# SECTION 11: Visualizations

# Plot 1: sgRNA1 vs sgRNA2 scatter (LFC)
p1 <- ggplot(paired_df, aes(x = lfc1, y = lfc2)) +
  geom_hex(bins = 100) +
  geom_abline(slope = 1, intercept = 0, color = "red", linetype = "dashed") +
  geom_hline(yintercept = 0, color = "gray50", linetype = "dotted") +
  geom_vline(xintercept = 0, color = "gray50", linetype = "dotted") +
  scale_fill_viridis_c(trans = "log10") +
  labs(title = "sgRNA Concordance (LFC)",
    subtitle = sprintf("ρ = %.3f, Concordance = %.1f%%", 
                       cor_spearman, 100 * n_concordant / n_total),
    x = "sgRNA1 LFC", y = "sgRNA2 LFC") +
  coord_fixed(xlim = c(-1, 1), ylim = c(-1, 1)) + theme_bw(base_size = 12)

# Plot 2: sgRNA1 vs sgRNA2 scatter (Z-score)
p2 <- ggplot(paired_df, aes(x = z1, y = z2)) + geom_hex(bins = 100) +
  geom_abline(slope = 1, intercept = 0, color = "red", linetype = "dashed") +
  geom_hline(yintercept = 0, color = "gray50", linetype = "dotted") +
  geom_vline(xintercept = 0, color = "gray50", linetype = "dotted") +
  scale_fill_viridis_c(trans = "log10") + labs(
    title = "sgRNA Concordance (Z-score)",
    subtitle = sprintf("ρ = %.3f", cor_z_pearson),
    x = "sgRNA1 Z-score", y = "sgRNA2 Z-score") +
  coord_fixed(xlim = c(-5, 5), ylim = c(-5, 5)) + theme_bw(base_size = 12)

# Plot 3: Self-targeted LFC distribution
p3 <- ggplot(self_targeted, aes(x = lfc)) +
  geom_histogram(bins = 50, fill = "steelblue", color = "white") +
  geom_vline(xintercept = 0, color = "red", linetype = "dashed", linewidth = 1) +
  geom_vline(xintercept = median(self_targeted$lfc, na.rm = TRUE), 
             color = "darkblue", linetype = "solid", linewidth = 1) + labs(
    title = "Self-Targeted LFC Distribution",
    subtitle = sprintf("Median = %.3f, %% Positive = %.1f%%",
                       median(self_targeted$lfc, na.rm = TRUE),
                       100 * mean(self_targeted$lfc > 0, na.rm = TRUE)),
    x = "LFC", y = "Count") +
  theme_bw(base_size = 12)

# Plot 4: Self-targeted Z-score distribution
p4 <- ggplot(self_targeted, aes(x = zscore)) +
  geom_histogram(bins = 50, fill = "coral", color = "white") +
  geom_vline(xintercept = 0, color = "red", linetype = "dashed", linewidth = 1) +
  geom_vline(xintercept = 1.96, color = "darkgreen", linetype = "dotted", linewidth = 1) +
  labs(
    title = "Self-Targeted Z-score Distribution",
    subtitle = sprintf("Median = %.3f, %% Z > 1.96 = %.1f%%",
                       median(self_targeted$zscore, na.rm = TRUE),
                       100 * mean(self_targeted$zscore > 1.96, na.rm = TRUE)),
    x = "Z-score", y = "Count") + theme_bw(base_size = 12)

# Plot 5: SE distribution
se_df <- data.frame(se = se_vals[1:min(1000000, length(se_vals))])
p5 <- ggplot(se_df, aes(x = se)) +
  geom_histogram(bins = 100, fill = "purple", color = "white") +
  labs(
    title = "SE Distribution",
    subtitle = sprintf("Median = %.4f", median(se_vals)),
    x = "Standard Error", y = "Count") +
  xlim(0, quantile(se_vals, 0.99)) + theme_bw(base_size = 12)

# Plot 6: Reliability per protein
rel_df <- data.frame(protein = names(reliability_per_protein), 
                      reliability = reliability_per_protein)
p6 <- ggplot(rel_df, aes(x = reorder(protein, reliability), y = reliability)) +
  geom_point(size = 0.5, alpha = 0.5) +
  geom_hline(yintercept = mean(reliability_per_protein, na.rm = TRUE), 
             color = "red", linetype = "dashed") +
  labs(
    title = "Reliability per Protein",
    subtitle = sprintf("Mean = %.3f", mean(reliability_per_protein, na.rm = TRUE)),
    x = "Protein (ordered)", y = "Reliability"
  ) +
  theme_bw(base_size = 12) +
  theme(axis.text.x = element_blank(), axis.ticks.x = element_blank())

# Combine plots
combined <- (p1 + p2) / (p3 + p4) / (p5 + p6)
print(combined)
@

\section{Save Results}

<<save-results>>=
# Create output directory
output_dir <- "/home/ec2-user/scitoseq/results/results_sgrna_level"
dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)

# Save matrices
saveRDS(lfc_mat, file.path(output_dir, "sgrna_lfc_mat.rds"))
cat(sprintf("Saved sgrna_lfc_mat: %d × %d\n", nrow(lfc_mat), ncol(lfc_mat)))

saveRDS(se_mat, file.path(output_dir, "sgrna_se_mat.rds"))
cat(sprintf("Saved sgrna_se_mat: %d × %d\n", nrow(se_mat), ncol(se_mat)))

saveRDS(zscore_mat, file.path(output_dir, "sgrna_zscore_mat.rds"))
cat(sprintf("Saved sgrna_zscore_mat: %d × %d\n", nrow(zscore_mat), ncol(zscore_mat)))

saveRDS(pval_mat, file.path(output_dir, "sgrna_pval_mat.rds"))
cat(sprintf("Saved sgrna_pval_mat: %d × %d\n", nrow(pval_mat), ncol(pval_mat)))

saveRDS(qval_mat, file.path(output_dir, "sgrna_qval_mat.rds"))
cat(sprintf("Saved sgrna_qval_mat: %d × %d\n", nrow(qval_mat), ncol(qval_mat)))

# Save cell counts
saveRDS(ncells_per_sgrna, file.path(output_dir, "sgrna_ncells.rds"))
cat(sprintf("Saved sgrna_ncells: %d sgRNAs\n", length(ncells_per_sgrna)))

# Save sgRNA info
saveRDS(sgrna_info, file.path(output_dir, "sgrna_info.rds"))

# Save paired concordance data
saveRDS(paired_df, file.path(output_dir, "sgrna_concordance.rds"))

# Save self-targeted data
saveRDS(self_targeted, file.path(output_dir, "self_targeted_sgrna.rds"))
saveRDS(self_targeted_paired, file.path(output_dir, "self_targeted_sgrna_paired.rds"))

# Save reliability
saveRDS(reliability_per_protein, file.path(output_dir, "reliability_per_protein.rds"))

# Create summary table
summary_df <- data.frame(
  Metric = c(
    "Total sgRNAs",
    "Total proteins", 
    "Total pairs",
    "Genes with 2 sgRNAs",
    "Overall concordance (LFC)",
    "Spearman correlation (LFC)",
    "Pearson correlation (Z-score)",
    "Mean reliability",
    "Self-targeted pairs",
    "Self-targeted % positive",
    "Self-targeted median LFC",
    "Self-targeted median Z",
    "Self-targeted concordance",
    "% p < 0.05",
    "% FDR < 0.10"
  ),
  Value = c(
    n_sgrnas,
    n_proteins,
    n_sgrnas * n_proteins,
    length(genes_with_2_sgrnas),
    sprintf("%.1f%%", 100 * n_concordant / n_total),
    sprintf("%.4f", cor_spearman),
    sprintf("%.4f", cor_z_pearson),
    sprintf("%.3f", mean(reliability_per_protein, na.rm = TRUE)),
    nrow(self_targeted),
    sprintf("%.1f%%", 100 * mean(self_targeted$lfc > 0, na.rm = TRUE)),
    sprintf("%.4f", median(self_targeted$lfc, na.rm = TRUE)),
    sprintf("%.4f", median(self_targeted$zscore, na.rm = TRUE)),
    sprintf("%.1f%%", 100 * n_conc_self / (n_conc_self + n_disc_self)),
    sprintf("%.2f%%", 100 * mean(p_vals < 0.05)),
    sprintf("%.3f%%", 100 * mean(qval_vec < 0.10))
  )
)

print(summary_df)
saveRDS(summary_df, file.path(output_dir, "summary.rds"))

cat(sprintf("\nResults saved to: %s\n", output_dir))
@

\section{Final Summary}

<<final-summary>>=
# FINAL SUMMARY: sgRNA-Level LFC, SE, and Z-Score Analysis

cat("METHOD:\n")
cat("  LFC = mean(sgRNA cells) - mean(NTC cells)\n")
cat("  SE = sqrt(var_sgRNA/n_sgRNA + var_NTC/n_NTC)\n")
cat("  Z-score = LFC / SE\n")
cat("  P-value = 2 * pt(-|Z|, df) with Welch-Satterthwaite df\n")
cat("  FDR = Benjamini-Hochberg correction\n\n")

cat("KEY RESULTS:\n")
cat(sprintf("  1. Overall concordance: %.1f%% (vs 50%% chance)\n", 
            100 * n_concordant / n_total))
cat(sprintf("  2. sgRNA LFC correlation: ρ = %.4f\n", cor_spearman))
cat(sprintf("  3. sgRNA Z-score correlation: r = %.4f\n", cor_z_pearson))
cat(sprintf("  4. Mean reliability (correlation ceiling): %.3f\n", 
            mean(reliability_per_protein, na.rm = TRUE)))
cat(sprintf("  5. Self-targeted positive rate: %.1f%% (CRISPRa validation)\n",
            100 * mean(self_targeted$lfc > 0, na.rm = TRUE)))
cat(sprintf("  6. Self-targeted concordance: %.1f%%\n",
            100 * n_conc_self / (n_conc_self + n_disc_self)))
cat(sprintf("  7. %% FDR < 0.10: %.3f%%\n", 100 * mean(qval_vec < 0.10)))
@

\end{document}
