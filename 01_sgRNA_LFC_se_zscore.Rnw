<<load-data>>=
# SECTION 1: Load Batch-Regressed Data

# Load the deviance-normalized (batch-regressed) data
RAW_RDS <- "/home/ec2-user/scitoseq/data/deviance_norm.rds"
raw_data <- readRDS(RAW_RDS)

# Clean protein names
old_names <- rownames(raw_data)
prefix_pat <- "^(anti-human-mouse-rat-|anti-mouse-human-|anti-human-mouse-|anti-human-|anti-mouse-|Mouse-|Rat-|ArmenianHamsterIgG-)"
clean_names <- gsub(prefix_pat, "", old_names)
clean_names <- gsub("-barcode\\d+$", "", clean_names)

# Extract counts and metadata
counts <- raw_data@assays$RNA@counts
rownames(counts) <- clean_names
meta <- raw_data@meta.data

cat(sprintf("Data dimensions: %d proteins × %d cells\n", nrow(counts), ncol(counts)))

rm(raw_data); gc()

# Create clean guide columns
meta$guide_target_clean <- ifelse(
  grepl("NO-TARGET", meta$guide_target, ignore.case = TRUE),
  "NTC", as.character(meta$guide_target))
meta$guide_target_clean <- factor(meta$guide_target_clean)

meta$guide_assignment_clean <- ifelse(
  meta$guide_target_clean == "NTC", 
  "NTC", 
  as.character(meta$guide_assignment))

# Summary
gene_targets <- setdiff(unique(as.character(meta$guide_target_clean)), "NTC")
all_sgrnas <- setdiff(unique(meta$guide_assignment_clean), "NTC")

cat(sprintf("Perturbation targets (genes): %d\n", length(gene_targets)))
cat(sprintf("sgRNAs (excluding NTC): %d\n", length(all_sgrnas)))
cat(sprintf("NTC cells: %d\n", sum(meta$guide_target_clean == "NTC")))
cat(sprintf("Perturbation cells: %d\n", sum(meta$guide_target_clean != "NTC")))

## ---------- Remove IgE / IgLightChainL ----------
drop_feats <- c("IgE", "IgLightChainL")
keep_rows  <- !(rownames(counts) %in% drop_feats)
counts <- counts[keep_rows, , drop = FALSE]

# Protein list
all_proteins <- rownames(counts)
n_proteins <- length(all_proteins)
cat(sprintf("Proteins: %d\n", n_proteins))
@

