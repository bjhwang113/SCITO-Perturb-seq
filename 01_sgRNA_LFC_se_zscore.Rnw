\section{sgRNA Concordance Analysis}

<<concordance-analysis>>=
# SECTION 7: sgRNA Concordance Analysis

# Build paired comparison data for genes with 2 sgRNAs
cat("Building paired sgRNA comparisons...\n")

paired_data <- list()

for (gene in genes_with_2_sgrnas) {
  gene_sgrnas <- sgrna_info %>% filter(gene == !!gene) %>% arrange(sgRNA) %>%
    pull(sgRNA)
  
  if (length(gene_sgrnas) != 2) next
  
  sg1 <- gene_sgrnas[1]
  sg2 <- gene_sgrnas[2]
  
  if (!(sg1 %in% rownames(lfc_mat)) || !(sg2 %in% rownames(lfc_mat))) next
  
  lfc1 <- lfc_mat[sg1, ]
  lfc2 <- lfc_mat[sg2, ]
  se1 <- se_mat[sg1, ]
  se2 <- se_mat[sg2, ]
  z1 <- zscore_mat[sg1, ]
  z2 <- zscore_mat[sg2, ]
  
  paired_data[[gene]] <- data.frame(
    gene = gene, protein = all_proteins, sgRNA1 = sg1,
    sgRNA2 = sg2, lfc1 = lfc1, lfc2 = lfc2, se1 = se1, se2 = se2,
    z1 = z1, z2 = z2, stringsAsFactors = FALSE)
}

paired_df <- bind_rows(paired_data)
cat(sprintf("Total paired comparisons: %d genes × %d proteins = %d pairs\n",
            length(unique(paired_df$gene)), length(all_proteins), nrow(paired_df)))

# Calculate concordance metrics
paired_df <- paired_df %>% mutate(
    concordant = sign(lfc1) == sign(lfc2),
    diff = abs(lfc1 - lfc2),
    mean_lfc = (lfc1 + lfc2) / 2,
    max_abs_lfc = pmax(abs(lfc1), abs(lfc2)),
    min_abs_lfc = pmin(abs(lfc1), abs(lfc2)),
    concordant_z = sign(z1) == sign(z2))

# Overall concordance
n_concordant <- sum(paired_df$concordant, na.rm = TRUE)
n_discordant <- sum(!paired_df$concordant, na.rm = TRUE)
n_total <- n_concordant + n_discordant

cat("\n--- Overall Concordance (LFC) ---\n")
cat(sprintf("Concordant (same sign): %d (%.1f%%)\n", 
            n_concordant, 100 * n_concordant / n_total))
cat(sprintf("Discordant (opposite signs): %d (%.1f%%)\n", 
            n_discordant, 100 * n_discordant / n_total))

# Correlation between sgRNA pairs
cor_pearson <- cor(paired_df$lfc1, paired_df$lfc2, method = "pearson", use = "complete.obs")
cor_spearman <- cor(paired_df$lfc1, paired_df$lfc2, method = "spearman", use = "complete.obs")
cor_z_pearson <- cor(paired_df$z1, paired_df$z2, method = "pearson", use = "complete.obs")

cat(sprintf("\nCorrelation between sgRNA1 and sgRNA2:\n"))
cat(sprintf("  LFC Pearson r: %.4f\n", cor_pearson))
cat(sprintf("  LFC Spearman ρ: %.4f\n", cor_spearman))
cat(sprintf("  Z-score Pearson r: %.4f\n", cor_z_pearson))

# Concordance by effect size threshold
cat("\n--- Concordance by Effect Size Threshold ---\n")
thresholds <- c(0.05, 0.10, 0.15, 0.20, 0.30, 0.50)

for (thresh in thresholds) {
  subset <- paired_df %>%
    filter(abs(lfc1) > thresh & abs(lfc2) > thresh)
  
  if (nrow(subset) > 0) {
    conc_rate <- mean(subset$concordant, na.rm = TRUE)
    cat(sprintf("Both |LFC| > %.2f: n=%d, concordance=%.1f%%\n",
                thresh, nrow(subset), 100 * conc_rate))
  }
}

# Concordance by Z-score threshold
cat("\n--- Concordance by Z-score Threshold ---\n")
z_thresholds <- c(1.0, 1.5, 1.96, 2.5, 3.0)

for (thresh in z_thresholds) {
  subset <- paired_df %>%
    filter(abs(z1) > thresh & abs(z2) > thresh)
  
  if (nrow(subset) > 0) {
    conc_rate <- mean(subset$concordant_z, na.rm = TRUE)
    cat(sprintf("Both |Z| > %.2f: n=%d, concordance=%.1f%%\n",
                thresh, nrow(subset), 100 * conc_rate))
  }
}
@

