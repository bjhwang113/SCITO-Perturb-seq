\section{Calculate NTC Statistics}

<<ntc-stats>>=
# SECTION 2: Calculate NTC Baseline Statistics

# Get NTC cell indices
ntc_idx <- which(meta$guide_assignment_clean == "NTC")
n_ntc <- length(ntc_idx)
cat(sprintf("NTC cells: %d\n", n_ntc))

# NTC counts matrix (proteins × NTC cells)
counts_ntc <- counts[, ntc_idx, drop = FALSE]

# NTC means (per protein)
ntc_means <- Matrix::rowMeans(counts_ntc)

# NTC variances (per protein)
# var(x) = E[x²] - E[x]²
ntc_sq_means <- Matrix::rowMeans(counts_ntc^2)
ntc_vars <- ntc_sq_means - ntc_means^2

# Apply Bessel's correction for sample variance: var * n/(n-1)
ntc_vars <- ntc_vars * n_ntc / (n_ntc - 1)

cat(sprintf("NTC mean range: [%.4f, %.4f]\n", min(ntc_means), max(ntc_means)))
cat(sprintf("NTC variance range: [%.4f, %.4f]\n", min(ntc_vars), max(ntc_vars)))

# Clean up
rm(counts_ntc); gc()
@

NTC mean range: [-0.0469, 0.0241]
NTC variance range: [0.8024, 1.4071]

\section{Calculate sgRNA Statistics (Vectorized)}

<<sgrna-stats>>=
# SECTION 3: Calculate sgRNA Statistics Using Vectorized Sparse Operations

# Get non-NTC cells
non_ntc_idx <- which(meta$guide_assignment_clean != "NTC")
sgrna_assignments <- meta$guide_assignment_clean[non_ntc_idx]
counts_non_ntc <- counts[, non_ntc_idx, drop = FALSE]

# Unique sgRNAs
unique_sgrnas <- sort(unique(sgrna_assignments))
n_sgrnas <- length(unique_sgrnas)

cat(sprintf("Computing statistics for %d sgRNAs across %d proteins...\n", 
            n_sgrnas, n_proteins))
# Computing statistics for 28104 sgRNAs across 201 proteins...
t_start <- Sys.time()

# VECTORIZED APPROACH: Use sparse matrix multiplication
# Build indicator matrix: rows = cells, cols = sgRNAs

cat("Building sgRNA indicator matrix...\n")

sgrna_factor <- factor(sgrna_assignments, levels = unique_sgrnas)

indicator_mat <- Matrix::sparseMatrix(
  i = seq_along(sgrna_assignments),
  j = as.integer(sgrna_factor),
  x = 1,
  dims = c(length(sgrna_assignments), n_sgrnas),
  dimnames = list(NULL, unique_sgrnas)
)

cat(sprintf("Indicator matrix: %d cells × %d sgRNAs\n", 
            nrow(indicator_mat), ncol(indicator_mat)))

# Cell counts per sgRNA
ncells_per_sgrna <- Matrix::colSums(indicator_mat)
names(ncells_per_sgrna) <- unique_sgrnas

cat(sprintf("Cell counts range: %d - %d (median: %.0f)\n",
            min(ncells_per_sgrna), max(ncells_per_sgrna), median(ncells_per_sgrna)))

# STEP 1: Compute sums via sparse matrix multiplication
# Result: (proteins × sgRNAs)
cat("Computing expression sums...\n")
sgrna_sums <- counts_non_ntc %*% indicator_mat
sgrna_sums_dense <- as.matrix(sgrna_sums)

# STEP 2: Compute sum of squares
# Square the counts element-wise, then multiply by indicator
cat("Computing sum of squares...\n")
counts_sq <- counts_non_ntc^2
sgrna_sumsq <- counts_sq %*% indicator_mat
sgrna_sumsq_dense <- as.matrix(sgrna_sumsq)

rm(counts_sq, sgrna_sums, sgrna_sumsq); gc()

# STEP 3: Compute means
# sgrna_means is (proteins × sgRNAs)
cat("Computing means...\n")
sgrna_means <- sweep(sgrna_sums_dense, 2, ncells_per_sgrna, "/")

# STEP 4: Compute variances using: var = E[x²] - E[x]²
# Then apply Bessel's correction: var * n/(n-1)
cat("Computing variances...\n")
sgrna_sq_means <- sweep(sgrna_sumsq_dense, 2, ncells_per_sgrna, "/")
sgrna_vars_uncorrected <- sgrna_sq_means - sgrna_means^2

# Apply Bessel's correction for sample variance
# For cells with n=1, variance is undefined (set to NA or large value)
bessel_factor <- ncells_per_sgrna / (ncells_per_sgrna - 1)
bessel_factor[ncells_per_sgrna <= 1] <- NA  # Handle n=1 case

sgrna_vars <- sweep(sgrna_vars_uncorrected, 2, bessel_factor, "*")

# Handle negative variances due to numerical precision (set to small positive)
sgrna_vars[sgrna_vars < 0 & !is.na(sgrna_vars)] <- 1e-10

# Clean up
rm(sgrna_sums_dense, sgrna_sumsq_dense, sgrna_sq_means, sgrna_vars_uncorrected); gc()

elapsed <- difftime(Sys.time(), t_start, units = "secs")
cat(sprintf("Statistics computation completed in %.1f seconds\n", elapsed))
@

Computing statistics for 28104 sgRNAs across 201 proteins...
Indicator matrix: 3108262 cells × 28104 sgRNAs
Cell counts range: 1 - 1237 (median: 88)
Statistics computation completed in 17.0 seconds

\section{Calculate LFC, SE, Z-score, and P-values}

<<calculate-lfc-se-zscore>>=
# SECTION 4: Calculate LFC, SE, Z-score, and P-values

# LFC = sgRNA mean - NTC mean
# Transpose to get (sgRNAs × proteins) format
cat("Computing LFC...\n")
lfc_mat <- t(sgrna_means) - matrix(ntc_means, nrow = n_sgrnas, ncol = n_proteins, byrow = TRUE)
rownames(lfc_mat) <- unique_sgrnas
colnames(lfc_mat) <- all_proteins

# SE = sqrt(var_sgRNA/n_sgRNA + var_NTC/n_NTC)
cat("Computing SE...\n")

# NTC variance contribution (constant for all sgRNAs)
# var_NTC / n_NTC for each protein
ntc_var_contrib <- ntc_vars / n_ntc

# sgRNA variance contribution: var_sgRNA / n_sgRNA
# sgrna_vars is (proteins × sgRNAs), need to divide each column by its n
sgrna_var_contrib <- sweep(sgrna_vars, 2, ncells_per_sgrna, "/")

# SE² = var_sgRNA/n_sgRNA + var_NTC/n_NTC
# Add NTC contribution (same for all sgRNAs) to each column
se_squared <- sgrna_var_contrib + matrix(ntc_var_contrib, 
                                          nrow = n_proteins, 
                                          ncol = n_sgrnas, 
                                          byrow = FALSE)

# SE matrix (transpose to sgRNAs × proteins)
se_mat <- t(sqrt(se_squared))
rownames(se_mat) <- unique_sgrnas
colnames(se_mat) <- all_proteins

# Z-score = LFC / SE
cat("Computing Z-scores...\n")
zscore_mat <- lfc_mat / se_mat

# P-values from Welch's t-test
# Two-sided: p = 2 * pt(-|Z|, df)
# Welch-Satterthwaite degrees of freedom approximation
cat("Computing p-values (Welch's t-test)...\n")

# Welch-Satterthwaite df formula:
# df = (var1/n1 + var2/n2)² / [(var1/n1)²/(n1-1) + (var2/n2)²/(n2-1)]

# For vectorized computation:
# s1² = var_sgRNA, n1 = n_sgRNA
# s2² = var_NTC, n2 = n_NTC

# Numerator: (s1²/n1 + s2²/n2)² = SE⁴
numerator_df <- se_squared^2

# Denominator terms
# Term 1: (s1²/n1)² / (n1-1) = (var_sgRNA/n_sgRNA)² / (n_sgRNA-1)
term1 <- sweep(sgrna_var_contrib^2, 2, ncells_per_sgrna - 1, "/")

# Term 2: (s2²/n2)² / (n2-1) = (var_NTC/n_NTC)² / (n_NTC-1)
term2 <- (ntc_var_contrib^2) / (n_ntc - 1)

# Denominator
denominator_df <- term1 + matrix(term2, nrow = n_proteins, ncol = n_sgrnas, byrow = FALSE)

# Degrees of freedom (proteins × sgRNAs)
df_mat <- numerator_df / denominator_df

# Ensure df is at least 1
df_mat[df_mat < 1 | is.na(df_mat)] <- 1

# Transpose to (sgRNAs × proteins)
df_mat <- t(df_mat)

# P-values: two-sided t-test
pval_mat <- 2 * pt(-abs(zscore_mat), df = df_mat)

# Clean up
rm(se_squared, sgrna_var_contrib, numerator_df, term1, denominator_df); gc()

cat("Calculations complete.\n")
@

\section{Summary Statistics}

<<summary-stats>>=
# SECTION 5: Summary Statistics

# --- LFC Summary ---
cat("--- LFC Summary ---\n")
lfc_vals <- as.vector(lfc_mat[!is.na(lfc_mat)])
cat(sprintf("Total (sgRNA, protein) pairs: %d\n", length(lfc_vals)))
cat(sprintf("Mean LFC: %.4f\n", mean(lfc_vals)))
cat(sprintf("Median LFC: %.4f\n", median(lfc_vals)))
cat(sprintf("SD LFC: %.4f\n", sd(lfc_vals)))
cat(sprintf("Min: %.3f, Max: %.3f\n", min(lfc_vals), max(lfc_vals)))
cat(sprintf("%% |LFC| > 0.05: %.1f%%\n", 100 * mean(abs(lfc_vals) > 0.05)))
cat(sprintf("%% |LFC| > 0.10: %.1f%%\n", 100 * mean(abs(lfc_vals) > 0.10)))
cat(sprintf("%% |LFC| > 0.20: %.1f%%\n", 100 * mean(abs(lfc_vals) > 0.20)))

# --- SE Summary ---
cat("\n--- SE Summary ---\n")
se_vals <- as.vector(se_mat[!is.na(se_mat)])
cat(sprintf("Mean SE: %.4f\n", mean(se_vals)))
cat(sprintf("Median SE: %.4f\n", median(se_vals)))
cat(sprintf("SD SE: %.4f\n", sd(se_vals)))
cat(sprintf("Min: %.4f, Max: %.4f\n", min(se_vals), max(se_vals)))

# --- Z-score Summary ---
cat("\n--- Z-score Summary ---\n")
z_vals <- as.vector(zscore_mat[!is.na(zscore_mat) & is.finite(zscore_mat)])
cat(sprintf("Mean Z: %.4f\n", mean(z_vals)))
cat(sprintf("Median Z: %.4f\n", median(z_vals)))
cat(sprintf("SD Z: %.4f\n", sd(z_vals)))
cat(sprintf("Min: %.3f, Max: %.3f\n", min(z_vals), max(z_vals)))
cat(sprintf("%% |Z| > 1.96: %.2f%%\n", 100 * mean(abs(z_vals) > 1.96)))
cat(sprintf("%% |Z| > 2.58: %.2f%%\n", 100 * mean(abs(z_vals) > 2.58)))
cat(sprintf("%% |Z| > 3.0: %.2f%%\n", 100 * mean(abs(z_vals) > 3.0)))

# --- P-value Summary ---
cat("\n--- P-value Summary ---\n")
p_vals <- as.vector(pval_mat[!is.na(pval_mat)])
cat(sprintf("%% p < 0.05: %.2f%%\n", 100 * mean(p_vals < 0.05)))
cat(sprintf("%% p < 0.01: %.2f%%\n", 100 * mean(p_vals < 0.01)))
cat(sprintf("%% p < 0.001: %.2f%%\n", 100 * mean(p_vals < 0.001)))

# --- FDR Correction ---
cat("\n--- FDR Correction (Benjamini-Hochberg) ---\n")
qval_vec <- p.adjust(p_vals, method = "BH")
cat(sprintf("%% FDR < 0.05: %.3f%%\n", 100 * mean(qval_vec < 0.05)))
cat(sprintf("%% FDR < 0.10: %.3f%%\n", 100 * mean(qval_vec < 0.10)))
cat(sprintf("%% FDR < 0.20: %.3f%%\n", 100 * mean(qval_vec < 0.20)))

# # Create FDR matrix
# qval_mat <- matrix(qval_vec, nrow = nrow(pval_mat), ncol = ncol(pval_mat))

# Create FDR matrix preserving NA structure
qval_mat <- pval_mat  # Copy structure including NAs
non_na_idx <- !is.na(pval_mat)
qval_mat[non_na_idx] <- p.adjust(pval_mat[non_na_idx], method = "BH")
rownames(qval_mat) <- rownames(pval_mat)
colnames(qval_mat) <- colnames(pval_mat)
dim(qval_mat) # 28104   201
@

