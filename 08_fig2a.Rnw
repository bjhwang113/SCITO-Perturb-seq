<<>>=
# Between-group and within-group mean correlations from NTC P×P matrix

# Build a matrix of group-level mean correlations
groups <- unique(prot_cluster_df$cluster_name)
n_groups <- length(groups)

group_cor_mat <- matrix(NA, nrow = n_groups, ncol = n_groups,
                        dimnames = list(groups, groups))

for (i in seq_along(groups)) {
  for (j in seq_along(groups)) {
    prots_i <- prot_cluster_df$protein[prot_cluster_df$cluster_name == groups[i]]
    prots_j <- prot_cluster_df$protein[prot_cluster_df$cluster_name == groups[j]]
    
    sub_mat <- prot_cor_ntc[prots_i, prots_j, drop = FALSE]
    
    if (i == j) {
      # Within-group: use upper triangle only (exclude diagonal = 1)
      vals <- sub_mat[upper.tri(sub_mat)]
    } else {
      # Between-group: use all entries
      vals <- as.vector(sub_mat)
    }
    
    group_cor_mat[i, j] <- mean(vals, na.rm = TRUE)
  }
}

cat("=== Group-level mean Pearson correlations (NTC) ===\n\n")
print(round(group_cor_mat, 4))
@
                   Activation Adhesion Cytokine/Chemokine Identity Innate-like
Activation             0.2304   0.1125             0.0227   0.2129      0.0576
Adhesion               0.1125   0.1037             0.0426   0.1628      0.0656
Cytokine/Chemokine     0.0227   0.0426             0.1486  -0.0044      0.0610
Identity               0.2129   0.1628            -0.0044   0.3837      0.0435
Innate-like            0.0576   0.0656             0.0610   0.0435      0.0812

<<>>=
# Tidy long-format table for easy reading
group_cor_long <- expand.grid(
  Group1 = groups, Group2 = groups, stringsAsFactors = FALSE) %>% rowwise() %>%
  mutate(
    mean_cor = group_cor_mat[Group1, Group2],
    type = ifelse(Group1 == Group2, "within", "between")
  ) %>% ungroup() %>% arrange(desc(type), desc(mean_cor))

cat("\n=== Within-group mean correlations ===\n")
group_cor_long %>% filter(type == "within") %>%  
  select(Group = Group1, mean_cor) %>% arrange(desc(mean_cor)) %>%
  print(n = Inf)
@
# A tibble: 5 × 2
  Group              mean_cor
  <chr>                 <dbl>
1 Identity             0.384 
2 Activation           0.230 
3 Cytokine/Chemokine   0.149 
4 Adhesion             0.104 
5 Innate-like          0.0812

<<>>=
cat("\n=== Between-group mean correlations (unique pairs) ===\n")
group_cor_long %>% filter(type == "between") %>% rowwise() %>%
  mutate(pair = paste(sort(c(Group1, Group2)), collapse = " — ")) %>%
  ungroup() %>% distinct(pair, .keep_all = TRUE) %>%
  select(pair, mean_cor) %>% arrange(desc(mean_cor)) %>%
  print(n = Inf)

group_cor_ordered <- group_cor_mat[CLUSTER_NAMES, CLUSTER_NAMES]
print(round(group_cor_ordered, 3))
@

