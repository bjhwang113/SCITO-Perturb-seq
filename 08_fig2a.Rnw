\SweaveOpts{concordance=TRUE}

from 218_V4.Rnw

Using Z-SCORE (not raw LFC) for heatmaps
Rationale: Z-score is confidence-weighted, downweights noisy estimates from genes with few cells, consistent with Zhu et al. 2025

Key design decisions:
1. Uses Z-SCORE (not raw LFC) for P×G heatmaps - confidence-weighted,
   consistent with Zhu et al. 2025
2. Square cells in P×P heatmaps
3. Explicit comparison of NTC vs LFC-derived P×P correlations

<<>>=
# COMPREHENSIVE CORRELATION ANALYSIS AND HEATMAP VISUALIZATION (v4)

suppressPackageStartupMessages({
  library(grid)
  library(dplyr)
  library(tidyr)
  library(Matrix)
  library(ggplot2)
  library(circlize)
  library(gridExtra)
  library(RColorBrewer)
  library(ComplexHeatmap)
})

set.seed(42)

DATA_DIR <- "/home/ec2-user/scitoseq/data"
RESULTS_DIR <- "/home/ec2-user/scitoseq/results/results_gene_level"
OUTPUT_DIR <- "/home/ec2-user/scitoseq/results/results_correlation"

# Parameters
HEATMAP_SIG_FDR <- 0.10
HEATMAP_Z_THRESHOLD <- 3
ZSCORE_CAP <- 3#5            # Cap Z-scores for visualization
N_PROTEIN_CLUSTERS <- 5

# Cluster names and colors
CLUSTER_NAMES <- c(
  "1" = "Activation",
  "2" = "Adhesion", 
  "3" = "Cytokine/Chemokine",
  "4" = "Identity",
  "5" = "Innate-like"
)

cluster_colors <- c(
  "Activation" = "#d7aca1",
  "Adhesion" = "#79ad41",
  "Cytokine/Chemokine" =  "#4063a3",
  "Identity" = "#ddc000",
  "Innate-like" = "#34b6c6"
)
# Isfahan2
@

<<>>=
# SECTION 1: LOAD DATA

# Load the deviance-normalized data for NTC correlation
cat("Loading deviance-normalized data...\n")
RAW_RDS <- file.path(DATA_DIR, "deviance_norm.rds")
raw_data <- readRDS(RAW_RDS)

# Clean protein names
old_names <- rownames(raw_data)
prefix_pat <- "^(anti-human-mouse-rat-|anti-mouse-human-|anti-human-mouse-|anti-human-|anti-mouse-|Mouse-|Rat-|ArmenianHamsterIgG-)"
clean_names <- gsub(prefix_pat, "", old_names)
clean_names <- gsub("-barcode\\d+$", "", clean_names)

# Extract counts and metadata
counts <- raw_data@assays$RNA@counts
rownames(counts) <- clean_names
meta <- raw_data@meta.data

cat(sprintf("Data dimensions: %d proteins × %d cells\n", nrow(counts), ncol(counts)))

rm(raw_data); gc()

# Create clean guide columns
meta$guide_target_clean <- ifelse(
  grepl("NO-TARGET", meta$guide_target, ignore.case = TRUE),
  "NTC", as.character(meta$guide_target))
meta$guide_assignment_clean <- ifelse(
  meta$guide_target_clean == "NTC", "NTC", as.character(meta$guide_assignment))

# Remove IgE / IgLightChainL
drop_feats <- c("IgE", "IgLightChainL")
keep_rows <- !(rownames(counts) %in% drop_feats)
counts <- counts[keep_rows, , drop = FALSE]

all_proteins <- rownames(counts)
n_proteins <- length(all_proteins)

cat(sprintf("Proteins after QC: %d\n", n_proteins))

# Load gene-level results
cat("\nLoading gene-level analysis results...\n")
gene_zscore_mat <- readRDS(file.path(RESULTS_DIR, "gene_zscore_mat.rds"))
gene_ncells <- readRDS(file.path(RESULTS_DIR, "gene_ncells.rds"))
@

Gene matrices: 17336 genes × 201 proteins

<<>>=
# SECTION 2: NTC PROTEIN-PROTEIN CORRELATION

# Extract NTC cells
ntc_idx <- which(meta$guide_assignment_clean == "NTC")
n_ntc <- length(ntc_idx)
cat(sprintf("NTC cells: %d\n", n_ntc))
# NTC cells: 26602

# NTC expression matrix
counts_ntc <- as.matrix(counts[, ntc_idx, drop = FALSE])

# Compute NTC protein-protein correlation
cat("Computing NTC protein-protein correlation...\n")
prot_cor_ntc <- cor(t(counts_ntc), method = "pearson")

rm(counts_ntc, counts); gc()

# Summary
ntc_upper <- prot_cor_ntc[upper.tri(prot_cor_ntc)]
cat(sprintf("NTC correlation: mean=%.4f, median=%.4f, SD=%.4f\n",
            mean(ntc_upper), median(ntc_upper), sd(ntc_upper)))


# SECTION 3: HIERARCHICAL CLUSTERING OF PROTEINS (FROM NTC)
prot_dist <- as.dist(1 - prot_cor_ntc)
prot_hclust <- hclust(prot_dist, method = "ward.D2")
prot_clusters_num <- cutree(prot_hclust, k = N_PROTEIN_CLUSTERS)

# Protein order from hierarchical clustering
proteins_ordered <- rownames(prot_cor_ntc)[prot_hclust$order]

# Create cluster assignments
prot_cluster_named <- sapply(prot_clusters_num, function(x) CLUSTER_NAMES[as.character(x)])
names(prot_cluster_named) <- names(prot_clusters_num)

prot_cluster_df <- data.frame(
  protein = names(prot_clusters_num),
  cluster_num = prot_clusters_num,
  cluster_name = prot_cluster_named,
  stringsAsFactors = FALSE
)

# Cluster order for annotations
cluster_ordered <- prot_cluster_df$cluster_name[match(proteins_ordered, prot_cluster_df$protein)]

cat("Protein clusters:\n")
print(table(prot_cluster_df$cluster_name))
# Activation    Adhesion Cytokine/Chemokine         Identity        Innate-like 
#        42          39                 39                24                 57 
                
# saveRDS(prot_cluster_df, paste0(OUTPUT_DIR, "/prot_cluster_df_ntc.rds"))
# print(paste0(OUTPUT_DIR, "/prot_cluster_df_ntc.rds"))
# # "/home/ec2-user/scitoseq/results/results_correlation/prot_cluster_df_ntc.rds"
head(prot_cluster_df)
@
