=== Innate-like (n=57) ===
CD103, CD106, CD117, CD11b, CD122, CD126, CD127, CD131, CD135, CD14, CD158e1, CD158f, CD16, CD161, CD185, CD192, CD193, CD1d, CD21, CD24, CD243, CD253, CD268, CD27, CD272, CD28, CD30, CD305, CD32, CD337, CD34, CD357, CD360, CD365, CD366, CD39, CD40, CD41, CD42b, CD56, CD57Recombinant, CD64, CD7, CD72, CD94, CLEC1B, FolateReceptorB, GPR56, HLA-A2, HLA-E, NKp80, Notch3, TCR-Va24-Ja18, TCRab, TIGIT, TIM-4, XCR1 

<<>>=
# SECTION 3: P×P NTC CORRELATION HEATMAP (SQUARE CELLS)

# Correlation color scale (0 = white, symmetric around 0)
cor_colors <- colorRamp2(
  c(-0.5, -0.2, 0, 0.2, 0.5),
  c("#2166AC", "#67A9CF", "white", "#EF8A62", "#B2182B")
)

zscore_colors <- colorRamp2(
  c(-ZSCORE_CAP, -ZSCORE_CAP/2, 0, ZSCORE_CAP/2, ZSCORE_CAP),
  c("#b08ba5",  "#c7a2b6", "white", "#ffb178", "#db8872")
)
#"#98768e", "#b08ba5", "#c7a2b6", "#dfbbc8", "#ffc680", "#ffb178", "#db8872", "#a56457"
# Morgenstern

# Reorder matrix
prot_cor_ntc_ordered <- prot_cor_ntc[proteins_ordered, proteins_ordered]

# Calculate cell size for square cells
# For n proteins, we want width = height
n_prot <- length(proteins_ordered)
cell_size <- 1 # 0.6 #0.4  # mm per cell
heatmap_size <- n_prot * cell_size / 10  # convert to cm

cat(sprintf("Heatmap size: %.1f cm × %.1f cm (%.1f mm per cell)\n", 
            heatmap_size, heatmap_size, cell_size))

# Row annotation
row_anno_pxp <- rowAnnotation(
  Group = cluster_ordered,
  col = list(Group = cluster_colors),
  show_annotation_name = FALSE,
  simple_anno_size = unit(4, "mm"),#unit(3, "mm"),
  show_legend = FALSE
)

# Column annotation
col_anno_pxp <- HeatmapAnnotation(
  Group = cluster_ordered,
  col = list(Group = cluster_colors),
  show_annotation_name = FALSE,
  simple_anno_size = unit(3, "mm"),
  annotation_legend_param = list(
    Group = list(
      title = "Protein Group",
      title_gp = gpar(fontsize = 12, fontface = "bold"),
      labels_gp = gpar(fontsize = 11)
    )
  )
)

cat("Generating NTC P×P correlation heatmap...\n")
fig_dir <- "/home/ec2-user/scitoseq/fig/fig2/"
pdf(file.path(fig_dir, "pxp_ntc_correlation_square.pdf"), width = 10, height = 10)

ht_ntc <- Heatmap(
  prot_cor_ntc_ordered,
  name = "Correlation",
  col = cor_colors,
  
  cluster_rows = FALSE,
  cluster_columns = FALSE,
  
  left_annotation = row_anno_pxp,
  top_annotation = col_anno_pxp,
  
  show_row_names = FALSE,#TRUE,
  show_column_names = FALSE,#TRUE,
  row_names_gp = gpar(fontsize = 4),
  column_names_gp = gpar(fontsize = 4),
  column_names_rot = 90,
  
  column_title = sprintf("Protein-Protein Correlation (NTC, n=%s)", format(n_ntc, big.mark=",")),
  column_title_gp = gpar(fontsize = 12, fontface = "bold"),
  
  heatmap_legend_param = list(
    title = "Pearson\nCorrelation",
    title_gp = gpar(fontsize = 9, fontface = "bold"),
    legend_height = unit(3, "cm"),
    at = c(-0.4, -0.2, 0, 0.2, 0.4, 0.8)
  ),
  
  # Square cells: equal width and height
  width = unit(heatmap_size, "cm"),
  height = unit(heatmap_size, "cm"),
  
  border = TRUE,
  border_gp = gpar(col = "gray40", lwd = 0.5),
  rect_gp = gpar(col = NA)
)

draw(ht_ntc, merge_legend = TRUE)
dev.off()

