CD86     CD86           1         Activation
CD274   CD274           2           Adhesion
CD273   CD273           2           Adhesion
CD270   CD270           3 Cytokine/Chemokine
CD47     CD47           4           Identity
CD70     CD70           1         Activation

<<>>=
for (cl in CLUSTER_NAMES) {
  prots <- prot_cluster_df$protein[prot_cluster_df$cluster_name == cl]
  cat(sprintf("\n=== %s (n=%d) ===\n", cl, length(prots)))
  cat(paste(sort(prots), collapse = ", "), "\n")
}
