<<>>=
# SECTION 4: PREPARE HEATMAP COMPONENTS

results_dir <- "/home/ec2-user/scitoseq/results/results_gene_level"
FDR_VERSION <- "per_protein"
if (FDR_VERSION == "global") {
  gene_qval_mat <- readRDS(file.path(results_dir, "gene_qval_mat.rds"))
  cat("Using GLOBAL FDR (BH across 3.5M tests) - most conservative\n")
} else if (FDR_VERSION == "per_protein") {
  # FIXED: per-protein FDR is in CORR_DIR
  gene_qval_mat <- readRDS(file.path(results_dir, "gene_qval_per_protein.rds"))
  cat("Using PER-PROTEIN FDR (BH across 17K genes per protein)\n")
} else if (FDR_VERSION == "per_gene") {
  # FIXED: per-gene FDR is in CORR_DIR
  gene_qval_mat <- readRDS(file.path(results_dir, "gene_qval_per_gene.rds"))
  cat("WARNING: Using PER-GENE FDR (only 201 tests per gene) - may inflate false positives!\n")
}

# Significant genes
HEATMAP_SIG_FDR <- 0.10
sig_genes_fdr <- unique(which(gene_qval_mat < HEATMAP_SIG_FDR, arr.ind = TRUE)[, 1])
sig_gene_names_fdr <- rownames(gene_zscore_mat)[sig_genes_fdr]
length(sig_gene_names_fdr)# 2848

# Genes with at least one FDR < 0.10 (for P×P correlation)
genes_with_any_sig <- rownames(gene_qval_mat)[sig_genes_fdr]
cat(sprintf("Genes with at least one GLOBAL FDR < %.2f: %d\n", HEATMAP_SIG_FDR, length(genes_with_any_sig)))
# # Genes with at least one FDR < 0.10: 2848

# Reorder NTC correlation matrix
prot_cor_ntc_ordered <- prot_cor_ntc[proteins_ordered, proteins_ordered]

# Row annotation for combined heatmaps
row_anno_combined <- rowAnnotation(
  Group = cluster_ordered,
  col = list(Group = cluster_colors),
  show_annotation_name = FALSE,
  simple_anno_size = unit(3, "mm"),
  annotation_legend_param = list(
    Group = list(title = "Functional\nGroup")
  )
)

# NTC heatmap (left panel, same for all)
ht_ntc_combined <- Heatmap(
  prot_cor_ntc_ordered,
  name = "Correlation",
  col = cor_colors,
  
  cluster_rows = FALSE,
  cluster_columns = FALSE,
  
  show_row_names = FALSE,
  show_column_names = FALSE,
  
  column_title = "P×P Correlation\n(NTC)",
  column_title_gp = gpar(fontsize = 10, fontface = "bold"),
  
  heatmap_legend_param = list(
    title = "Pearson\nCorrelation",
    legend_height = unit(3, "cm"),
    at = c(-0.4, 0, 0.4, 0.8)),
  
  width = unit(9, "cm"),
  height = unit(9, "cm"),
  
  border = TRUE,
  rect_gp = gpar(col = NA)
)

# SECTION 5: HEATMAP WITH PER-PROTEIN FDR SELECTION

# Select genes with at least one FDR < 0.10 (per-protein)
FDR_THRESHOLD <- 0.1
cat(sprintf("Selecting genes with ≥1 protein at per-protein FDR < %.2f...\n", FDR_THRESHOLD))

genes_sig_per_protein <- rownames(gene_qval_mat)[rowSums(gene_qval_mat < FDR_THRESHOLD, na.rm = TRUE) >= 1]
cat(sprintf("Number of genes: %d\n", length(genes_sig_per_protein)))
# Number of genes: 2848

# Prepare Z-score matrix for these genes
zscore_per_protein <- t(gene_zscore_mat[genes_sig_per_protein, , drop = FALSE])
zscore_per_protein_ordered <- zscore_per_protein[proteins_ordered, , drop = FALSE]

# Cluster genes
zscore_for_clust <- t(zscore_per_protein_ordered)
zscore_for_clust[is.na(zscore_for_clust)] <- 0
gene_hclust_per_protein <- hclust(dist(zscore_for_clust), method = "ward.D2")
genes_ordered_per_protein <- colnames(zscore_per_protein_ordered)[gene_hclust_per_protein$order]
zscore_per_protein_final <- zscore_per_protein_ordered[, genes_ordered_per_protein]

# Cap Z-scores
zscore_per_protein_capped <- pmax(pmin(zscore_per_protein_final, ZSCORE_CAP), -ZSCORE_CAP)

cat(sprintf("Per-protein FDR Z-score matrix: %d proteins × %d genes\n", 
            nrow(zscore_per_protein_capped), ncol(zscore_per_protein_capped)))


# Key proteins to label (3-5 per module)
# key_proteins <- c(
#   "CD25", "CD134", "CD137", "HLA-DR", "CD71",
#   "CD62L", "CD274", "Notch1", "KLRG1",
#   "CD183", "CD197", "CD279", "CX3CR1", "GARP",
#   "CD4", "CD45", "HLA-ABC", "CD29", "CD47",
#   "CD56", "CD161", "TIGIT", "CD366", "CD28"
# )
key_proteins <- c(
  # Identity
  "CD4", "CD45", "CD47", "CD29",
  # Activation
  "CD25", "CD134", "CD137", "CD71",
  # Cytokine/Chemokine
  "CD183", "CD197", "CD279", "GARP",
  # Adhesion
  "CD62L", "CD31", "KLRG1", "Notch1",
  # Innate-like
  "CD56", "CD161", "TIGIT", "CD366"
)

# # Indices in the ordered protein list (rows of the heatmap)
# mark_idx <- which(proteins_ordered %in% key_proteins)
# mark_labels <- proteins_ordered[mark_idx]
# 
# right_anno_mark <- rowAnnotation(
#   mark = anno_mark(
#     at = mark_idx,
#     labels = mark_labels,
#     labels_gp = gpar(fontsize = 7),
#     link_width = unit(5, "mm"),
#     link_gp = gpar(col = "gray50", lwd = 0.5)
#   )
# )
# Get cluster color for each labeled protein
mark_idx <- which(proteins_ordered %in% key_proteins)
mark_labels <- proteins_ordered[mark_idx]
mark_cluster <- prot_cluster_df$cluster_name[match(mark_labels, prot_cluster_df$protein)]
mark_colors <- cluster_colors[mark_cluster]

right_anno_mark <- rowAnnotation(
  mark = anno_mark(
    at = mark_idx, labels = mark_labels,
    labels_gp = gpar(fontsize = 7, col = mark_colors, fontface = "bold"),
    link_width = unit(5, "mm"),
    link_gp = gpar(col = "gray50", lwd = 0.5)))

# Create right panel heatmap
ht_zscore_per_protein <- Heatmap(
  zscore_per_protein_capped,
  name = "Z-score",
  col = zscore_colors,
  
  right_annotation = right_anno_mark,
  
  cluster_rows = FALSE,
  cluster_columns = FALSE,
  
  show_row_names = FALSE,
  show_column_names = FALSE,
  
  column_title = sprintf("P×G Perturbation Z-scores\n(%d Genes: Per-Protein FDR<%.2f)", 
                         length(genes_sig_per_protein), FDR_THRESHOLD),
  column_title_gp = gpar(fontsize = 10, fontface = "bold"),
  
  heatmap_legend_param = list(
    title = "Z-score",
    legend_height = unit(3, "cm"),
    at = c(-ZSCORE_CAP, 0, ZSCORE_CAP),
    labels = c(sprintf("≤%.0f", -ZSCORE_CAP), "0", sprintf("≥%.0f", ZSCORE_CAP))
  ),
  
  use_raster = TRUE,
  raster_quality = 3,
  
  width = unit(20, "cm"),#16, "cm"),
  height = unit(9, "cm"),
  
  border = TRUE,
  rect_gp = gpar(col = NA)
)

cat("Generating combined heatmap (NTC + per-protein FDR genes)...\n")

pdf(file.path(fig_dir, "combined_ntc_zscore_perprotein_fdr3.pdf"), width = 20, height = 9)#16, height = 9)

draw(row_anno_combined + ht_ntc_combined + ht_zscore_per_protein,
     merge_legend = TRUE,
     heatmap_legend_side = "right",
     annotation_legend_side = "right",
     column_title = "Protein Co-expression (NTC) vs Perturbation Response Z-scores (Per-Protein FDR)",
     column_title_gp = gpar(fontsize = 13, fontface = "bold"))

dev.off()

