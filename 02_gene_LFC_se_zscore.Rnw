\section{Reliability Analysis (Gene-Level)}

<<reliability>>=
# SECTION 9: Reliability / Correlation Ceiling Analysis (Gene-Level)

# Calculate reliability per protein at GENE level
# reliability = sigma²_true / (sigma²_true + sigma²_error)

reliability_gene_per_protein <- sapply(all_proteins, function(prot) {
  lfc <- gene_lfc_mat[, prot]
  se <- gene_se_mat[, prot]
  
  # Remove NAs and invalid values
  valid <- !is.na(lfc) & !is.na(se) & se > 0 & is.finite(lfc) & is.finite(se)
  lfc <- lfc[valid]
  se <- se[valid]
  
  if (length(lfc) < 10) return(NA)
  
  # Variance components
  sigma2_total <- var(lfc)
  sigma2_error <- mean(se^2)
  sigma2_true <- max(0, sigma2_total - sigma2_error)
  
  # Reliability
  reliability <- sigma2_true / (sigma2_true + sigma2_error)
  return(reliability)
})

cat("--- Reliability Summary (Gene-Level, Filtered) ---\n")
cat(sprintf("Mean reliability: %.3f\n", mean(reliability_gene_per_protein, na.rm = TRUE)))
cat(sprintf("Median reliability: %.3f\n", median(reliability_gene_per_protein, na.rm = TRUE)))
cat(sprintf("Min reliability: %.3f\n", min(reliability_gene_per_protein, na.rm = TRUE)))
cat(sprintf("Max reliability: %.3f\n", max(reliability_gene_per_protein, na.rm = TRUE)))

cat("\n--- Interpretation ---\n")
cat("Reliability reflects fraction of variance that is true signal.\n")
cat("Low values expected because most gene-protein pairs are true nulls.\n")
cat("Self-targeted pairs provide better validation of data quality.\n")
@

