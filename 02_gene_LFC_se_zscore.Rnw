\section{Visualizations}

<<visualizations, fig.width=14, fig.height=12>>=
# SECTION 11: Visualizations

# Plot 1: LFC distribution (gene-level)
p1 <- ggplot(
  data.frame(lfc = lfc_vals[1:min(500000, length(lfc_vals))]), aes(x = lfc)) +
  geom_histogram(bins = 100, fill = "steelblue", color = "white") +
  geom_vline(xintercept = 0, color = "red", linetype = "dashed") +
  labs(title = "Gene-Level LFC Distribution",
    subtitle = sprintf("n_cells >= %d | Median = %.4f, SD = %.4f", 
                       MIN_CELLS_PER_GENE, median(lfc_vals), sd(lfc_vals)),
    x = "LFC", y = "Count") + xlim(-1, 1) + theme_bw(base_size = 12)

# Plot 2: Z-score distribution (gene-level)
p2 <- ggplot(data.frame(z = z_vals[1:min(500000, length(z_vals))]), aes(x = z)) +
  geom_histogram(bins = 100, fill = "coral", color = "white") +
  geom_vline(xintercept = c(-1.96, 1.96), color = "darkgreen", linetype = "dotted") +
  labs(title = "Gene-Level Z-score Distribution",
    subtitle = sprintf("n_cells >= %d | SD = %.3f, %% |Z|>1.96 = %.1f%%", 
                       MIN_CELLS_PER_GENE, sd(z_vals), 100 * mean(abs(z_vals) > 1.96)),
    x = "Z-score", y = "Count") + xlim(-5, 5) +
  theme_bw(base_size = 12)

# Plot 3: Self-targeted LFC distribution (gene-level)
p3 <- ggplot(self_targeted_gene, aes(x = lfc)) +
  geom_histogram(bins = 40, fill = "darkgreen", color = "white") +
  geom_vline(xintercept = 0, color = "red", linetype = "dashed", linewidth = 1) +
  geom_vline(xintercept = median(self_targeted_gene$lfc, na.rm = TRUE), 
             color = "blue", linetype = "solid", linewidth = 1) +
  labs(
    title = "Self-Targeted LFC (Gene-Level)",
    subtitle = sprintf("Median = %.3f, %% Positive = %.1f%%",
                       median(self_targeted_gene$lfc, na.rm = TRUE),
                       100 * mean(self_targeted_gene$lfc > 0, na.rm = TRUE)),
    x = "LFC", y = "Count") + theme_bw(base_size = 12)

# Plot 4: Self-targeted Z-score distribution (gene-level)
p4 <- ggplot(self_targeted_gene, aes(x = zscore)) +
  geom_histogram(bins = 40, fill = "purple", color = "white") +
  geom_vline(xintercept = 0, color = "red", linetype = "dashed", linewidth = 1) +
  geom_vline(xintercept = 1.96, color = "darkgreen", linetype = "dotted", linewidth = 1) +
  labs(
    title = "Self-Targeted Z-score (Gene-Level)",
    subtitle = sprintf("Median = %.3f, %% Z > 1.96 = %.1f%%",
                       median(self_targeted_gene$zscore, na.rm = TRUE),
                       100 * mean(self_targeted_gene$zscore > 1.96, na.rm = TRUE)),
    x = "Z-score", y = "Count") + theme_bw(base_size = 12)

# Plot 5: SE distribution (gene-level)
p5 <- ggplot(data.frame(se = se_vals[1:min(500000, length(se_vals))]), 
             aes(x = se)) +
  geom_histogram(bins = 100, fill = "orange", color = "white") + labs(
    title = "Gene-Level SE Distribution",
    subtitle = sprintf("n_cells >= %d | Median = %.4f", MIN_CELLS_PER_GENE, median(se_vals)),
    x = "Standard Error", y = "Count") +
  xlim(0, quantile(se_vals, 0.99)) + theme_bw(base_size = 12)

# Plot 6: Volcano plot
volcano_sample <- hits_df %>% sample_n(min(100000, nrow(hits_df)))

p6 <- ggplot(volcano_sample, aes(x = lfc, y = -log10(pval), color = self_targeted)) +
  geom_point(alpha = 0.3, size = 0.5) +
  geom_hline(yintercept = -log10(0.05), color = "red", linetype = "dashed") +
  geom_vline(xintercept = c(-0.1, 0.1), color = "blue", linetype = "dotted") +
  scale_color_manual(values = c("FALSE" = "gray50", "TRUE" = "red")) +
  labs(
    title = "Volcano Plot (Gene-Level)",
    subtitle = sprintf("n_cells >= %d | Red points = self-targeted", MIN_CELLS_PER_GENE),
    x = "LFC", y = "-log10(p-value)") +
  xlim(-1.5, 1.5) + theme_bw(base_size = 12) + theme(legend.position = "none")

combined <- (p1 + p2) / (p3 + p4) / (p5 + p6)
print(combined)
@

\section{Save Results}

<<save-results>>=
# Create output directory (include filter parameter in name for clarity)
output_dir <- "/home/ec2-user/scitoseq/results/results_gene_level"
dir.create(output_dir, showWarnings = FALSE, recursive = TRUE)

# Save analysis parameters
params <- list(
  MIN_CELLS_PER_GENE = MIN_CELLS_PER_GENE, n_genes_total = n_genes_total,
  n_genes_filtered = n_genes, n_genes_removed = n_genes_fail,
  analysis_date = Sys.Date())
saveRDS(params, file.path(output_dir, "analysis_params.rds"))
cat(sprintf("Saved analysis_params.rds (MIN_CELLS = %d)\n", MIN_CELLS_PER_GENE))

# Save matrices
saveRDS(gene_lfc_mat, file.path(output_dir, "gene_lfc_mat.rds"))
cat(sprintf("Saved gene_lfc_mat: %d × %d\n", nrow(gene_lfc_mat), ncol(gene_lfc_mat)))

saveRDS(gene_se_mat, file.path(output_dir, "gene_se_mat.rds"))
cat(sprintf("Saved gene_se_mat: %d × %d\n", nrow(gene_se_mat), ncol(gene_se_mat)))

saveRDS(gene_zscore_mat, file.path(output_dir, "gene_zscore_mat.rds"))
cat(sprintf("Saved gene_zscore_mat: %d × %d\n", nrow(gene_zscore_mat), ncol(gene_zscore_mat)))

saveRDS(gene_pval_mat, file.path(output_dir, "gene_pval_mat.rds"))
cat(sprintf("Saved gene_pval_mat: %d × %d\n", nrow(gene_pval_mat), ncol(gene_pval_mat)))

saveRDS(gene_qval_mat, file.path(output_dir, "gene_qval_mat.rds"))
cat(sprintf("Saved gene_qval_mat: %d × %d\n", nrow(gene_qval_mat), ncol(gene_qval_mat)))

# Save cell counts (both filtered and unfiltered)
saveRDS(ncells_per_gene, file.path(output_dir, "gene_ncells.rds"))
cat(sprintf("Saved gene_ncells: %d genes (filtered)\n", length(ncells_per_gene)))

saveRDS(ncells_per_gene_unfiltered, file.path(output_dir, "gene_ncells_unfiltered.rds"))
cat(sprintf("Saved gene_ncells_unfiltered: %d genes (all)\n", length(ncells_per_gene_unfiltered)))

# Save gene info (both filtered and all)
saveRDS(gene_info, file.path(output_dir, "gene_info.rds"))
saveRDS(gene_info_all, file.path(output_dir, "gene_info_all.rds"))

# Save self-targeted data
saveRDS(self_targeted_gene, file.path(output_dir, "self_targeted_gene.rds"))

# Save reliability
saveRDS(reliability_gene_per_protein, file.path(output_dir, "reliability_gene_per_protein.rds"))

# Save top hits
saveRDS(hits_df, file.path(output_dir, "all_hits_df.rds"))

# Create summary table
summary_gene <- data.frame(
  Metric = c(
    "Analysis Level",
    "MIN_CELLS_PER_GENE filter",
    "Total genes (before filter)",
    "Genes passing filter",
    "Genes removed by filter",
    "Total proteins", 
    "Total pairs (filtered)",
    "Median cells per gene",
    "Median SE",
    "Z-score SD",
    "% |Z| > 1.96",
    "% p < 0.05",
    "% FDR < 0.05",
    "% FDR < 0.10",
    "Mean reliability",
    "Self-targeted pairs",
    "Self-targeted % positive",
    "Self-targeted median LFC",
    "Self-targeted median Z",
    "Self-targeted % Z > 1.96",
    "Self-targeted % FDR < 0.10"
  ),
  Value = c(
    "GENE (PRIMARY)",
    as.character(MIN_CELLS_PER_GENE),
    as.character(n_genes_total),
    as.character(n_genes),
    as.character(n_genes_fail),
    as.character(n_proteins),
    as.character(n_genes * n_proteins),
    sprintf("%.0f", median(ncells_per_gene)),
    sprintf("%.4f", median(se_vals)),
    sprintf("%.3f", sd(z_vals)),
    sprintf("%.2f%%", 100 * mean(abs(z_vals) > 1.96)),
    sprintf("%.2f%%", 100 * mean(p_vals < 0.05)),
    sprintf("%.3f%%", 100 * mean(q_vals < 0.05)),
    sprintf("%.3f%%", 100 * mean(q_vals < 0.10)),
    sprintf("%.3f", mean(reliability_gene_per_protein, na.rm = TRUE)),
    as.character(nrow(self_targeted_gene)),
    sprintf("%.1f%%", 100 * mean(self_targeted_gene$lfc > 0, na.rm = TRUE)),
    sprintf("%.4f", median(self_targeted_gene$lfc, na.rm = TRUE)),
    sprintf("%.4f", median(self_targeted_gene$zscore, na.rm = TRUE)),
    sprintf("%.1f%%", 100 * mean(self_targeted_gene$zscore > 1.96, na.rm = TRUE)),
    sprintf("%.1f%%", 100 * mean(self_targeted_gene$qval < 0.10, na.rm = TRUE))
  )
)

print(summary_gene)
saveRDS(summary_gene, file.path(output_dir, "summary_gene.rds"))

cat(sprintf("\nResults saved to: %s\n", output_dir))
@

