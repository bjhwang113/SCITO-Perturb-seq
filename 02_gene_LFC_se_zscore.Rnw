\section{Top Hits by Z-score}

<<top-hits>>=
# SECTION 10: Top Hits by Z-score

# Convert to long format for ranking
hits_df <- data.frame(
  gene = rep(rownames(gene_lfc_mat), ncol(gene_lfc_mat)),
  protein = rep(colnames(gene_lfc_mat), each = nrow(gene_lfc_mat)),
  lfc = as.vector(gene_lfc_mat),
  se = as.vector(gene_se_mat),
  zscore = as.vector(gene_zscore_mat),
  pval = as.vector(gene_pval_mat),
  qval = as.vector(gene_qval_mat)
)

# Add cell counts
hits_df$n_cells <- ncells_per_gene[hits_df$gene]

# Mark self-targeted
hits_df$self_targeted <- paste(hits_df$gene, hits_df$protein, sep = "_") %in%
  paste(self_targeted_gene$gene, self_targeted_gene$protein, sep = "_")

# Remove NAs
hits_df <- hits_df %>% filter(!is.na(zscore) & is.finite(zscore))

cat(sprintf("Total gene-protein pairs (after filtering): %d\n", nrow(hits_df)))
cat(sprintf("Min n_cells in results: %d (should be >= %d)\n", 
            min(hits_df$n_cells), MIN_CELLS_PER_GENE))

# Top positive Z-scores (upregulation)
cat("\n--- Top 20 Positive Z-scores (Upregulation) ---\n")
top_pos <- hits_df %>% arrange(desc(zscore)) %>% head(20) %>% mutate(
    lfc = round(lfc, 3), zscore = round(zscore, 2),
    qval = formatC(qval, format = "e", digits = 2)) %>%
  dplyr::select(gene, protein, lfc, zscore, qval, n_cells, self_targeted)

print(top_pos, row.names = FALSE)

# Top negative Z-scores (downregulation)
cat("\n--- Top 20 Negative Z-scores (Downregulation) ---\n")
top_neg <- hits_df %>% arrange(zscore) %>% head(20) %>% mutate(
    lfc = round(lfc, 3), zscore = round(zscore, 2),
    qval = formatC(qval, format = "e", digits = 2)) %>%
  dplyr::select(gene, protein, lfc, zscore, qval, n_cells, self_targeted)

print(top_neg, row.names = FALSE)

# Top self-targeted hits
cat("\n--- Top 20 Self-Targeted Hits by Z-score ---\n")
top_self <- hits_df %>% filter(self_targeted) %>%
  arrange(desc(zscore)) %>% head(20) %>% mutate(
    lfc = round(lfc, 3), zscore = round(zscore, 2),
    qval = formatC(qval, format = "e", digits = 2)) %>%
  dplyr::select(gene, protein, lfc, zscore, qval, n_cells)

print(top_self, row.names = FALSE)
@

