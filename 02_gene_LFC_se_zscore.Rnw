\section{Self-Targeted Validation (Gene-Level)}

<<self-targeted>>=
# SECTION 8: Self-Targeted Validation (Gene-Level)

# Load marker-gene mapping
marker_gene_df <- readRDS("/home/ec2-user/scitoseq/data/marker_gene_df.rds")

# Build gene-to-marker map (expand semicolon-separated genes)
marker_gene_tidy <- marker_gene_df %>%
  mutate(gene_list = str_split(gene, pattern = ";")) %>%
  mutate(gene_list = lapply(gene_list, function(v) {
    v <- v[!is.na(v)]
    v <- trimws(v)
    v <- v[nzchar(v)]
    unique(v)
  }))

gene_to_marker_map <- marker_gene_tidy %>%
  select(marker, gene_list) %>%
  unnest_longer(gene_list, values_to = "gene_single") %>%
  filter(!is.na(gene_single), nzchar(gene_single)) %>%
  distinct(gene_single, marker)

cat(sprintf("Gene-to-marker mappings: %d\n", nrow(gene_to_marker_map)))

# Find self-targeted pairs at GENE level (only for genes passing filter)
self_targeted_gene <- data.frame()

for (i in 1:nrow(gene_info)) {
  gene <- gene_info$gene[i]
  n_cells <- gene_info$n_cells[i]
  n_sgrnas <- gene_info$n_sgrnas[i]
  
  if (!(gene %in% rownames(gene_lfc_mat))) next
  
  # Find proteins encoded by this gene
  target_proteins <- gene_to_marker_map %>% filter(gene_single == gene) %>%
    pull(marker)
  
  target_proteins <- intersect(target_proteins, colnames(gene_lfc_mat))
  
  if (length(target_proteins) == 0) next
  
  for (prot in target_proteins) {
    lfc <- gene_lfc_mat[gene, prot]
    se <- gene_se_mat[gene, prot]
    zscore <- gene_zscore_mat[gene, prot]
    pval <- gene_pval_mat[gene, prot]
    qval <- gene_qval_mat[gene, prot]
    
    self_targeted_gene <- rbind(self_targeted_gene, data.frame(
      gene = gene, protein = prot, n_cells = n_cells,
      n_sgrnas = n_sgrnas, lfc = lfc, se = se,
      zscore = zscore, pval = pval, qval = qval,
      stringsAsFactors = FALSE))
  }
}

cat(sprintf("Self-targeted gene-protein pairs (after filter): %d\n", nrow(self_targeted_gene)))
cat(sprintf("  Unique genes: %d\n", length(unique(self_targeted_gene$gene))))
cat(sprintf("  Unique proteins: %d\n", length(unique(self_targeted_gene$protein))))

# Check how many self-targeted genes were filtered out
self_targeted_genes_all <- gene_to_marker_map$gene_single
n_self_targeted_filtered <- sum(self_targeted_genes_all %in% genes_failing_filter)
cat(sprintf("  Self-targeted genes removed by filter: %d\n", n_self_targeted_filtered))

# Self-targeted validation metrics
cat("\n--- Self-Targeted Validation Metrics (Gene-Level, Filtered) ---\n")
cat("For CRISPRa, ground truth = positive LFC expected\n\n")

cat(sprintf("Mean LFC: %.4f\n", mean(self_targeted_gene$lfc, na.rm = TRUE)))
cat(sprintf("Median LFC: %.4f\n", median(self_targeted_gene$lfc, na.rm = TRUE)))
cat(sprintf("%% Positive: %.1f%%\n", 100 * mean(self_targeted_gene$lfc > 0, na.rm = TRUE)))
cat(sprintf("%% LFC > 0.10: %.1f%%\n", 100 * mean(self_targeted_gene$lfc > 0.10, na.rm = TRUE)))
cat(sprintf("%% LFC > 0.50: %.1f%%\n", 100 * mean(self_targeted_gene$lfc > 0.50, na.rm = TRUE)))

cat(sprintf("\nMean Z-score: %.4f\n", mean(self_targeted_gene$zscore, na.rm = TRUE)))
cat(sprintf("Median Z-score: %.4f\n", median(self_targeted_gene$zscore, na.rm = TRUE)))
cat(sprintf("%% Z > 1.96: %.1f%%\n", 100 * mean(self_targeted_gene$zscore > 1.96, na.rm = TRUE)))
cat(sprintf("%% p < 0.05: %.1f%%\n", 100 * mean(self_targeted_gene$pval < 0.05, na.rm = TRUE)))
cat(sprintf("%% FDR < 0.10: %.1f%%\n", 100 * mean(self_targeted_gene$qval < 0.10, na.rm = TRUE)))
cat(sprintf("%% FDR < 0.20: %.1f%%\n", 100 * mean(self_targeted_gene$qval < 0.20, na.rm = TRUE)))

# Compare to non-self-targeted as baseline
non_self_genes <- setdiff(unique_genes, unique(self_targeted_gene$gene))
non_self_lfc <- as.vector(gene_lfc_mat[non_self_genes, ])
non_self_lfc <- non_self_lfc[!is.na(non_self_lfc)]

cat("\n--- Baseline (Non-Self-Targeted) ---\n")
cat(sprintf("Mean LFC: %.4f\n", mean(non_self_lfc)))
cat(sprintf("Median LFC: %.4f\n", median(non_self_lfc)))
cat(sprintf("%% Positive: %.1f%%\n", 100 * mean(non_self_lfc > 0)))

# Statistical test
wilcox_result <- wilcox.test(self_targeted_gene$lfc, non_self_lfc, alternative = "greater")
cat(sprintf("\nWilcoxon test (self-targeted > non-self-targeted):\n"))
cat(sprintf("  p-value: %.2e\n", wilcox_result$p.value))
@

