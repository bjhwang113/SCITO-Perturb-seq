\documentclass{article}

\begin{document}
\SweaveOpts{concordance=TRUE}

\title{Gene-Level LFC, SE, and Z-Score Analysis (PRIMARY)}
\maketitle

\section{Overview}

This is the \textbf{PRIMARY analysis} (gene-level), consistent with Zhu et al. 2025 methodology.
Unlike sgRNA-level analysis, we pool ALL cells with ANY sgRNA targeting each gene,
providing more stable effect estimates.

\textbf{Key difference from sgRNA-level:}
\begin{itemize}
  \item sgRNA-level: Each sgRNA analyzed separately (28,104 rows)
  \item Gene-level: Pool cells from all sgRNAs targeting same gene (17,755 rows)
\end{itemize}

\textbf{Method:}
\begin{enumerate}
  \item For each gene: pool ALL cells with ANY sgRNA targeting that gene
  \item \textbf{Filter genes with fewer than MIN\_CELLS\_PER\_GENE cells}
  \item Compute mean and variance across pooled cells
  \item LFC = gene mean - NTC mean
  \item SE = sqrt(var\_gene/n\_gene + var\_NTC/n\_NTC)
  \item Z-score = LFC / SE
  \item P-values from Welch's t-test (two-sided)
  \item FDR via Benjamini-Hochberg
\end{enumerate}

<<load-packages>>=
# SETUP: Load Packages
suppressPackageStartupMessages({
  library(Matrix)
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  library(patchwork)
  library(stringr)
})

set.seed(42)
@

\section{Parameters}

<<parameters>>=
# Minimum number of cells per gene to include in analysis
# Genes with fewer cells will be filtered out
# Rationale: With n_cells < 20, variance estimates are unreliable (df < 19)
# Options: 10 (lenient), 20 (recommended), 30 (conservative)
MIN_CELLS_PER_GENE <- 20

cat(sprintf("MIN_CELLS_PER_GENE = %d\n", MIN_CELLS_PER_GENE))
cat("\nRationale: Genes with too few cells have unreliable variance estimates.\n")
cat("With n=20, df=19 for variance estimation (acceptable for t-test).\n")
@

\section{Load Data}

<<load-data>>=
# SECTION 1: Load Batch-Regressed Data

# Load the deviance-normalized (batch-regressed) data
RAW_RDS <- "/home/ec2-user/scitoseq/data/deviance_norm.rds"
raw_data <- readRDS(RAW_RDS)

# Clean protein names
old_names <- rownames(raw_data)
prefix_pat <- "^(anti-human-mouse-rat-|anti-mouse-human-|anti-human-mouse-|anti-human-|anti-mouse-|Mouse-|Rat-|ArmenianHamsterIgG-)"
clean_names <- gsub(prefix_pat, "", old_names)
clean_names <- gsub("-barcode\\d+$", "", clean_names)

# Extract counts and metadata
counts <- raw_data@assays$RNA@counts
rownames(counts) <- clean_names
meta <- raw_data@meta.data

cat(sprintf("Data dimensions: %d proteins × %d cells\n", nrow(counts), ncol(counts)))
# Data dimensions: 203 proteins × 3134864 cells

rm(raw_data); gc()

# Create clean guide columns
meta$guide_target_clean <- ifelse(
  grepl("NO-TARGET", meta$guide_target, ignore.case = TRUE),
  "NTC", as.character(meta$guide_target))
meta$guide_target_clean <- factor(meta$guide_target_clean)

meta$guide_assignment_clean <- ifelse(
  meta$guide_target_clean == "NTC", "NTC", 
  as.character(meta$guide_assignment))

# Summary
gene_targets <- setdiff(unique(as.character(meta$guide_target_clean)), "NTC")
all_sgrnas <- setdiff(unique(meta$guide_assignment_clean), "NTC")

cat(sprintf("Perturbation targets (genes): %d\n", length(gene_targets))) # 17755
cat(sprintf("sgRNAs (excluding NTC): %d\n", length(all_sgrnas))) # 28104
cat(sprintf("NTC cells: %d\n", sum(meta$guide_target_clean == "NTC"))) # 26602
cat(sprintf("Perturbation cells: %d\n", sum(meta$guide_target_clean != "NTC"))) # 3108262

## ---------- Remove IgE / IgLightChainL ----------
drop_feats <- c("IgE", "IgLightChainL")
keep_rows  <- !(rownames(counts) %in% drop_feats)
counts <- counts[keep_rows, , drop = FALSE]

# Protein list
all_proteins <- rownames(counts)
n_proteins <- length(all_proteins)
cat(sprintf("Proteins: %d\n", n_proteins))
@

