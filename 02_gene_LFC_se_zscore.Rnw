\section{Final Summary}

<<final-summary>>=
cat("PARAMETERS:\n")
cat(sprintf("  MIN_CELLS_PER_GENE = %d\n", MIN_CELLS_PER_GENE))
cat(sprintf("  Genes removed by filter: %d (%.1f%%)\n", 
            n_genes_fail, 100 * n_genes_fail / n_genes_total))

cat("\nMETHOD:\n")
cat("  Pool ALL cells with ANY sgRNA targeting each gene\n")
cat(sprintf("  Filter genes with n_cells < %d\n", MIN_CELLS_PER_GENE))
cat("  LFC = mean(gene cells) - mean(NTC cells)\n")
cat("  SE = sqrt(var_gene/n_gene + var_NTC/n_NTC)\n")
cat("  Z-score = LFC / SE\n")
cat("  P-value = Welch's t-test\n")
cat("  FDR = Benjamini-Hochberg\n\n")

cat("KEY RESULTS:\n")
cat(sprintf("  1. Matrix dimensions: %d genes × %d proteins\n", n_genes, n_proteins))
cat(sprintf("  2. Median cells per gene: %.0f\n", median(ncells_per_gene)))
cat(sprintf("  3. Median SE: %.4f\n", median(se_vals)))
cat(sprintf("  4. Z-score SD: %.3f (should be ~1 under null)\n", sd(z_vals)))
cat(sprintf("  5. %% FDR < 0.10: %.3f%%\n", 100 * mean(q_vals < 0.10)))
cat(sprintf("  6. Self-targeted positive rate: %.1f%%\n",
            100 * mean(self_targeted_gene$lfc > 0, na.rm = TRUE)))
cat(sprintf("  7. Self-targeted %% Z > 1.96: %.1f%%\n",
            100 * mean(self_targeted_gene$zscore > 1.96, na.rm = TRUE)))
@

\end{document}
