\section{Build Gene Metadata}

<<gene-metadata>>=
# SECTION 7: Build Gene Metadata

# Build gene info from sgRNA metadata (for ALL genes, before filtering)
gene_info_all <- meta %>%
  filter(guide_assignment_clean != "NTC") %>%
  group_by(guide_target_clean) %>%
  summarise(
    n_sgrnas = n_distinct(guide_assignment_clean),
    n_cells = n(),
    batches = paste(sort(unique(Batch)), collapse = ","),
    .groups = "drop"
  ) %>%
  rename(gene = guide_target_clean) %>%
  mutate(gene = as.character(gene))

# Add filter status
gene_info_all$passed_filter <- gene_info_all$gene %in% unique_genes

# Gene info for passing genes only
gene_info <- gene_info_all %>% filter(passed_filter)

cat(sprintf("Total genes: %d\n", nrow(gene_info_all)))
cat(sprintf("Genes passing filter (n_cells >= %d): %d\n", MIN_CELLS_PER_GENE, nrow(gene_info)))

cat(sprintf("\nsgRNAs per gene distribution (filtered genes):\n"))
print(table(gene_info$n_sgrnas))

cat(sprintf("\nGenes with 1 sgRNA: %d\n", sum(gene_info$n_sgrnas == 1)))
cat(sprintf("Genes with 2 sgRNAs: %d\n", sum(gene_info$n_sgrnas == 2)))
@

