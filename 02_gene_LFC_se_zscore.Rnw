\section{Calculate Gene-Level Statistics (Vectorized)}

<<gene-stats>>=
# SECTION 4: Calculate Gene-Level Statistics Using Vectorized Sparse Operations

cat(sprintf("Computing statistics for %d genes across %d proteins...\n", 
            n_genes, n_proteins))

# STEP 1: Compute sums via sparse matrix multiplication
# Result: (proteins × genes)
cat("Computing expression sums...\n")
gene_sums <- counts_non_ntc_filtered %*% indicator_mat
gene_sums_dense <- as.matrix(gene_sums)

# STEP 2: Compute sum of squares
cat("Computing sum of squares...\n")
counts_sq <- counts_non_ntc_filtered^2
gene_sumsq <- counts_sq %*% indicator_mat
gene_sumsq_dense <- as.matrix(gene_sumsq)

# Clean up intermediate
rm(counts_sq, gene_sums, gene_sumsq, counts_non_ntc_filtered); gc()

# STEP 3: Compute means
# gene_means is (proteins × genes)
cat("Computing means...\n")
gene_means <- sweep(gene_sums_dense, 2, ncells_per_gene, "/")

# STEP 4: Compute variances using: var = E[x²] - E[x]²
# Then apply Bessel's correction: var * n/(n-1)
cat("Computing variances...\n")
gene_sq_means <- sweep(gene_sumsq_dense, 2, ncells_per_gene, "/")
gene_vars_uncorrected <- gene_sq_means - gene_means^2

# Apply Bessel's correction for sample variance
# With MIN_CELLS_PER_GENE filter, all genes have n >= threshold
bessel_factor <- ncells_per_gene / (ncells_per_gene - 1)
gene_vars <- sweep(gene_vars_uncorrected, 2, bessel_factor, "*")

# Handle negative variances due to numerical precision
gene_vars[gene_vars < 0] <- 1e-10

rm(gene_sums_dense, gene_sumsq_dense, gene_sq_means, gene_vars_uncorrected); gc()

elapsed <- difftime(Sys.time(), t_start, units = "secs")
cat(sprintf("\nStatistics computation completed in %.1f seconds\n", elapsed))
@

Computing statistics for 17336 genes across 201 proteins...
Statistics computation completed in 21.3 seconds

\section{Calculate LFC, SE, Z-score, and P-values}

<<calculate-lfc-se-zscore>>=
# SECTION 5: Calculate LFC, SE, Z-score, and P-values

# LFC = gene mean - NTC mean
# Transpose to get (genes × proteins) format
cat("Computing LFC...\n")
gene_lfc_mat <- t(gene_means) - matrix(ntc_means, nrow = n_genes, ncol = n_proteins, byrow = TRUE)
rownames(gene_lfc_mat) <- unique_genes
colnames(gene_lfc_mat) <- all_proteins

# SE = sqrt(var_gene/n_gene + var_NTC/n_NTC)
cat("Computing SE...\n")

# NTC variance contribution (constant for all genes)
ntc_var_contrib <- ntc_vars / n_ntc

# Gene variance contribution: var_gene / n_gene
# gene_vars is (proteins × genes)
gene_var_contrib <- sweep(gene_vars, 2, ncells_per_gene, "/")

# SE² = var_gene/n_gene + var_NTC/n_NTC
se_squared <- gene_var_contrib + matrix(
  ntc_var_contrib, nrow = n_proteins, ncol = n_genes, byrow = FALSE)

# SE matrix (transpose to genes × proteins)
gene_se_mat <- t(sqrt(se_squared))
rownames(gene_se_mat) <- unique_genes
colnames(gene_se_mat) <- all_proteins

# Z-score = LFC / SE
cat("Computing Z-scores...\n")
gene_zscore_mat <- gene_lfc_mat / gene_se_mat

# P-values from Welch's t-test
# Welch-Satterthwaite degrees of freedom approximation
cat("Computing p-values (Welch's t-test)...\n")

# Welch-Satterthwaite df formula
numerator_df <- se_squared^2

# Term 1: (var_gene/n_gene)² / (n_gene-1)
term1 <- sweep(gene_var_contrib^2, 2, ncells_per_gene - 1, "/")

# Term 2: (var_NTC/n_NTC)² / (n_NTC-1)
term2 <- (ntc_var_contrib^2) / (n_ntc - 1)

# Denominator
denominator_df <- term1 + matrix(term2, nrow = n_proteins, ncol = n_genes, byrow = FALSE)

# Degrees of freedom (proteins × genes)
df_mat <- numerator_df / denominator_df
df_mat[df_mat < 1 | is.na(df_mat)] <- 1

# Transpose to (genes × proteins)
df_mat <- t(df_mat)

# P-values: two-sided t-test
gene_pval_mat <- 2 * pt(-abs(gene_zscore_mat), df = df_mat)

# Clean up
rm(se_squared, gene_var_contrib, numerator_df, term1, denominator_df, df_mat); gc()

# FDR Correction (preserve NA structure)
cat("Computing FDR (Benjamini-Hochberg)...\n")

gene_qval_mat <- gene_pval_mat  # Copy structure
non_na_idx <- !is.na(gene_pval_mat)
gene_qval_mat[non_na_idx] <- p.adjust(gene_pval_mat[non_na_idx], method = "BH")

cat("Calculations complete.\n")
@

\section{Summary Statistics}

<<summary-stats>>=
# SECTION 6: Summary Statistics

# --- Matrix dimensions ---
cat("--- Matrix Dimensions (Gene-Level, FILTERED) ---\n")
cat(sprintf("Filter applied: n_cells >= %d\n", MIN_CELLS_PER_GENE))
cat(sprintf("LFC matrix: %d genes × %d proteins = %d pairs\n", 
            nrow(gene_lfc_mat), ncol(gene_lfc_mat), 
            nrow(gene_lfc_mat) * ncol(gene_lfc_mat)))
cat(sprintf("Genes removed by filter: %d\n", n_genes_fail))

# --- LFC Summary ---
cat("\n--- LFC Summary ---\n")
lfc_vals <- as.vector(gene_lfc_mat[!is.na(gene_lfc_mat)])
cat(sprintf("Valid (gene, protein) pairs: %d\n", length(lfc_vals)))
cat(sprintf("Mean LFC: %.4f\n", mean(lfc_vals)))
cat(sprintf("Median LFC: %.4f\n", median(lfc_vals)))
cat(sprintf("SD LFC: %.4f\n", sd(lfc_vals)))
cat(sprintf("Min: %.3f, Max: %.3f\n", min(lfc_vals), max(lfc_vals)))
cat(sprintf("%% |LFC| > 0.05: %.1f%%\n", 100 * mean(abs(lfc_vals) > 0.05)))
cat(sprintf("%% |LFC| > 0.10: %.1f%%\n", 100 * mean(abs(lfc_vals) > 0.10)))
cat(sprintf("%% |LFC| > 0.20: %.1f%%\n", 100 * mean(abs(lfc_vals) > 0.20)))

# --- SE Summary ---
cat("\n--- SE Summary ---\n")
se_vals <- as.vector(gene_se_mat[!is.na(gene_se_mat)])
cat(sprintf("Mean SE: %.4f\n", mean(se_vals)))
cat(sprintf("Median SE: %.4f\n", median(se_vals)))
cat(sprintf("SD SE: %.4f\n", sd(se_vals)))
cat(sprintf("Min: %.4f, Max: %.4f\n", min(se_vals), max(se_vals)))

# --- Z-score Summary ---
cat("\n--- Z-score Summary ---\n")
z_vals <- as.vector(gene_zscore_mat[!is.na(gene_zscore_mat) & is.finite(gene_zscore_mat)])
cat(sprintf("Mean Z: %.4f\n", mean(z_vals)))
cat(sprintf("Median Z: %.4f\n", median(z_vals)))
cat(sprintf("SD Z: %.4f (should be ~1 under null)\n", sd(z_vals)))
cat(sprintf("Min: %.3f, Max: %.3f\n", min(z_vals), max(z_vals)))
cat(sprintf("%% |Z| > 1.96: %.2f%%\n", 100 * mean(abs(z_vals) > 1.96)))
cat(sprintf("%% |Z| > 2.58: %.2f%%\n", 100 * mean(abs(z_vals) > 2.58)))
cat(sprintf("%% |Z| > 3.0: %.2f%%\n", 100 * mean(abs(z_vals) > 3.0)))

# --- P-value Summary ---
cat("\n--- P-value Summary ---\n")
p_vals <- as.vector(gene_pval_mat[!is.na(gene_pval_mat)])
cat(sprintf("%% p < 0.05: %.2f%%\n", 100 * mean(p_vals < 0.05)))
cat(sprintf("%% p < 0.01: %.2f%%\n", 100 * mean(p_vals < 0.01)))
cat(sprintf("%% p < 0.001: %.2f%%\n", 100 * mean(p_vals < 0.001)))

# --- FDR Summary ---
cat("\n--- FDR Summary (Benjamini-Hochberg) ---\n")
q_vals <- as.vector(gene_qval_mat[!is.na(gene_qval_mat)])
cat(sprintf("%% FDR < 0.05: %.3f%%\n", 100 * mean(q_vals < 0.05)))
cat(sprintf("%% FDR < 0.10: %.3f%%\n", 100 * mean(q_vals < 0.10)))
cat(sprintf("%% FDR < 0.20: %.3f%%\n", 100 * mean(q_vals < 0.20)))

# Count significant hits
n_fdr05 <- sum(q_vals < 0.05)
n_fdr10 <- sum(q_vals < 0.10)
cat(sprintf("\nSignificant hits: %d at FDR<0.05, %d at FDR<0.10\n", n_fdr05, n_fdr10))
@

