\section{Calculate NTC Statistics}

<<ntc-stats>>=
# SECTION 2: Calculate NTC Baseline Statistics

# Get NTC cell indices
ntc_idx <- which(meta$guide_assignment_clean == "NTC")
n_ntc <- length(ntc_idx)
cat(sprintf("NTC cells: %d\n", n_ntc))

# NTC counts matrix (proteins × NTC cells)
counts_ntc <- counts[, ntc_idx, drop = FALSE]

# NTC means (per protein)
ntc_means <- Matrix::rowMeans(counts_ntc)

# NTC variances (per protein)
# var(x) = E[x²] - E[x]²
ntc_sq_means <- Matrix::rowMeans(counts_ntc^2)
ntc_vars <- ntc_sq_means - ntc_means^2

# Apply Bessel's correction for sample variance: var * n/(n-1)
ntc_vars <- ntc_vars * n_ntc / (n_ntc - 1)

cat(sprintf("NTC mean range: [%.4f, %.4f]\n", min(ntc_means), max(ntc_means)))
cat(sprintf("NTC variance range: [%.4f, %.4f]\n", min(ntc_vars), max(ntc_vars)))

rm(counts_ntc); gc()
@

NTC cells: 26602
NTC mean range: [-0.0469, 0.0241]
NTC variance range: [0.8024, 1.4071]

\section{Build Gene-Level Indicator Matrix and Apply Filter}

<<gene-indicator>>=
# SECTION 3: Build GENE-Level Indicator Matrix and Apply Cell Count Filter

# Get non-NTC cells
non_ntc_idx <- which(meta$guide_assignment_clean != "NTC")
n_non_ntc <- length(non_ntc_idx)

# KEY: Use guide_target_clean (gene) instead of guide_assignment_clean (sgRNA)
gene_assignments <- as.character(meta$guide_target_clean[non_ntc_idx])
counts_non_ntc <- counts[, non_ntc_idx, drop = FALSE]

# Unique genes (NOT sgRNAs) - BEFORE filtering
all_unique_genes <- sort(unique(gene_assignments))
n_genes_total <- length(all_unique_genes)

cat(sprintf("Total genes before filtering: %d\n", n_genes_total))
cat(sprintf("Total perturbation cells: %d\n", n_non_ntc))

# Count cells per gene BEFORE filtering
gene_factor_all <- factor(gene_assignments, levels = all_unique_genes)
ncells_per_gene_all <- table(gene_factor_all)
ncells_per_gene_all <- as.integer(ncells_per_gene_all)
names(ncells_per_gene_all) <- all_unique_genes

cat(sprintf("\nCell counts per gene (BEFORE filtering):\n"))
cat(sprintf("  Min: %d\n", min(ncells_per_gene_all)))
cat(sprintf("  Median: %.0f\n", median(ncells_per_gene_all)))
cat(sprintf("  Mean: %.1f\n", mean(ncells_per_gene_all)))
cat(sprintf("  Max: %d\n", max(ncells_per_gene_all)))

# APPLY CELL COUNT FILTER
cat(sprintf("\n>>> APPLYING FILTER: n_cells >= %d <<<\n\n", MIN_CELLS_PER_GENE))

genes_passing_filter <- names(ncells_per_gene_all)[ncells_per_gene_all >= MIN_CELLS_PER_GENE]
genes_failing_filter <- names(ncells_per_gene_all)[ncells_per_gene_all < MIN_CELLS_PER_GENE]

n_genes_pass <- length(genes_passing_filter)
n_genes_fail <- length(genes_failing_filter)

cat(sprintf("Genes passing filter (n_cells >= %d): %d (%.1f%%)\n", 
            MIN_CELLS_PER_GENE, n_genes_pass, 100 * n_genes_pass / n_genes_total))
cat(sprintf("Genes failing filter (n_cells < %d): %d (%.1f%%)\n", 
            MIN_CELLS_PER_GENE, n_genes_fail, 100 * n_genes_fail / n_genes_total))

# Show distribution of filtered-out genes
if (n_genes_fail > 0) {
  filtered_ncells <- ncells_per_gene_all[genes_failing_filter]
  cat(sprintf("\nFiltered-out genes cell count distribution:\n"))
  cat(sprintf("  n_cells = 1: %d genes\n", sum(filtered_ncells == 1)))
  cat(sprintf("  n_cells = 2: %d genes\n", sum(filtered_ncells == 2)))
  cat(sprintf("  n_cells 3-9: %d genes\n", sum(filtered_ncells >= 3 & filtered_ncells <= 9)))
  cat(sprintf("  n_cells 10-19: %d genes\n", sum(filtered_ncells >= 10 & filtered_ncells < 20)))
}

# Use only genes passing filter
unique_genes <- genes_passing_filter
n_genes <- length(unique_genes)

# Filter cells to only those belonging to passing genes
cells_to_keep <- gene_assignments %in% unique_genes
gene_assignments_filtered <- gene_assignments[cells_to_keep]
counts_non_ntc_filtered <- counts_non_ntc[, cells_to_keep, drop = FALSE]

cat(sprintf("\nCells retained after gene filtering: %d / %d (%.1f%%)\n",
            sum(cells_to_keep), length(cells_to_keep), 100 * mean(cells_to_keep)))

# Build indicator matrix for FILTERED genes only
t_start <- Sys.time()

cat(sprintf("\nBuilding indicator matrix for %d genes (after filtering)...\n", n_genes))

gene_factor <- factor(gene_assignments_filtered, levels = unique_genes)

indicator_mat <- Matrix::sparseMatrix(
  i = seq_along(gene_assignments_filtered), j = as.integer(gene_factor),
  x = 1, dims = c(length(gene_assignments_filtered), n_genes),
  dimnames = list(NULL, unique_genes))

cat(sprintf("Indicator matrix: %d cells × %d genes\n", 
            nrow(indicator_mat), ncol(indicator_mat)))

# Cell counts per GENE (filtered)
ncells_per_gene <- Matrix::colSums(indicator_mat)
names(ncells_per_gene) <- unique_genes

cat(sprintf("\nCell counts per gene (AFTER filtering, n_cells >= %d):\n", MIN_CELLS_PER_GENE))
cat(sprintf("  Min: %d\n", min(ncells_per_gene)))
cat(sprintf("  Median: %.0f\n", median(ncells_per_gene)))
cat(sprintf("  Mean: %.1f\n", mean(ncells_per_gene)))
cat(sprintf("  Max: %d\n", max(ncells_per_gene)))

# Store unfiltered counts for reference
ncells_per_gene_unfiltered <- ncells_per_gene_all
@

