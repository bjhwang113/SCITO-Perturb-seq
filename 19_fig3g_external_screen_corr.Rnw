<<>>=
## --- Build linked protein matrix ---
linked_mat <- matrix(NA_real_, nrow = length(screen_order), ncol = 1,
                     dimnames = list(screen_order, "Linked\nprotein"))
linked_labels <- character(length(screen_order))
for (i in seq_along(screen_order)) {
  s <- screen_order[i]
  linked_mat[i, 1] <- results_linked[[s]]
  linked_labels[i] <- linked_proteins[s]
}

## --- Shared color scale ---
lim <- 0.45
col_fun <- colorRamp2(c(-lim, 0, lim), c("#2166AC", "#F7F7F7", "#B2182B"))

## --- Row labels (screen name + n) ---
row_labels_fmt <- sapply(screen_order, function(s) {
  sprintf("%s\n(n = %d)", screen_labels[s], overlap_info[[s]]$n_used)
})

## --- Row annotation: readout type (left side, matching doc 1 style) ---
readout_types <- screen_readout[screen_order]
row_ha <- rowAnnotation(
  Readout = readout_types,
  col = list(Readout = readout_type_colors),
  show_annotation_name = FALSE,
  annotation_legend_param = list(
    title = "Readout type",
    title_gp = gpar(fontsize = 9, fontface = "bold"),
    labels_gp = gpar(fontsize = 8),
    direction = "horizontal",
    nrow = 1
  ),
  width = unit(4, "mm")
)

## --- Column (bottom) annotation for NMF heatmap ---
## Matches doc 1: Module color bar + spacer + label text + title placeholder
mod_order <- colnames(cor_mat_nmf)
col_labels_fmt <- sprintf("%s\n%s", mod_order, module_names[mod_order])

col_ha_nmf <- HeatmapAnnotation(
  Module = mod_order,
  spacer = anno_empty(height = unit(4, "mm"), border = FALSE),
  Labels = anno_text(
    col_labels_fmt,
    gp = gpar(fontsize = 9),
    rot = 0,
    just = "center",
    location = unit(0.5, "npc")
  ),
  Title = anno_empty(height = unit(6, "mm"), border = FALSE),
  spacer2 = anno_empty(height = unit(8, "mm"), border = FALSE),
  col = list(Module = module_colors),
  show_legend = FALSE,
  show_annotation_name = FALSE,
  simple_anno_size = unit(4, "mm"),
  gap = unit(0, "mm")
)

## --- Cell function for NMF heatmap: bold highlight pairs, small grey otherwise ---
cell_fun_nmf <- function(j, i, x, y, w, h, fill) {
  val <- cor_mat_nmf[i, j]
  if (is.na(val)) return()
  rn <- rownames(cor_mat_nmf)[i]
  cn <- colnames(cor_mat_nmf)[j]
  is_key <- any(sapply(highlight_pairs, function(hp) hp[1] == rn && hp[2] == cn))

  if (is_key) {
    grid.text(sprintf("%.2f", val), x, y,
              gp = gpar(fontsize = 14, fontface = "bold",
                        col = ifelse(abs(val) > lim * 0.4, "white", "black")))
  } else {
    grid.text(sprintf("%.2f", val), x, y,
              gp = gpar(fontsize = 10, col = "grey55"))
  }
}

## --- Cell function for linked protein heatmap ---
cell_fun_linked <- function(j, i, x, y, w, h, fill) {
  val <- linked_mat[i, j]
  if (is.na(val)) return()
  grid.text(sprintf("%.2f", val), x, y - unit(1, "mm"),
            gp = gpar(fontsize = 14, fontface = "bold",
                      col = ifelse(abs(val) > lim * 0.4, "white", "black")))
  grid.text(linked_labels[i], x, y + unit(3, "mm"),
            gp = gpar(fontsize = 7,
                      col = ifelse(abs(val) > lim * 0.4, "white", "grey30"),
                      fontface = "italic"))
}

## --- Heatmap A: NMF modules ---
ht_nmf <- Heatmap(
  cor_mat_nmf,
  name = "Pearson r",
  col = col_fun,
  na_col = "grey90",
  cluster_rows    = FALSE,
  cluster_columns = FALSE,

  ## Rows
  row_labels = row_labels_fmt,
  row_names_gp = gpar(fontsize = 9, lineheight = 0.85),
  row_names_side = "left",
  left_annotation = row_ha,
  row_title = "External CRISPR screens",
  row_title_gp = gpar(fontsize = 11, fontface = "bold"),

  ## Columns: labels via bottom annotation, not column_names
  show_column_names = FALSE,
  bottom_annotation = col_ha_nmf,

  ## Cells
  cell_fun = cell_fun_nmf,
  border = TRUE,
  rect_gp = gpar(col = "white", lwd = 1.5),

  ## Legend
  heatmap_legend_param = list(
    title = "Pearson r",
    title_gp = gpar(fontsize = 9, fontface = "bold"),
    labels_gp = gpar(fontsize = 8),
    at = round(seq(-lim, lim, length.out = 5), 2),
    legend_width = unit(3, "cm"),
    direction = "horizontal"
  ),

  ## Size: 5 columns x 4 rows
  width  = unit(5 * 1.65, "cm"),
  height = unit(4 * 1.8, "cm")
)

## --- Heatmap B: A priori linked protein ---
ht_linked <- Heatmap(
  linked_mat,
  name = "Pearson r (linked)",
  col = col_fun,
  na_col = "grey90",
  cluster_rows    = FALSE,
  cluster_columns = FALSE,

  show_row_names = FALSE,
  column_labels = "A priori\nlinked protein",
  column_names_gp = gpar(fontsize = 9, fontface = "bold", lineheight = 0.85),
  column_names_rot = 0,
  column_names_centered = TRUE,
  column_names_side = "bottom",

  cell_fun = cell_fun_linked,
  border = TRUE,
  rect_gp = gpar(col = "white", lwd = 1.5),

  show_heatmap_legend = FALSE,

  width  = unit(2.5, "cm"),
  height = unit(4 * 1.8, "cm")
)

## --- Draw combined ---
draw(ht_nmf + ht_linked,
     merge_legend = TRUE,
     heatmap_legend_side = "bottom",
     annotation_legend_side = "bottom",
     padding = unit(c(2, 2, 2, 20), "mm"))
decorate_annotation("Title", {
  grid.text("Semi-NMF modules",
            x = unit(0.5, "npc"), y = unit(-0.3, "npc"),
            gp = gpar(fontsize = 11, fontface = "bold"))
})

## Save
pdf(file.path(OUTPUT_DIR, "parallel_correlation_comparison_v3.pdf"),
    width = 9, height = 6.5)
draw(ht_nmf + ht_linked,
     merge_legend = TRUE,
     heatmap_legend_side = "bottom",
     annotation_legend_side = "bottom",
     padding = unit(c(2, 2, 2, 2), "mm"))
decorate_annotation("Title", {
  grid.text("Semi-NMF modules",
            x = unit(0.5, "npc"), y = unit(-0.3, "npc"),
            gp = gpar(fontsize = 11, fontface = "bold"))
})
dev.off()
@

<<>>=
## SECTION 10: Violin plot (all 201 proteins, NMF + linked overlaid)
indiv_long <- lapply(screen_order, function(s) {
  rv <- results_all_prot[[s]]
  rv <- rv[is.finite(rv)]
  tibble(screen = s, protein = names(rv), r = rv)
}) %>% bind_rows() %>% mutate(
    screen_label = recode(
      screen,
      Belk_exhaust   = "Belk exhaustion",
      Shifrut_prolif = "Shifrut proliferation",
      Schmidt_IL2    = "Schmidt IL-2",
      Arce_IL2RA     = "Arce IL2RA"),
    screen_label = factor(screen_label, levels = c(
      "Belk exhaustion", "Shifrut proliferation",
      "Schmidt IL-2", "Arce IL2RA")))

## Reference points: NMF best module + linked protein
ref_points <- bind_rows(
  lapply(screen_order, function(s) {
    r_vec <- results_nmf[[s]]$r
    best <- which.max(abs(r_vec))
    tibble(screen = s, method = "Semi-NMF (best module)",
           r = r_vec[best], label = names(r_vec)[best])}),
  lapply(screen_order, function(s) {
    tibble(screen = s, method = "Linked protein (a priori)",
           r = results_linked[[s]], label = linked_proteins[s])
  })) %>% mutate(
    screen_label = recode(
      screen,
      Belk_exhaust   = "Belk exhaustion",
      Shifrut_prolif = "Shifrut proliferation",
      Schmidt_IL2    = "Schmidt IL-2",
      Arce_IL2RA     = "Arce IL2RA"),
    screen_label = factor(screen_label, levels = c(
      "Belk exhaustion", "Shifrut proliferation",
      "Schmidt IL-2", "Arce IL2RA")),
    method = factor(method, levels = c(
      "Semi-NMF (best module)",
      "Linked protein (a priori)"))
  )

p_dist <- ggplot(indiv_long, aes(x = screen_label, y = r)) +
  geom_hline(yintercept = 0, linewidth = 0.3, color = "grey60") +
  geom_violin(fill = "grey90", color = "grey50", alpha = 0.6, width = 0.7) +
  geom_jitter(width = 0.15, size = 0.4, alpha = 0.3, color = "grey40") +
  geom_point(data = ref_points,
             aes(color = method, shape = method),
             size = 3.5, stroke = 1.2,
             position = position_dodge(width = 0.3)) +
  scale_color_manual(values = c(
    "Semi-NMF (best module)"    = "#B2182B",
    "Linked protein (a priori)" = "#1B7837")) +
  scale_shape_manual(values = c(
    "Semi-NMF (best module)"    = 18,
    "Linked protein (a priori)" = 16)) +
  labs(x = NULL, y = "Pearson r with external screen",
       color = NULL, shape = NULL) +
  theme_bw(base_size = 13) +
  theme(
    panel.grid.major.x = element_blank(),
    panel.grid.minor   = element_blank(),
    legend.position    = "top",
    legend.text        = element_text(size = 10),
    axis.text          = element_text(color = "black"),
    axis.title.y       = element_text(face = "bold")
  )

ggsave(file.path(OUTPUT_DIR, "protein_correlation_distributions_v3.pdf"),
       p_dist, width = 8, height = 5.5)
@


