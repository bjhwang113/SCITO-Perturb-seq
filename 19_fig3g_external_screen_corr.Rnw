<<>>=
## SECTION 9: Two-panel heatmap (NMF modules + a priori protein)

## --- Shared definitions ---
module_names <- c(
  "M1" = "Adhesion /\nRegulation",
  "M2" = "Tissue /\nInnate-like",
  "M3" = "Resting /\nNaive",
  "M4" = "Activation /\nProliferation",
  "M5" = "Effector /\nExhaustion"
)

module_colors <- c(
  "M1" = "#da7901",
  "M2" = "#20235b",
  "M3" = "#637b31",
  "M4" = "#7B2D8E",
  "M5" = "#f0be3d"
)

screen_labels <- c(
  Belk_exhaust   = "Belk\nExhaustion",
  Shifrut_prolif = "Shifrut\nProliferation",
  Schmidt_IL2    = "Schmidt\nIL-2 cytokine",
  Arce_IL2RA     = "Arce\nIL2RA protein"
)

readout_type_colors <- c(
  "Composite cellular\nphenotype" = "#2C3E50",
  "Single-molecule\nreadout"      = "#BDC3C7"
)

screen_readout <- c(
  Belk_exhaust   = "Composite cellular\nphenotype",
  Shifrut_prolif = "Composite cellular\nphenotype",
  Schmidt_IL2    = "Single-molecule\nreadout",
  Arce_IL2RA     = "Single-molecule\nreadout"
)

## Highlighted cells (biologically expected key pairs)
highlight_pairs <- list(
  c("Belk_exhaust",   "M5"),
  c("Shifrut_prolif", "M4"),
  c("Shifrut_prolif", "M3")
)

## --- Build NMF correlation matrix ---
cor_mat_nmf <- do.call(rbind, lapply(screen_order, function(s) results_nmf[[s]]$r))
rownames(cor_mat_nmf) <- screen_order

pval_mat_nmf <- do.call(rbind, lapply(screen_order, function(s) results_nmf[[s]]$p))
rownames(pval_mat_nmf) <- screen_order

cat("\nNMF correlation matrix:\n")
print(round(cor_mat_nmf, 4))
cat("\nP-value matrix:\n")
print(round(pval_mat_nmf, 4))
#print(formatC(pval_mat_nmf, format = "e", digits = 2))
