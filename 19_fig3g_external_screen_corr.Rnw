Parallel Correlation Comparison: Semi-NMF Modules vs A Priori Linked
Proteins Against External CRISPR Screens

<<>>=
suppressPackageStartupMessages({
  library(dplyr)
  library(tidyr)
  library(readr)
  library(readxl)
  library(tibble)
  library(ggplot2)
  library(ggrepel)
  library(ComplexHeatmap)
  library(circlize)
  library(grid)
  library(gridExtra)
})

set.seed(42)

INPUT_DIR        <- "/home/ec2-user/scitoseq/results/semiNMF_v1_analysis"
GENE_RESULTS_DIR <- "/home/ec2-user/scitoseq/results/results_gene_level"
DATA_DIR         <- "/home/ec2-user/scitoseq/data"
OUTPUT_DIR       <- "/home/ec2-user/scitoseq/fig/fig3"

path_schmidt  <- "/mnt/my-data/scito-perturb-seq-internal/scitoseq/Pipes/logs/external/schmidt_et_al.xlsx"
sheet_schmidt <- "Prim.CRa.CD4.IL2.gene_summary"
path_belk     <- "/mnt/my-data/scito-perturb-seq-internal/scitoseq/Pipes/logs/external/belk_et_al.xlsx"
sheet_belk    <- "genomewide_results"
path_shifrut  <- "/mnt/my-data/scito-perturb-seq-internal/scitoseq/Pipes/logs/external/shifrut_et_al.xlsx"
sheet_shifrut <- "PrimaryScreen_Rep1_Gene"
path_arce     <- file.path(DATA_DIR, "ARCE_2023-10-17819C-S1_all_screens_results.xlsx")

my_q_thres   <- 0.1
FIXED_N      <- 50
MIN_GENES    <- 15
N_SWEEP      <- seq(20, 300, by = 10)
@

<<>>=
## SECTION 1: Load semi-NMF W matrix (L2-normalized)
model_k5 <- readRDS(file.path(INPUT_DIR, "model_k5.rds"))
W_raw <- model_k5$W
H_raw <- model_k5$H

modules <- paste0("M", 1:5)
colnames(W_raw) <- modules
rownames(H_raw) <- modules

d <- sqrt(colSums(W_raw^2))
W <- sweep(W_raw, 2, d, "/")
H <- diag(d) %*% H_raw
rownames(H) <- modules
colnames(H) <- colnames(H_raw)

cat(sprintf("W: %d genes x %d modules (L2-normalized)\n", nrow(W), ncol(W)))
# W: 2848 genes x 5 modules (L2-normalized)

## SECTION 2: Load gene-level Z-scores and significance
gene_zscore_mat <- readRDS(file.path(GENE_RESULTS_DIR, "gene_zscore_mat.rds"))
gene_qval_per_protein <- readRDS(file.path(GENE_RESULTS_DIR, "gene_qval_per_protein.rds"))

cat(sprintf("Z-score matrix: %d genes x %d proteins\n",
            nrow(gene_zscore_mat), ncol(gene_zscore_mat)))
# Z-score matrix: 2848 genes x 201 proteins

## Align gene universes
common_genes <- Reduce(intersect, list(
  rownames(W), rownames(gene_qval_per_protein), rownames(gene_zscore_mat)))
W <- W[common_genes, , drop = FALSE]
gene_qval_per_protein <- gene_qval_per_protein[common_genes, , drop = FALSE]
gene_zscore_mat <- gene_zscore_mat[common_genes, , drop = FALSE]

## Significant genes
q_min <- apply(gene_qval_per_protein, 1L, function(x) {
  fv <- x[is.finite(x)]
  if (length(fv) == 0) return(Inf)
  min(fv)
})
genes_my_sig <- names(q_min)[is.finite(q_min) & q_min <= my_q_thres]
cat(sprintf("Significant genes (min q <= %.2f): %d\n", my_q_thres, length(genes_my_sig)))
# Significant genes (min q <= 0.10): 2848
@

<<>>=
## SECTION 3: Load external screens (NO FDR filtering)
## Schmidt IL-2 (CRISPRa, no sign flip)
schmidt_ref <- read_excel(path_schmidt, sheet = sheet_schmidt) %>%
  transmute(
    Gene = id,
    lfc  = `pos|lfc`,
    fdr  = pmin(`pos|fdr`, `neg|fdr`, na.rm = TRUE)
  ) %>%
  filter(!is.na(Gene), is.finite(lfc), is.finite(fdr))
cat(sprintf("Schmidt IL-2 (all): %d genes\n", nrow(schmidt_ref)))
# Schmidt IL-2 (all): 18930 genes

## Belk exhaustion (CRISPRko, no sign flip)
belk_ref <- read_excel(path_belk, sheet = sheet_belk) %>%
  transmute(Gene = Gene, lfc = lfc_mageck, fdr = fdr_mageck) %>%
  filter(!is.na(Gene), is.finite(lfc), is.finite(fdr))
cat(sprintf("Belk exhaustion (all): %d genes\n", nrow(belk_ref)))
# Belk exhaustion (all): 17447 genes

## Shifrut proliferation (CRISPRko, sign flip: lfc = -pos|lfc)
shifrut_ref <- read_excel(path_shifrut, sheet = sheet_shifrut) %>%
  transmute(
    Gene = id,
    lfc  = -`pos|lfc`,
    fdr  = pmin(`pos|fdr`, `neg|fdr`, na.rm = TRUE)
  ) %>%
  filter(!is.na(Gene), is.finite(lfc), is.finite(fdr))
cat(sprintf("Shifrut proliferation (all): %d genes (sign-flipped)\n", nrow(shifrut_ref)))
# Shifrut proliferation (all): 19114 genes (sign-flipped)

## Arce IL2RA, Stimulated_Teff (CRISPRko, sign flip: lfc = -neg|lfc)
arce_ref <- read_excel(path_arce, sheet = "gene_summary") %>%
  transmute(
    Gene    = id,
    lfc_raw = `neg|lfc.Stimulated_Teff`,
    fdr_neg = `neg|fdr.Stimulated_Teff`,
    fdr_pos = `pos|fdr.Stimulated_Teff`
  ) %>% mutate(
    fdr = ifelse(lfc_raw > 0, fdr_pos, ifelse(lfc_raw < 0, fdr_neg, NA)),
    lfc = -lfc_raw) %>%
  filter(!is.na(Gene), is.finite(lfc), is.finite(fdr)) %>%
  dplyr::select(Gene, lfc, fdr)
cat(sprintf("Arce IL2RA (all): %d genes (sign-flipped)\n", nrow(arce_ref)))
# Arce IL2RA (all): 1350 genes (sign-flipped)

screen_list <- list(
  Belk_exhaust   = belk_ref,
  Shifrut_prolif = shifrut_ref,
  Schmidt_IL2    = schmidt_ref,
  Arce_IL2RA     = arce_ref
)
@

<<>>=
## SECTION 4: Fixed-N gene selection
select_top_n <- function(ref_df, sig_genes, n) {
  shared <- ref_df %>%
    filter(Gene %in% sig_genes) %>%
    arrange(fdr) %>%
    distinct(Gene, .keep_all = TRUE)
  actual_n <- min(n, nrow(shared))
  list(
    genes     = shared$Gene[seq_len(actual_n)],
    actual_n  = actual_n,
    max_avail = nrow(shared)
  )
}

cat("\n=== Gene overlap diagnostics ===\n")
for (s in names(screen_list)) {
  ref_df <- screen_list[[s]]
  shared <- ref_df %>% filter(Gene %in% genes_my_sig)
  cat(sprintf("  %s: %d total genes in screen, %d overlap with SCITO sig set\n",
              s, nrow(ref_df), nrow(shared)))
}
@

Belk_exhaust: 17447 total genes in screen, 2263 overlap with SCITO sig set
Shifrut_prolif: 19114 total genes in screen, 2793 overlap with SCITO sig set
Schmidt_IL2: 18930 total genes in screen, 2848 overlap with SCITO sig set
Arce_IL2RA: 1350 total genes in screen, 226 overlap with SCITO sig set

<<>>=
## SECTION 5: Biologically linked proteins (a priori)

linked_proteins <- c(
  Belk_exhaust   = "CD279",
  Shifrut_prolif = "CD71",
  Schmidt_IL2    = "CD25",
  Arce_IL2RA     = "CD25"
)

available_prots <- colnames(gene_zscore_mat)
for (s in names(linked_proteins)) {
  p <- linked_proteins[s]
  if (p %in% available_prots) {
    cat(sprintf("  %s -> %s [found]\n", s, p))
  } else {
    cat(sprintf("  %s -> %s [NOT FOUND in panel]\n", s, p))
    if (p == "CD71" && "CD98" %in% available_prots) {
      linked_proteins[s] <- "CD98"
      cat(sprintf("    -> falling back to CD98 (amino acid transporter, proliferation-linked)\n"))
    } else if (p == "CD71" && "CD25" %in% available_prots) {
      linked_proteins[s] <- "CD25"
      cat(sprintf("    -> falling back to CD25 (activation/proliferation proxy)\n"))
    }
  }
}
cat("\nFinal mapping:\n")
print(linked_proteins)
@
  Belk_exhaust Shifrut_prolif    Schmidt_IL2     Arce_IL2RA 
       "CD279"         "CD71"         "CD25"         "CD25" 
       
<<>>=
## SECTION 6: Core correlation functions
cor_repr_vs_screen <- function(repr_mat, ref_df, gene_set) {
  ref_vec <- ref_df$lfc[match(gene_set, ref_df$Gene)]
  sub_mat <- repr_mat[gene_set, , drop = FALSE]
  apply(sub_mat, 2, function(col) {
    ok <- is.finite(col) & is.finite(ref_vec)
    if (sum(ok) < MIN_GENES) return(NA_real_)
    cor(col[ok], ref_vec[ok], method = "pearson")
  })
}

cor_single_protein <- function(zscore_mat, ref_df, gene_set, protein) {
  ref_vec <- ref_df$lfc[match(gene_set, ref_df$Gene)]
  prot_vec <- zscore_mat[gene_set, protein]
  ok <- is.finite(prot_vec) & is.finite(ref_vec)
  if (sum(ok) < MIN_GENES) return(NA_real_)
  cor(prot_vec[ok], ref_vec[ok], method = "pearson")
}

cor_all_proteins <- function(zscore_mat, ref_df, gene_set) {
  ref_vec <- ref_df$lfc[match(gene_set, ref_df$Gene)]
  sub_mat <- zscore_mat[gene_set, , drop = FALSE]
  apply(sub_mat, 2, function(col) {
    ok <- is.finite(col) & is.finite(ref_vec)
    if (sum(ok) < MIN_GENES) return(NA_real_)
    cor(col[ok], ref_vec[ok], method = "pearson")
  })
}
@

<<>>=
## SECTION 7: Run correlations at fixed N (4 screens)
screen_order <- c("Belk_exhaust", "Shifrut_prolif",
                  "Schmidt_IL2", "Arce_IL2RA")

cat(sprintf("\n=== Running correlations at fixed N = %d ===\n\n", FIXED_N))

results_nmf      <- list()
results_linked   <- list()
results_all_prot <- list()
overlap_info     <- list()

for (s in screen_order) {
  ref_df <- screen_list[[s]]
  sel <- select_top_n(ref_df, genes_my_sig, FIXED_N)
  gene_set <- sel$genes
  gene_set <- Reduce(intersect, list(
    gene_set, rownames(W), rownames(gene_zscore_mat)))

  overlap_info[[s]] <- list(
    n_used    = length(gene_set),
    n_avail   = sel$max_avail,
    requested = FIXED_N
  )

  cat(sprintf("[%s] requested=%d, available=%d, used=%d\n",
              s, FIXED_N, sel$max_avail, length(gene_set)))

  ## NMF modules (with p-values)
  ref_vec <- ref_df$lfc[match(gene_set, ref_df$Gene)]
  W_sub <- W[gene_set, , drop = FALSE]
  cor_r <- cor_p <- setNames(rep(NA_real_, ncol(W_sub)), colnames(W_sub))
  for (m in colnames(W_sub)) {
    x <- W_sub[, m]; y <- ref_vec
    ok <- is.finite(x) & is.finite(y)
    if (sum(ok) < MIN_GENES) next
    ct <- cor.test(x[ok], y[ok], method = "pearson")
    cor_r[m] <- ct$estimate
    cor_p[m] <- ct$p.value
  }
  results_nmf[[s]] <- list(r = cor_r, p = cor_p)

  ## Linked protein
  results_linked[[s]] <- cor_single_protein(
    gene_zscore_mat, ref_df, gene_set, linked_proteins[s])

  ## All individual proteins (for distribution plot)
  results_all_prot[[s]] <- cor_all_proteins(gene_zscore_mat, ref_df, gene_set)
}
@
[Belk_exhaust] requested=50, available=2263, used=50
[Shifrut_prolif] requested=50, available=2793, used=50
[Schmidt_IL2] requested=50, available=2848, used=50
[Arce_IL2RA] requested=50, available=226, used=50

<<>>=
## SECTION 8: Summary
cat("\n=== Summary at fixed N ===\n\n")

for (s in screen_order) {
  info <- overlap_info[[s]]
  cat(sprintf("--- %s (n_used = %d, n_avail = %d) ---\n",
              s, info$n_used, info$n_avail))

  cat("  NMF modules:       ")
  cat(paste(sprintf("%s=%.3f", names(results_nmf[[s]]$r), results_nmf[[s]]$r),
            collapse = "  "))
  nmf_peak <- which.max(abs(results_nmf[[s]]$r))
  cat(sprintf("  [peak: %s, r=%.3f]\n",
              names(results_nmf[[s]]$r)[nmf_peak],
              results_nmf[[s]]$r[nmf_peak]))

  cat(sprintf("  Linked protein:    %s (r=%.3f)\n",
              linked_proteins[s], results_linked[[s]]))
  cat("\n")
}
@

