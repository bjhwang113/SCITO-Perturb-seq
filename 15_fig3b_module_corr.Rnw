@

<<>>=
# COMPARISON: W vs H module correlations
cat("Pair-wise comparison (upper triangle):\n")
cat(sprintf("  %-8s  %8s  %8s  %s\n", "Pair", "cor(W)", "cor(H)", "Interpretation"))
cat(paste(rep("-", 70), collapse = ""), "\n")

pairs <- combn(modules, 2)
for (k in 1:ncol(pairs)) {
  mi <- pairs[1, k]
  mj <- pairs[2, k]
  rw <- cor_W[mi, mj]
  rh <- cor_H[mi, mj]

  interp <- ""
  if (rw < -0.3 & rh < 0.3) {
    interp <- "Opposing programs, distinct signatures"
  } else if (rw < -0.3 & rh >= 0.3) {
    interp <- "Opposing programs, shared proteins"
  } else if (rw > 0.15 & rh > 0.3) {
    interp <- "Co-activated, shared signatures"
  } else if (rw > 0.15 & rh < 0.3) {
    interp <- "Co-activated, distinct signatures"
  } else if (abs(rw) <= 0.15) {
    interp <- "Independent programs"
  } else {
    interp <- "Weak/mixed"
  }

  cat(sprintf("  %s–%s  %+8.3f  %+8.3f  %s\n", mi, mj, rw, rh, interp))
}
@

  Pair        cor(W)    cor(H)  Interpretation
  M1–M2    -0.108    +0.274  Independent programs
  M1–M3    -0.558    -0.389  Opposing programs, distinct signatures
  M1–M4    -0.091    +0.091  Independent programs
  M1–M5    -0.067    -0.058  Independent programs
  M2–M3    -0.199    -0.508  Weak/mixed
  M2–M4    +0.237    +0.291  Co-activated, distinct signatures
  M2–M5    -0.410    +0.325  Opposing programs, shared proteins
  M3–M4    -0.294    -0.541  Weak/mixed
  M3–M5    +0.018    -0.490  Independent programs
  M4–M5    -0.280    +0.145  Weak/mixed
  
