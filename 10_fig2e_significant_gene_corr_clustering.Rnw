CLUSTER GENE INSPECTION

<<>>=
# For each cluster: list constituent genes, show per-gene Z-score profiles
# across the 5 protein groups, and check whether direction of effect is
# consistent with the pathway annotation.

# 1. Per-gene mean Z-score across each protein group
# For every gene in every cluster, compute mean Z-score within each protein group
gene_group_zscores <- data.frame()

for (cl in sort(unique(gene_clusters[gene_clusters > 0]))) {
  cluster_genes <- names(gene_clusters)[gene_clusters == cl]
  
  for (g in cluster_genes) {
    z_row <- zscore_for_clust[g, , drop = FALSE]
    
    group_means <- sapply(protein_groups, function(grp) {
      grp_proteins <- prot_cluster_df$protein[prot_cluster_df$cluster_name == grp]
      grp_proteins <- intersect(grp_proteins, colnames(z_row))
      if (length(grp_proteins) == 0) return(NA)
      mean(z_row[, grp_proteins], na.rm = TRUE)
    })
    
    # Also compute overall mean absolute Z (as a measure of total effect size)
    overall_mean_abs <- mean(abs(z_row), na.rm = TRUE)
    
    gene_group_zscores <- rbind(gene_group_zscores, data.frame(
      cluster = cl,
      gene = g,
      n_sig = n_sig_proteins_per_gene[g],
      mean_abs_z = round(overall_mean_abs, 3),
      Activation = round(group_means["Activation"], 3),
      Adhesion = round(group_means["Adhesion"], 3),
      `Cytokine/Chemokine` = round(group_means["Cytokine/Chemokine"], 3),
      Identity = round(group_means["Identity"], 3),
      `Innate-like` = round(group_means["Innate-like"], 3),
      stringsAsFactors = FALSE,
      check.names = FALSE
    ))
  }
}

# 2. Print cluster-by-cluster gene lists with Z-score profiles
for (cl in sort(unique(gene_clusters[gene_clusters > 0]))) {
  
  cluster_data <- gene_group_zscores[gene_group_zscores$cluster == cl, ]
  cluster_data <- cluster_data[order(-cluster_data$mean_abs_z), ]
  
  annotation <- cluster_annotation_lookup[as.character(cl)]
  n_genes_cl <- nrow(cluster_data)
  
  cat("\n")
  cat(sprintf("==== C%d: %s (n = %d genes) ====\n", cl, annotation, n_genes_cl))
  cat(sprintf("Intra-cluster correlation: %.3f\n", cluster_intra_corr[as.character(cl)]))
  cat("\n")
  
  # Print top 15 genes by effect size (or all if fewer)
  n_show <- min(15, n_genes_cl)
  cat(sprintf("Top %d genes by mean |Z|:\n", n_show))
  print(cluster_data[1:n_show, c("gene", "n_sig", "mean_abs_z", 
                                  "Identity", "Activation", "Adhesion", 
                                  "Cytokine/Chemokine", "Innate-like")], 
        row.names = FALSE)
  
  if (n_genes_cl > n_show) {
    remaining <- cluster_data[(n_show + 1):n_genes_cl, ]
    cat(sprintf("\nRemaining %d genes: %s\n", 
                nrow(remaining), 
                paste(remaining$gene, collapse = ", ")))
  }
  
  # Cluster-level summary: mean Z per protein group
  cat("\nCluster mean Z-score per protein group:\n")
  cluster_means <- colMeans(cluster_data[, c("Identity", "Activation", "Adhesion", 
                                              "Cytokine/Chemokine", "Innate-like")], 
                            na.rm = TRUE)
  print(round(cluster_means, 3))
  
  # Direction consistency: what fraction of genes have the same sign as the
  # cluster mean for the dominant protein group?
  dominant_grp <- names(which.max(abs(cluster_means)))
  dominant_sign <- sign(cluster_means[dominant_grp])
  gene_signs <- sign(cluster_data[[dominant_grp]])
  n_concordant <- sum(gene_signs == dominant_sign, na.rm = TRUE)
  n_valid <- sum(!is.na(gene_signs))
  
  cat(sprintf("\nDominant group: %s (mean Z = %.3f)\n", dominant_grp, cluster_means[dominant_grp]))
  cat(sprintf("Direction concordance: %d / %d genes (%.1f%%) match cluster direction\n",
              n_concordant, n_valid, 100 * n_concordant / n_valid))
  
  cat("\n")
}

# 3. Full gene list per cluster (for quick reference)
for (cl in sort(unique(gene_clusters[gene_clusters > 0]))) {
  cluster_genes <- sort(names(gene_clusters)[gene_clusters == cl])
  annotation <- cluster_annotation_lookup[as.character(cl)]
  cat(sprintf("C%d (%s, n=%d): %s\n\n", 
              cl, annotation, length(cluster_genes),
              paste(cluster_genes, collapse = ", ")))
}

# 4. Top enrichment terms per cluster (for cross-referencing with gene lists)
for (cl in sort(unique(gene_clusters[gene_clusters > 0]))) {
  annotation <- cluster_annotation_lookup[as.character(cl)]
  cat(sprintf("---- C%d: %s ----\n", cl, annotation))
  
  cluster_enrich <- all_enrichments %>%
    dplyr::filter(cluster == cl, p.adjust < ENRICHMENT_QVAL_CUTOFF) %>%
    arrange(p.adjust) %>%
    head(5)
  
  if (nrow(cluster_enrich) == 0) {
    cat("  No significant enrichments\n")
  } else {
    for (i in 1:nrow(cluster_enrich)) {
      # Parse overlapping genes
      overlap_genes_entrez <- strsplit(cluster_enrich$geneID[i], "/")[[1]]
      
      # Convert Entrez back to symbols for readability
      entrez_to_symbol <- setNames(gene_to_entrez$SYMBOL, gene_to_entrez$ENTREZID)
      overlap_genes_symbol <- entrez_to_symbol[overlap_genes_entrez]
      overlap_genes_symbol <- overlap_genes_symbol[!is.na(overlap_genes_symbol)]
      
      cat(sprintf("  [%s] %s\n    q=%.2e, overlap=%d: %s\n",
                  cluster_enrich$database[i],
                  cluster_enrich$Description[i],
                  cluster_enrich$p.adjust[i],
                  cluster_enrich$overlap_size[i],
                  paste(overlap_genes_symbol, collapse = ", ")))
    }
  }
  cat("\n")
}

# 5. Focused check: C3 calcineurin genes — are they activators or inhibitors?
c3_genes <- sort(names(gene_clusters)[gene_clusters == 3])

# Known calcineurin pathway genes (activators vs inhibitors)
calcineurin_activators <- c("PPP3CA", "PPP3CB", "PPP3CC", "PPP3R1", "PPP3R2",  # calcineurin subunits
                            "CALM1", "CALM2", "CALM3",                          # calmodulin
                            "NFATC1", "NFATC2", "NFATC3", "NFATC4",           # NFAT TFs
                            "PLCG1", "PLCG2",                                   # PLCgamma
                            "STIM1", "STIM2", "ORAI1", "ORAI2")               # CRAC channels

calcineurin_inhibitors <- c("RCAN1", "RCAN2", "RCAN3",                         # regulators of calcineurin
                            "CABIN1",                                           # calcineurin binding protein
                            "CASP3",                                            # cleaves calcineurin
                            "CHP1", "CHP2",                                     # calcineurin inhibitory proteins
                            "CAIN")                                             # calcineurin inhibitor

cat("C3 genes found in calcineurin ACTIVATOR list:\n")
c3_activators <- intersect(c3_genes, calcineurin_activators)
if (length(c3_activators) > 0) {
  for (g in c3_activators) {
    z_row <- gene_group_zscores[gene_group_zscores$gene == g, ]
    cat(sprintf("  %s: Identity=%.2f, Activation=%.2f\n", 
                g, z_row$Identity, z_row$Activation))
  }
} else {
  cat("  (none)\n")
}

cat("\nC3 genes found in calcineurin INHIBITOR list:\n")
c3_inhibitors <- intersect(c3_genes, calcineurin_inhibitors)
if (length(c3_inhibitors) > 0) {
  for (g in c3_inhibitors) {
    z_row <- gene_group_zscores[gene_group_zscores$gene == g, ]
    cat(sprintf("  %s: Identity=%.2f, Activation=%.2f\n", 
                g, z_row$Identity, z_row$Activation))
  }
} else {
  cat("  (none)\n")
}

cat("\nC3 genes NOT in either list (need manual review):\n")
c3_unknown <- setdiff(c3_genes, c(calcineurin_activators, calcineurin_inhibitors))
cat(sprintf("  %s\n", paste(c3_unknown, collapse = ", ")))

cat("\nSummary: C3 cluster direction\n")
c3_data <- gene_group_zscores[gene_group_zscores$cluster == 3, ]
cat(sprintf("  Mean Identity Z = %.3f (negative = suppression)\n", mean(c3_data$Identity, na.rm = TRUE)))
cat(sprintf("  Mean Activation Z = %.3f (negative = suppression)\n", mean(c3_data$Activation, na.rm = TRUE)))
cat("\nIf C3 contains calcineurin ACTIVATORS with NEGATIVE Z-scores,\n")
cat("that is PARADOXICAL (overexpressing the pathway suppresses markers).\n")
cat("If C3 contains calcineurin INHIBITORS with NEGATIVE Z-scores,\n")
cat("that is EXPECTED (overexpressing inhibitors mimics cyclosporine).\n")
cat("If C3 contains ACTIVATORS with POSITIVE Z-scores, the current text is wrong.\n")

# 6. Export full table for manual review
# Add cluster annotation to the gene-level table
gene_group_zscores$annotation <- cluster_annotation_lookup[as.character(gene_group_zscores$cluster)]

output_file <- file.path(GENE_RESULTS_DIR, "cluster_gene_inspection.csv")
# "/home/ec2-user/scitoseq/results/results_gene_level/cluster_gene_inspection.csv"
write.csv(gene_group_zscores, output_file, row.names = FALSE)
@

