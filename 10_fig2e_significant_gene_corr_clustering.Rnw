<<>>=
# SECTION 12: VISUALIZATION - CORRELATION HEATMAP (SQUARED, CLUSTER LEGEND SEPARATE)
cat("Creating gene correlation heatmap...\n")

gene_order <- gene_cluster_df %>% arrange(cluster) %>% pull(gene)

n_clusters_viz <- length(unique(gene_clusters[gene_clusters > 0]))

custom_cluster_colors <- c(
  "#a82203", "#208cc0", "#f1af3a", "#cf5e4e", "#637b31", 
  "#003967", "#3b7c70", "#ce9642", "#898e9f", "#3b3a3e"
)

cluster_colors_viz <- setNames(
  custom_cluster_colors[1:n_clusters_viz],
  seq_len(n_clusters_viz)
)

corr_colors <- colorRamp2(
  c(-0.5, -0.3, -0.1, 0, 0.1, 0.3, 0.5), 
  c("#225bb2", "#7db0ea", "#bad6f9", "white", "#fbc2a9", "#ee956a", "#da6c42")
)

cluster_assignments <- gene_cluster_df$cluster[match(gene_order, gene_cluster_df$gene)]

cluster_positions <- gene_cluster_df %>%
  arrange(cluster) %>%
  mutate(index = row_number()) %>%
  group_by(cluster) %>%
  summarise(
    start = min(index),
    end = max(index),
    center = (min(index) + max(index)) / 2,
    .groups = "drop"
  )

# Bottom annotation — hide its legend (cluster legend goes to separate PDF)
bottom_anno <- HeatmapAnnotation(
  Cluster = factor(cluster_assignments),
  cluster_label = anno_empty(border = FALSE, height = unit(5, "mm")),
  col = list(Cluster = cluster_colors_viz),
  which = "column",
  annotation_name_side = "left",
  show_annotation_name = c(TRUE, FALSE),
  annotation_name_gp = gpar(fontsize = 12),
  simple_anno_size = unit(5, "mm"),
  show_legend = FALSE
)

# Square heatmap — keep correlation legend
heatmap_size <- unit(14, "cm")

ht_corr <- Heatmap(
  corr_mat[gene_order, gene_order],
  name = "Correlation",
  col = corr_colors,
  cluster_rows = FALSE,
  cluster_columns = FALSE,
  show_row_names = FALSE,
  show_column_names = FALSE,
  bottom_annotation = bottom_anno,
  width = heatmap_size,
  height = heatmap_size,
  column_title = sprintf("Gene-Gene Correlation (n=%d genes with \u2265%d significant proteins)", 
                         nrow(corr_mat), MIN_SIG_PROTEINS),
  column_title_gp = gpar(fontsize = 12, fontface = "bold"),
  use_raster = TRUE,
  raster_quality = 3,
  heatmap_legend_param = list(
    title = "Correlation",
    at = c(-0.5, -0.25, 0, 0.25, 0.5),
    labels = c("\u2264-0.5", "-0.25", "0", "0.25", "\u22650.5"),
    legend_height = unit(4, "cm"),
    title_gp = gpar(fontsize = 12, fontface = "bold"),
    labels_gp = gpar(fontsize = 12)
  )
)

# --- PDF 1: Heatmap + correlation colorbar ---
pdf("/home/ec2-user/scitoseq/fig/fig2/fig2e.pdf", width = 9, height = 8)
draw(ht_corr, 
     heatmap_legend_side = "right",
     padding = unit(c(5, 2, 2, 2), "mm"))

decorate_annotation("cluster_label", {
  n_genes <- length(gene_order)
  for (i in 1:nrow(cluster_positions)) {
    center_npc <- cluster_positions$center[i] / n_genes
    grid.text(paste0("C", cluster_positions$cluster[i]), 
              x = unit(center_npc, "npc"), 
              y = unit(0.5, "npc"),
              gp = gpar(fontsize = 14))
  }
})

dev.off()

# --- PDF 2: Cluster legend only (wide, single column) ---
lgd_cluster <- Legend(
  labels = sapply(1:n_clusters_viz, function(i) {
    paste0("C", i, ": ", cluster_annotation_lookup[as.character(i)])
  }),
  legend_gp = gpar(fill = custom_cluster_colors[1:n_clusters_viz]),
  title = "Cluster",
  title_gp = gpar(fontsize = 11, fontface = "bold"),
