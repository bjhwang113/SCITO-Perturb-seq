<<>>=
# SECTION 9: COMBINE ALL ENRICHMENT RESULTS
all_enrichments_list <- list()
for (cluster_name in names(ora_results_all)) {
  cluster_data <- ora_results_all[[cluster_name]]
  if (length(cluster_data) == 0) next
  
  cluster_num <- as.integer(gsub("cluster_", "", cluster_name))
  
  for (db_name in names(cluster_data)) {
    df <- cluster_data[[db_name]]
    if (!is.null(df) && nrow(df) > 0) {
      df$cluster <- cluster_num
      all_enrichments_list[[paste0(cluster_name, "_", db_name)]] <- df
    }
  }
}

if (length(all_enrichments_list) > 0) {
  all_enrichments <- do.call(rbind, all_enrichments_list)
  rownames(all_enrichments) <- NULL
  
  cat(sprintf("Total enrichment results: %d\n", nrow(all_enrichments)))
  cat(sprintf("Significant results (q < %.2f): %d\n", 
              ENRICHMENT_QVAL_CUTOFF, 
              sum(all_enrichments$p.adjust < ENRICHMENT_QVAL_CUTOFF, na.rm = TRUE)))
  
  cat("\nResults by database:\n")
  db_summary <- all_enrichments %>%
    group_by(database) %>%
    summarise(
      total = n(),
      significant = sum(p.adjust < ENRICHMENT_QVAL_CUTOFF, na.rm = TRUE),
      .groups = "drop"
    )
  print(as.data.frame(db_summary))
  
  cat("\nTop 3 enrichments per cluster:\n")
  top_per_cluster <- all_enrichments %>%
    dplyr::filter(p.adjust < ENRICHMENT_QVAL_CUTOFF) %>%
    group_by(cluster) %>%
    slice_min(order_by = p.adjust, n = 3) %>%
    dplyr::select(cluster, ID, Description, database, p.adjust, Count) %>%
    arrange(cluster, p.adjust)
  
  print(as.data.frame(top_per_cluster), right = FALSE)
} else {
  all_enrichments <- data.frame()
  cat("No enrichment results found.\n")
}
@

<<>>=
# SECTION 10: CLUSTER ANNOTATION (T-CELL AWARE, LOWERCASE, WITH GO IDs)
generate_cluster_annotation_tcell <- function(all_enrichments, qval_cutoff = ENRICHMENT_QVAL_CUTOFF) {
  
 # T-cell/immune priority keywords (case-insensitive)
 # NOTE: B-cell terms are EXCLUDED since this is T-cell data
  tcell_priority_patterns <- c(
    "t cell|t-cell|tcr|\\bcd4\\b|\\bcd8\\b|thymocyte" = "t cell",
    "calcineurin|nfat" = "calcineurin/nfat",
    "cytokine|interleukin|interferon|\\bil-|\\bil2\\b|\\bifn" = "cytokine",
    "chemokine|cxcr|cxcl|ccr\\d|ccl\\d" = "chemokine",
    "nfkb|nf-kb|ikk|\\brel\\b" = "nfkb",
    "jak.stat|\\bjak\\b|\\bstat[0-9]" = "jak/stat",
    "\\btnf|death receptor|\\bfas\\b|trail|apoptosis" = "tnf/apoptosis",
    "costimulat|cd28|ctla|icos|pd-1|pd1" = "costimulation",
    "antigen present|\\bmhc|\\bhla" = "antigen presentation",
    "lymphocyte activation|leukocyte activation|immune response" = "immune activation",
    "mapk|\\berk\\b|\\bjnk\\b|\\bp38\\b" = "mapk",
    "pi3k|\\bakt\\b|\\bmtor\\b" = "pi3k/akt/mtor",
    "calcium|ca2\\+|calmodulin" = "calcium signaling",
    "phospholipase|\\bplc\\b|\\bdag\\b|\\bip3\\b" = "plc signaling",
    "proliferation" = "proliferation",
    "differentiation" = "differentiation",
    "complement" = "complement"
  )
  
  # Terms to EXCLUDE/deprioritize (B-cell, non-immune generic terms)
  # Terms to EXCLUDE/deprioritize (B-cell, non-immune generic terms)
  exclude_patterns <- c(
  "b cell|b-cell|\\bbcr\\b|bcr_|_bcr_|immunoglobulin|antibody|b lymphocyte",
  "nephron|kidney|renal|metanephric",
  "retinal|bipolar neuron|eye development",
  "cardiac|heart muscle|cardiomyocyte|adrenergic.*cardio",
  "hepat|liver development",
  "neural crest|neuron differentiation|motor neuron|dopaminergic|oligodendrocyte",
  "renin|estrogen|oxytocin",  # Non-T-cell KEGG pathways
  "osteoblast"
 # "egfr|hiv|hcmv|CXCR4"
)
  exclude_regex <- paste(exclude_patterns, collapse = "|")
  
  annotations <- data.frame()
  
  for (cl in sort(unique(all_enrichments$cluster))) {
    cluster_enrich <- all_enrichments %>%
      dplyr::filter(cluster == cl, p.adjust < qval_cutoff) %>%
      arrange(p.adjust)
    
    if (nrow(cluster_enrich) == 0) {
      annotation <- "uncharacterized"
      top_term <- NA
      top_db <- NA
      top_qval <- NA
      go_id <- NA
      priority_match <- FALSE
    } else {
      # First, try to find T-cell/immune priority matches (excluding B-cell terms)
      priority_match <- FALSE
      best_priority_row <- NULL
      best_priority_idx <- NULL
      
      for (i in seq_len(nrow(cluster_enrich))) {
        desc_lower <- tolower(cluster_enrich$Description[i])
        
        # Skip if matches exclude patterns (B-cell, etc.)
        if (grepl(exclude_regex, desc_lower, ignore.case = TRUE)) {
          next
        }
        
        for (pattern_idx in seq_along(tcell_priority_patterns)) {
          pattern <- names(tcell_priority_patterns)[pattern_idx]
          if (grepl(pattern, desc_lower, ignore.case = TRUE)) {
            if (is.null(best_priority_row)) {
              best_priority_row <- cluster_enrich[i, ]
              best_priority_idx <- pattern_idx
              priority_match <- TRUE
            }
            break
          }
        }
        
        if (priority_match) break
      }
      
      # If no priority match found, take first non-excluded term
      if (!priority_match) {
        for (i in seq_len(nrow(cluster_enrich))) {
          desc_lower <- tolower(cluster_enrich$Description[i])
          if (!grepl(exclude_regex, desc_lower, ignore.case = TRUE)) {
            best_priority_row <- cluster_enrich[i, ]
            break
          }
        }
        # If all terms are excluded, just take the top one
        if (is.null(best_priority_row)) {
          best_priority_row <- cluster_enrich[1, ]
        }
      }
      
      # Extract information from selected row
      top_term <- best_priority_row$Description
      top_db <- best_priority_row$database
      top_qval <- best_priority_row$p.adjust
      
      # Get GO ID if available
      go_id <- NA
      term_id <- best_priority_row$ID
      
      if (grepl("^GO:", term_id)) {
        # Already has GO ID
        go_id <- term_id
      } else if (top_db %in% c("GO_BP_MSigDB", "GO_BP")) {
        # Try to find matching GO ID from builtin GO_BP results
        # Extract the term name without GOBP_ prefix for matching
        term_name_clean <- gsub("^GOBP_", "", term_id)
        term_name_clean <- gsub("_", " ", term_name_clean)
        
        matching_go <- cluster_enrich %>%
          dplyr::filter(database == "GO_BP", grepl("^GO:", ID))
        
        if (nrow(matching_go) > 0) {
          # Try to match by similar description
          for (j in seq_len(nrow(matching_go))) {
            go_desc <- tolower(matching_go$Description[j])
            if (grepl(substr(tolower(term_name_clean), 1, 20), go_desc) ||
                grepl(substr(go_desc, 1, 20), tolower(term_name_clean))) {
              go_id <- matching_go$ID[j]
              break
            }
          }
        }
      }
      
      # Create clean annotation (lowercase, complete name)
      desc_clean <- top_term
      # Remove database prefixes
      desc_clean <- gsub("KEGG_MEDICUS_|REACTOME_|GOBP_|HALLMARK_|REFERENCE_|PATHOGEN_", "", desc_clean)
      # Replace underscores with spaces
      desc_clean <- gsub("_", " ", desc_clean)
      # Convert to lowercase
      desc_clean <- tolower(desc_clean)
      # Trim whitespace
      desc_clean <- trimws(desc_clean)
      
      # Add GO ID if available
      if (!is.na(go_id)) {
        annotation <- paste0(desc_clean, " (", go_id, ")")
      } else {
        annotation <- desc_clean
      }
    }
    
    annotations <- rbind(annotations, data.frame(
      cluster = cl,
      annotation = annotation,
      top_term = top_term,
      top_database = top_db,
      top_qval = top_qval,
      go_id = go_id,
      priority_match = priority_match,
      stringsAsFactors = FALSE
    ))
  }
  
  return(annotations)
}

# Apply the improved annotation
cluster_annotations <- generate_cluster_annotation_tcell(all_enrichments)

cat("Improved Cluster Annotations (T-cell aware, lowercase, with GO IDs):\n")
print(cluster_annotations)
print(all_enrichments[(all_enrichments$cluster == 3) & (all_enrichments$p.adjust < 0.1),])
print(all_enrichments[(all_enrichments$cluster == 7) & (all_enrichments$p.adjust < 0.1),])


# Merge with cluster characterization
cluster_summary <- cluster_characterization %>%
  left_join(cluster_annotations, by = "cluster") %>%
  dplyr::select(cluster, n_genes, annotation, dominant_group, dominant_direction, 
                intra_cluster_corr, top_term, top_database, top_qval, go_id, priority_match)

cat("\n\nFull Cluster Summary:\n")
print(as.data.frame(cluster_summary))

# Create annotation lookup for heatmap
cluster_annotation_lookup <- setNames(cluster_annotations$annotation, cluster_annotations$cluster)
@

<<>>=
 SECTION 10b: Manual Annotation Corrections
# Based on careful review of enrichment terms vs perturbation patterns,
# the following clusters have better annotations than the automated selection:

cat("\n--- Manual Annotation Corrections ---\n")

# Store original annotations for reference
cluster_annotations$annotation_auto <- cluster_annotations$annotation

# C3: Simplify to "calcineurin signaling" (core T-cell pathway)
# Rationale: PPP3CA (calcineurin) and CALM2 (calmodulin) are the key genes
#            Strong Identity/Activation downregulation matches calcineurin inhibition
cluster_annotations$annotation[cluster_annotations$cluster == 3] <- "calcineurin signaling"
cluster_annotations$top_term[cluster_annotations$cluster == 3] <- "Calcineurin signaling (manual)"

# C5: Change to "immunoregulatory interactions" 
# Rationale: More T-cell relevant than "complement cascade"
#            KLRC4 (NKG2 family) is a T/NK cell receptor
cluster_annotations$annotation[cluster_annotations$cluster == 5] <- "immunoregulatory interactions"
cluster_annotations$top_term[cluster_annotations$cluster == 5] <- "Immunoregulatory interactions (manual)"

# C7: Change from "interleukin 10 signaling" to "TNF receptor signaling"
# Rationale: Top enrichments are TNFRSF1A/1B and CD27, NOT IL-10
#            TNF receptor signaling explains Activation ↑ pattern
cluster_annotations$annotation[cluster_annotations$cluster == 7] <- "TNF receptor signaling"
cluster_annotations$top_term[cluster_annotations$cluster == 7] <- "TNFS bind their physiological receptors (manual)"

# C9: Change from "GMP metabolic process" to "protein localization to cell periphery"
# Rationale: DLG1, RAP1A, CLIP3 regulate membrane protein localization
#            This directly explains the Adhesion ↑ pattern
cluster_annotations$annotation[cluster_annotations$cluster == 9] <- "protein localization to cell periphery (GO:1904375)"
cluster_annotations$top_term[cluster_annotations$cluster == 9] <- "Regulation of protein localization to cell periphery (manual)"
cluster_annotations$go_id[cluster_annotations$cluster == 9] <- "GO:1904375"

cat("Corrected annotations for clusters 3, 5, 7, 9\n\n")

# Print comparison of auto vs manual annotations
cat("Annotation Comparison (auto → manual):\n")
corrections <- cluster_annotations %>%
  dplyr::filter(cluster %in% c(3, 5, 7, 9)) %>%
  dplyr::select(cluster, annotation_auto, annotation)
print(corrections)
@
