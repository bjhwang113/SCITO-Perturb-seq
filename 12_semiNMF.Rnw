semi-NMF Analysis: V1 Z-score Masked - Extended Rank Search & Validation
<<>>=
suppressPackageStartupMessages({
  library(NMF)
  library(hNMF)
  library(Matrix)
  library(dplyr)
  library(tidyr)
  library(ggplot2)
  library(patchwork)
  library(pheatmap)
  library(RColorBrewer)
  library(clusterProfiler)
  library(org.Hs.eg.db)
  library(enrichplot)
})

# Paths
GENE_RESULTS_DIR <- "/home/ec2-user/scitoseq/results/results_gene_level"
OUTPUT_DIR <- "/home/ec2-user/scitoseq/results/semiNMF_v1_analysis"
dir.create(OUTPUT_DIR, recursive = TRUE, showWarnings = FALSE)
dir.create(file.path(OUTPUT_DIR, "figures"), recursive = TRUE, showWarnings = FALSE)
dir.create(file.path(OUTPUT_DIR, "enrichment"), recursive = TRUE, showWarnings = FALSE)

# Parameters
FDR_THRESHOLD <- 0.1
RANK_GRID <- 3:10
NMF_NRUNS <- 20 #10
NMF_MAXITER <- 500  # Increased for better convergence
NMF_SEED <- 42


cat(sprintf("Rank grid: %d to %d\n", min(RANK_GRID), max(RANK_GRID))) 
# Rank grid: 3 to 10
cat(sprintf("Runs per rank: %d\n", NMF_NRUNS))
# Runs per rank: 20
cat(sprintf("Max iterations: %d\n", NMF_MAXITER))
# Max iterations: 500
cat(sprintf("Output directory: %s\n", OUTPUT_DIR))

# Load Data
gene_zscore_mat <- readRDS(file.path(GENE_RESULTS_DIR, "gene_zscore_mat.rds"))
gene_lfc_mat <- readRDS(file.path(GENE_RESULTS_DIR, "gene_lfc_mat.rds"))
gene_qval_per_protein <- readRDS(file.path(GENE_RESULTS_DIR, "gene_qval_per_protein.rds"))
self_targeted_gene <- readRDS(file.path(GENE_RESULTS_DIR, "self_targeted_gene.rds"))

cat(sprintf("  Z-score matrix: %d genes × %d proteins\n", nrow(gene_zscore_mat), ncol(gene_zscore_mat)))
# Z-score matrix: 17336 genes × 201 proteins


# Gene Filtering: Per-protein FDR < 0.1
gene_min_qval <- apply(gene_qval_per_protein, 1, min, na.rm = TRUE)
genes_filtered <- names(gene_min_qval)[gene_min_qval < FDR_THRESHOLD]

cat(sprintf("  Genes passing filter: %d\n", length(genes_filtered)))
# 2848

# Prepare V1 Input Matrix: Z-score, Cis-masked
# Subset to filtered genes
mat_v1 <- gene_zscore_mat[genes_filtered, , drop = FALSE]

# Mask cis-pairs (set to 0)
n_masked <- 0
for (i in 1:nrow(self_targeted_gene)) {
  gene <- self_targeted_gene$gene[i]
  protein <- self_targeted_gene$protein[i]
  if (gene %in% rownames(mat_v1) && protein %in% colnames(mat_v1)) {
    mat_v1[gene, protein] <- 0
    n_masked <- n_masked + 1
  }
}
cat(sprintf("  Masked %d cis-pairs\n", n_masked))

# Clean matrix (handle NA/Inf)
mat_v1[is.na(mat_v1)] <- 0
mat_v1[!is.finite(mat_v1)] <- 0

cat(sprintf("  Final dimensions: %d genes × %d proteins\n", nrow(mat_v1), ncol(mat_v1)))
cat(sprintf("  Value range: [%.2f, %.2f]\n", min(mat_v1), max(mat_v1)))
# Final dimensions: 2848 genes × 201 proteins
# Value range: [-17.34, 9.82]

# Save input matrix
saveRDS(mat_v1, file.path(OUTPUT_DIR, "input_matrix_v1.rds"))
saveRDS(genes_filtered, file.path(OUTPUT_DIR, "genes_filtered.rds"))
@

<<>>=
semi_wrapper <- function(x, seed, maxiter = 800, ...) {
  current_rank <- nbasis(seed)
  
  # Initialize with improved values
  H_improved <- matrix(runif(current_rank * ncol(x), 0.01, 1), 
                       nrow = current_rank, ncol = ncol(x))
  W_improved <- matrix(rnorm(nrow(x) * current_rank), 
                       nrow = nrow(x), ncol = current_rank)
  
  NMF::basis(seed) <- W_improved
  NMF::coef(seed) <- H_improved
  
  # Test invertibility

  H_test <- try(MASS::ginv(NMF::coef(seed)), silent = TRUE)
  if (inherits(H_test, "try-error")) {
    warning("H matrix may be problematic for semi-NMF")
  }
  
  result <- hNMF::semiNMF(X = x, nmfMod = seed, 
                          maxiter = maxiter, checkDivergence = FALSE)
  return(result)
}

# Run Semi-NMF with Extended Rank Search
set.seed(NMF_SEED)
t_start <- Sys.time()

estim_v1 <- nmf(mat_v1, 
                rank = RANK_GRID, 
                method = semi_wrapper,
                mixed = TRUE,
                nrun = NMF_NRUNS, 
                seed = NMF_SEED + 1, 
                maxiter = NMF_MAXITER,
                .options = "v")

t_elapsed <- difftime(Sys.time(), t_start, units = "mins")
cat(sprintf("\nCompleted in %.1f minutes\n", as.numeric(t_elapsed)))

# Save estimation results
saveRDS(estim_v1, file.path(OUTPUT_DIR, "estim_v1_k3to10.rds"))

estim_v1 <- readRDS(file.path(OUTPUT_DIR, "estim_v1_k3to10.rds"))
plot(estim_v1, main = "V1 zscore masked")
@

\end{document}