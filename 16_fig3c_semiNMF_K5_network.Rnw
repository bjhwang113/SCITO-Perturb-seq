      117       158       155 
      
<<>>=
# 6. MODULE POSITIONS (correlation-informed pentagon)
module_radius <- 15
pentagon_angles <- seq(pi/2, pi/2 + 2*pi, length.out = 6)[1:5]

# Place anti-correlated modules maximally apart
module_to_pos <- c("M4" = 1, "M1" = 2, "M5" = 3, "M3" = 4, "M2" = 5)
module_angles <- setNames(pentagon_angles[module_to_pos], names(module_to_pos))

module_pos <- data.frame(
  name    = modules,
  x       = cos(module_angles[modules]) * module_radius,
  y       = sin(module_angles[modules]) * module_radius,
  angle   = module_angles[modules],
  name_x  = cos(module_angles[modules]) * (module_radius + 3.0),
  name_y  = sin(module_angles[modules]) * (module_radius + 3.0),
  stringsAsFactors = FALSE
)

# 7. POSITION GUIDES
apply_repulsion <- function(df, iterations = 100, min_dist = 0.45, strength = 0.1) {
  n <- nrow(df)
  if (n < 2) return(df)
  for (iter in seq_len(iterations)) {
    for (i in 1:(n - 1)) {
      for (j in (i + 1):n) {
        dx   <- df$x[j] - df$x[i]
        dy   <- df$y[j] - df$y[i]
        dist <- sqrt(dx^2 + dy^2)
        if (dist < min_dist && dist > 0.01) {
          force <- strength * (min_dist - dist) / dist
          df$x[i] <- df$x[i] - dx * force
          df$y[i] <- df$y[i] - dy * force
          df$x[j] <- df$x[j] + dx * force
          df$y[j] <- df$y[j] + dy * force
        }
      }
    }
  }
  df
}

position_guides <- function(guide_df, module_pos, W, w_strong, seed = 42) {
  set.seed(seed)
  n_modules    <- nrow(module_pos)
  sector_width <- 2 * pi / n_modules
  m_radius     <- max(sqrt(module_pos$x^2 + module_pos$y^2))

  r_near_module <- m_radius - 2.5
  r_near_center <- 5

  guide_df$x <- NA_real_
  guide_df$y <- NA_real_

  passing_abs <- guide_df$primary_abs[guide_df$primary_abs >= w_strong]
  w_min <- min(passing_abs, na.rm = TRUE)
  w_max <- max(passing_abs, na.rm = TRUE)

  for (i in seq_len(nrow(guide_df))) {
    cat_i    <- guide_df$category[i]
    primary  <- guide_df$primary_module[i]
    secondary <- guide_df$secondary_module[i]
    pw       <- guide_df$primary_abs[i]
    primary_angle <- module_pos$angle[module_pos$name == primary]

    if (w_max > w_min) {
      base_radius <- r_near_center +
        (pw - w_min) / (w_max - w_min) * (r_near_module - r_near_center)
    } else {
      base_radius <- (r_near_center + r_near_module) / 2
    }

    if (cat_i %in% c("activator", "repressor")) {
      angle_offset <- runif(1, -sector_width * 0.35, sector_width * 0.35)
      radius <- base_radius + runif(1, -0.2, 0.2)
      guide_df$x[i] <- cos(primary_angle + angle_offset) * radius
      guide_df$y[i] <- sin(primary_angle + angle_offset) * radius

    } else if (cat_i == "opposing" && !is.na(secondary)) {
      secondary_angle <- module_pos$angle[module_pos$name == secondary]
      angle_diff <- secondary_angle - primary_angle
      if (abs(angle_diff) > pi) angle_diff <- angle_diff - sign(angle_diff) * 2 * pi
      mid_angle <- primary_angle + angle_diff * runif(1, 0.35, 0.65)
      radius <- (r_near_center + r_near_module) / 2 + runif(1, -0.5, 0.5)
      guide_df$x[i] <- cos(mid_angle) * radius
      guide_df$y[i] <- sin(mid_angle) * radius

    } else {
      angle_offset <- runif(1, -sector_width * 0.3, sector_width * 0.3)
      radius <- base_radius + runif(1, -0.2, 0.2)
      guide_df$x[i] <- cos(primary_angle + angle_offset) * radius
      guide_df$y[i] <- sin(primary_angle + angle_offset) * radius
    }
  }

  guide_df <- apply_repulsion(guide_df, iterations = 100, min_dist = 0.45)
  guide_df
}

cat("Positioning guides...\n")
selected <- position_guides(selected, module_pos, W, W_STRONG)


# 8. CREATE EDGES
create_edges <- function(guide_df, W, module_pos, w_strong) {
  edges_list <- vector("list", nrow(guide_df) * ncol(W))
  idx <- 0
  for (i in seq_len(nrow(guide_df))) {
    g  <- guide_df$guide[i]
    gx <- guide_df$x[i]
    gy <- guide_df$y[i]
    w  <- W[g, ]
    for (m in colnames(W)) {
      if (abs(w[m]) >= w_strong) {
        idx <- idx + 1
        edges_list[[idx]] <- data.frame(
          guide     = g,
          module    = m,
          x1 = gx, y1 = gy,
          x2 = module_pos$x[module_pos$name == m],
          y2 = module_pos$y[module_pos$name == m],
          weight    = w[m],
          direction = ifelse(w[m] > 0, "activating", "repressing"),
          stringsAsFactors = FALSE
        )
      }
    }
  }
  do.call(rbind, edges_list[seq_len(idx)])
}

# Note: guide_df uses column "gene", edges function expects "guide"
selected$guide <- selected$gene

cat("Creating edges...\n")
edges <- create_edges(selected, W, module_pos, W_STRONG)
cat(sprintf("Created %d edges (%d activating, %d repressing)\n",
            nrow(edges), sum(edges$direction == "activating"),
            sum(edges$direction == "repressing")))


# 9. PROTEIN POSITIONS
prot_max     <- apply(H, 2, max)
prot_primary <- modules[apply(H, 2, which.max)]
prot_second  <- apply(H, 2, function(x) sort(x, decreasing = TRUE)[2])
prot_spec    <- prot_max / pmax(prot_second, 1e-10)

get_protein_positions <- function(H, module_pos, prot_spec, prot_primary,
                                  spec_min = 1.5, n_max = 6,
                                  radial_offset = 2.3) {
  out <- list()
  for (m in rownames(H)) {
    mx      <- module_pos$x[module_pos$name == m]
    my      <- module_pos$y[module_pos$name == m]
    m_angle <- module_pos$angle[module_pos$name == m]

    all_m_prots <- which(prot_primary == m)
    n_total     <- length(all_m_prots)

    m_prots_idx <- which(prot_primary == m & prot_spec >= spec_min)
    if (length(m_prots_idx) == 0) {
      m_prots_idx <- all_m_prots
      m_prots_idx <- m_prots_idx[order(H[m, m_prots_idx], decreasing = TRUE)]
      m_prots_idx <- head(m_prots_idx, 3)
    } else {
      m_prots_idx <- m_prots_idx[order(prot_spec[m_prots_idx], decreasing = TRUE)]
      m_prots_idx <- head(m_prots_idx, n_max)
    }

    k <- length(m_prots_idx)
    if (k == 0) next

    prots      <- colnames(H)[m_prots_idx]
    label_text <- paste(prots, collapse = "\n")
    n_remaining <- n_total - k
    if (n_remaining > 0) {
      label_text <- paste0(label_text, sprintf("\n+%d more", n_remaining))
    }

    urx <- cos(m_angle); ury <- sin(m_angle)
    x <- mx + urx * radial_offset
    y <- my + ury * radial_offset
    hjust <- ifelse(abs(urx) < 0.15, 0.5, ifelse(urx > 0, 0, 1))

    out[[m]] <- data.frame(
      module = m, label = label_text,
      x = x, y = y, hjust = hjust,
      n_shown = k, n_total = n_total,
      stringsAsFactors = FALSE
    )
  }
  do.call(rbind, out)
}

protein_df <- get_protein_positions(
  H, module_pos, prot_spec, prot_primary,
  spec_min = PROTEIN_SPECIFICITY_MIN,
  n_max    = N_PROTEINS_MAX,
  radial_offset = 2.3
)

# Manual adjustment for M4 label position
m4_row <- which(protein_df$module == "M4")
if (length(m4_row) > 0) {
  m4_mx <- module_pos$x[module_pos$name == "M4"]
  m4_my <- module_pos$y[module_pos$name == "M4"]
  protein_df$x[m4_row]     <- m4_mx + 2.5
  protein_df$y[m4_row]     <- m4_my - 0.6
  protein_df$hjust[m4_row] <- 0
}
@

<<>>=
# 10. MAIN NETWORK PLOT
plot_network <- function(
    guide_df, edges, module_pos,
    protein_df      = NULL,
    show_proteins   = FALSE,
    show_all_labels = FALSE,
    highlight_novel = TRUE,
    title    = NULL,
    subtitle = NULL
) {

  edges$direction <- factor(edges$direction, levels = c("activating", "repressing"))

  p <- ggplot()

  # --- Edges ---
  edges_act <- edges[edges$direction == "activating", ]
  edges_rep <- edges[edges$direction == "repressing", ]
  edge_lw <- 0.6

  if (nrow(edges_act) > 0) {
    p <- p + geom_curve(
        data = edges_act,
        aes(x = x1, y = y1, xend = x2, yend = y2),
        color = EDGE_COLORS["activating"],
        linewidth = edge_lw, alpha = 0.45, curvature = 0.2)
  }
  if (nrow(edges_rep) > 0) {
    p <- p +
      geom_curve(
        data = edges_rep,
        aes(x = x1, y = y1, xend = x2, yend = y2),
        color = EDGE_COLORS["repressing"],
        linewidth = edge_lw, alpha = 0.45, curvature = 0.2
      )
  }

  # --- Proteins ---
  if (show_proteins && !is.null(protein_df)) {
    for (i in seq_len(nrow(protein_df))) {
      m <- protein_df$module[i]
      p <- p +
        geom_label(
          data = protein_df[i, , drop = FALSE],
          aes(x = x, y = y, label = label),
          hjust         = protein_df$hjust[i],
          size          = 2.6,
          color         = MODULE_COLORS[m],
          fill          = "gray97",
          label.size    = 0.3,
          label.r       = unit(0.15, "lines"),
          label.padding = unit(0.25, "lines"),
          lineheight    = 0.9,
          fontface      = "bold"
        )
    }
  }

  # --- Module nodes ---
  for (m in module_pos$name) {
    m_data <- module_pos[module_pos$name == m, ]
    p <- p +
      geom_point(data = m_data, aes(x = x, y = y),
                 size = 18, shape = 21,
                 fill = MODULE_COLORS[m], color = "white", stroke = 2.5)
  }
  p <- p +
    geom_text(data = module_pos,
              aes(x = x, y = y, label = name),
              color = "white", size = 5.5, fontface = "bold")

  # --- Guide nodes: three visual tiers ---
  guide_df$category <- factor(guide_df$category, levels = names(CAT_SHAPES))

  # Tier 1: Regular (background)
  regular <- guide_df[!guide_df$is_immune & !guide_df$is_novel, ]
  if (nrow(regular) > 0) {
    p <- p +
      geom_point(data = regular,
                 aes(x = x, y = y, shape = category, fill = category),
                 size = 1.5, color = "gray40", stroke = 0.6)
  }

  # Tier 2: Novel
  if (highlight_novel) {
    novel <- guide_df[guide_df$is_novel & !guide_df$is_immune, ]
    if (nrow(novel) > 0) {
      p <- p +
        geom_point(data = novel,
                   aes(x = x, y = y, shape = category, fill = category),
                   size = 2.2, color = NOVEL_LABEL_COLOR, stroke = 1.2)
    }
  }

  # Tier 3: Immune (foreground)
  immune <- guide_df[guide_df$is_immune, ]
  if (nrow(immune) > 0) {
    p <- p +
      geom_point(data = immune,
                 aes(x = x, y = y, shape = category, fill = category),
                 size = 2.5, color = IMMUNE_LABEL_COLOR, stroke = 1.4)
  }

  p <- p +
    scale_shape_manual(values = CAT_SHAPES, labels = CAT_LABELS,
                       name = "Gene type", drop = FALSE) +
    scale_fill_manual(values = CAT_FILLS, labels = CAT_LABELS,
                      name = "Gene type", drop = FALSE)

  # --- Labels: immune + novel only ---
  if (show_all_labels) {
    label_data <- guide_df
  } else {
    label_data <- guide_df[guide_df$is_immune | guide_df$is_novel, ]
  }

  if (nrow(label_data) > 0) {
    label_colors <- ifelse(label_data$is_immune, IMMUNE_LABEL_COLOR,
                    ifelse(label_data$is_novel, NOVEL_LABEL_COLOR, "gray40"))
    label_face <- ifelse(label_data$is_immune | label_data$is_novel,
                         "bold", "plain")

    p <- p +
      geom_text_repel(
        data = label_data,
        aes(x = x, y = y, label = guide),
        size          = 2.8,
        fontface      = label_face,
        color         = label_colors,
        bg.color      = "white",
        bg.r          = 0.15,
        max.overlaps  = 60,
        segment.color = "gray60",
        segment.size  = 0.25,
        box.padding   = 0.4,
        point.padding = 0.3,
        force         = 3,
        seed          = 42
      )
  }

  # --- Legend: Edge direction ---
  edge_legend_df <- data.frame(
    x = c(Inf, Inf), y = c(Inf, Inf),
    direction = factor(c("activating", "repressing"),
                       levels = c("activating", "repressing")))
  p <- p +
    geom_segment(
      data = edge_legend_df,
      aes(x = x, y = y, xend = x, yend = y, color = direction),
      linewidth = 0.8, alpha = 1) + scale_color_manual(
      name   = "Edge direction",
      values = EDGE_COLORS,
      labels = c("activating" = "Activating", "repressing" = "Repressing"),
      guide  = guide_legend(
        order = 1, nrow = 1, title.position = "left",
        override.aes = list(linewidth = 2.5, alpha = 1)))

  # --- Legend: Module identity ---
  module_legend_df <- data.frame(
    x = rep(Inf, length(modules)),
    y = rep(Inf, length(modules)),
    module_id = factor(modules, levels = modules))
  p <- p + geom_point(
      data = module_legend_df,
      aes(x = x, y = y, size = module_id),
      shape = 21, fill = NA, color = NA, stroke = 0) +
    scale_size_manual(
      name   = "Module",
      values = setNames(rep(5, length(modules)), modules),
      labels = setNames(gsub("\n", " ", MODULE_NAMES[modules]), modules),
      guide  = guide_legend(
        order = 2, nrow = 2, title.position = "left",
        override.aes = list(
          shape = 21, fill  = unname(MODULE_COLORS[modules]),
          color = "white", stroke = 1.5, size = 5)))

  # --- Legend: Gene annotation color ---
  p <- p + new_scale_color() +
    geom_point(
      data = data.frame(
        x = c(Inf, Inf), y = c(Inf, Inf),
        #gene_type = factor(c("Validated immune", "Candidate novel"),
        #                   levels = c("Validated immune", "Candidate novel"))),
        gene_type = factor(c("known regulator", "newly identified regulator"),
                          levels = c("known regulator", "newly identified regulator"))),
      aes(x = x, y = y, color = gene_type),
      size = 3
    ) +
    scale_color_manual(
      name   = "",
      values = c("known regulator" = IMMUNE_LABEL_COLOR,
                 "newly identified regulator"  = NOVEL_LABEL_COLOR),
      guide  = guide_legend(
        order = 4, nrow = 1, title.position = "left",
        override.aes = list(size = 3, shape = 16, alpha = 1)))

  # --- Coord + theme ---
  p <- p + coord_equal(clip = "off",
                xlim = c(-16, 16), ylim = c(-16, 16)) +
    theme_void(base_size = 11) +
    theme(
      legend.position    = "bottom",
      legend.box         = "vertical",
      legend.box.just    = "center",
      legend.margin      = margin(0, 0, 0, 0),
      legend.key.size    = unit(0.45, "cm"),
      legend.key.width   = unit(1.0, "cm"),
      legend.text        = element_text(size = 9),
      legend.title       = element_text(size = 10, face = "bold"),
      legend.box.spacing = unit(-1.5, "cm"),
      legend.box.margin  = margin(0, 0, 10, 0),
      plot.margin        = margin(0, 0, 0, 0)
    ) +
    guides(
      shape = guide_legend(
        order = 3, nrow = 1, title.position = "left",
        override.aes = list(size = 4, stroke = 1, color = "black",
                            fill = "white")
      ), fill = "none")

  if (!is.null(title) || !is.null(subtitle)) {
    p <- p +
      labs(title = title, subtitle = subtitle) +
      theme(
        plot.title    = element_text(face = "bold", size = 15, hjust = 0.5),
        plot.subtitle = element_text(size = 9, hjust = 0.5, color = "gray40"))
  }

  p
}


# 11. GENERATE PLOTS
p_main <- plot_network(
  selected, edges, module_pos,
  protein_df      = protein_df,
  show_proteins   = TRUE,
  show_all_labels = FALSE,
  highlight_novel = TRUE
)

ggsave(file.path(OUTPUT_DIR, "network_fig3c.pdf"),
       p_main, width = 8, height = 8)
@

<<>>=
# 12. DIAGNOSTIC: PRINT SELECTED GENES BY CATEGORY
cat("\n--- Opposing genes in final selection ---\n")
opp <- selected %>% filter(category == "opposing") %>%
  arrange(desc(primary_abs))
cat(sprintf("%-14s %-6s %8s %8s %8s %8s %8s  sel_from\n",
            "Gene", "Prim", "M1", "M2", "M3", "M4", "M5"))
for (i in seq_len(nrow(opp))) {
  g <- opp$gene[i]
  cat(sprintf("%-14s %-6s %+.4f %+.4f %+.4f %+.4f %+.4f  %s\n",
              g, opp$primary_module[i],
              W[g, 1], W[g, 2], W[g, 3], W[g, 4], W[g, 5],
              opp$selection[i]))
}

cat("\n--- Immune genes in final selection ---\n")
imm <- selected %>% filter(is_immune) %>% arrange(primary_module, desc(primary_abs))
cat(sprintf("%-14s %-6s %-10s %-10s %8s  sel_from\n",
            "Gene", "Prim", "Category", "SecMod", "|W|max"))
for (i in seq_len(nrow(imm))) {
  cat(sprintf("%-14s %-6s %-10s %-10s %8.4f  %s\n",
              imm$gene[i], imm$primary_module[i], imm$category[i],
              ifelse(is.na(imm$secondary_module[i]), "-", imm$secondary_module[i]),
              imm$primary_abs[i], imm$selection[i]))
}

cat("\n--- Novel genes in final selection ---\n")
nov <- selected %>% filter(is_novel) %>% arrange(primary_module, desc(primary_abs))
cat(sprintf("%-14s %-6s %-10s %8s  sel_from\n",
            "Gene", "Prim", "Category", "|W|max"))
for (i in seq_len(nrow(nov))) {
  cat(sprintf("%-14s %-6s %-10s %8.4f  %s\n",
              nov$gene[i], nov$primary_module[i], nov$category[i],
              nov$primary_abs[i], nov$selection[i]))
}
@

