\documentclass{article}

\begin{document}
\SweaveOpts{concordance=TRUE}

Semi-NMF Network: Restructured Gene Selection + Network Plot

Three-category gene selection:
  Category 1: Module-defining (top activators/repressors per module)
  Category 2: Module-specific (single-module, high specificity)
  Category 3: Opposing-effect (multi-module, signed transitions)
  
<<>>=
suppressPackageStartupMessages({
  library(dplyr)
  library(ggplot2)
  library(ggrepel)
  library(ggnewscale)
})

# 1. PARAMETERS
INPUT_DIR  <- "/home/ec2-user/scitoseq/results/semiNMF_v1_analysis"
OUTPUT_DIR <- "/home/ec2-user/scitoseq/fig/fig3/"

# --- Threshold ---
W_THRESHOLD_PERCENTILE <- 0.90

# --- Selection counts ---
N_MODULE_DEFINING  <- 50   # top activators + repressors per module (each side)
N_MODULE_SPECIFIC  <- 10    # highest-specificity single-module genes per module
N_OPPOSING         <- 100   # total opposing-effect genes (across all module pairs)

# --- Protein display ---
PROTEIN_SPECIFICITY_MIN <- 1.5
N_PROTEINS_MAX          <- 6

# --- Highlight lists ---
# Genes with established T cell / immune literature (from audit)
IMMUNE_GENES <- c(
  # Known immune regulators from original list
  "IL2RA", "IL2RB", "IL15RA", "IL12B",
  "PDCD1", "CTLA4", "LAG3", "ICOS",
  "CD28", "CD27", "CD40LG", "TNFRSF4", "TNFRSF1B", "TNFRSF1A", # "TNFRSF9", 
  "CARD11", "NFKB1", "RELA",
  "PRDM1", "STAT5A",
  "GZMA", "FASLG",
  "CXCR3", "CXCR4",
  "S1PR1", "PTPN6", "MAP3K8",
  # Literature-supported from audit
  "CD244", "CD69", "STX11", "GNAI2", "SORT1",
  "CSF2", "LYN", "PECAM1", "RIPOR1",
  "TAB2", "CASP6", "CTSC", "PSTPIP1",
  "IL17RA", "ALOX5AP", "SIRPA", "MAP2K2",
  "MYLIP", "SLPI", "CD19"
)

# Novel candidates (high specificity, limited T cell literature)
NOVEL_HIGHLIGHT <- c(
  "SALL2", "RAP1GDS1", "KCNJ18", "TBL3",
  "CCDC134", "NUFIP1", "PHF8", "CNTN2",
  "HVCN1", "EPHA4", "EFNA4", "LAPTM5",
  "SATB2", "PRKACB", "MZF1", "FJX1",
  "NOP58", "CTBS"
)

# --- Visual parameters ---
EDGE_COLORS <- c(
  "activating"  = "#C0392B",
  "repressing"  = "#2471A3"
)
IMMUNE_LABEL_COLOR <- "#6D1A36"
NOVEL_LABEL_COLOR  <- "#00796B"

MODULE_NAMES <- c(
  "M1" = "Adhesion &\nImmune Regulation",
  "M2" = "Tissue Interaction\n/ Innate-like",
  "M3" = "Resting / Naive",
  "M4" = "Activation\n/ Proliferation",
  "M5" = "Effector\n/ Exhaustion"
)
MODULE_COLORS <- c(
  "M1" = "#da7901",
  "M2" = "#20235b",
  "M3" = "#637b31",
  "M4" = "#7B2D8E",
  "M5" = "#f0be3d"
)
CAT_SHAPES <- c(
  "activator"  = 24,
  "repressor"  = 25,
  "opposing"   = 23
)
CAT_FILLS <- c(
  "activator"  = "white",
  "repressor"  = "white",
  "opposing"   = "white"
)
CAT_LABELS <- c(
  "activator"  = "Module activator",
  "repressor"  = "Module repressor",
  "opposing"   = "Opposing effects"
)


# 2. LOAD AND NORMALIZE
model_k5 <- readRDS(file.path(INPUT_DIR, "model_k5.rds"))
W_raw <- model_k5$W
H_raw <- model_k5$H
modules <- paste0("M", 1:5)
colnames(W_raw) <- modules
rownames(H_raw) <- modules

# L2-normalize columns of W, scale H accordingly
d <- sqrt(colSums(W_raw^2))
W <- sweep(W_raw, 2, d, "/")
H <- diag(d) %*% H_raw
rownames(H) <- modules
colnames(H) <- colnames(H_raw)

cat(sprintf("W: %d genes x %d modules\n", nrow(W), ncol(W)))
cat(sprintf("H: %d modules x %d proteins\n", nrow(H), ncol(H)))
# W: 2848 genes x 5 modules
# H: 5 modules x 201 proteins

# --- Threshold ---
w_abs_all <- abs(as.vector(W))
W_STRONG  <- quantile(w_abs_all, probs = W_THRESHOLD_PERCENTILE)
cat(sprintf("Edge threshold: %.5f (%.0f%% percentile of |W|)\n",
            W_STRONG, W_THRESHOLD_PERCENTILE * 100))
# Edge threshold: 0.03072 (90% percentile of |W|)
@

<<>>=
# 3. GENE-LEVEL ANNOTATIONS (computed once, used by all categories)
gene_ann <- data.frame(
  gene        = rownames(W),
  is_immune   = rownames(W) %in% IMMUNE_GENES,
  is_novel    = rownames(W) %in% NOVEL_HIGHLIGHT,
  stringsAsFactors = FALSE
)

# Per-gene summary statistics
gene_ann$max_abs       <- apply(abs(W), 1, max)
gene_ann$max_pos       <- apply(W, 1, max)
gene_ann$max_neg       <- apply(W, 1, min)
gene_ann$n_strong_pos  <- rowSums(W >=  W_STRONG)
gene_ann$n_strong_neg  <- rowSums(W <= -W_STRONG)
gene_ann$n_strong_any  <- gene_ann$n_strong_pos + gene_ann$n_strong_neg

# Primary module (largest |W|)
gene_ann$primary_module <- colnames(W)[apply(abs(W), 1, which.max)]
gene_ann$primary_weight <- sapply(seq_len(nrow(W)), function(i) {
  W[i, gene_ann$primary_module[i]]
})
gene_ann$primary_abs <- abs(gene_ann$primary_weight)

# Secondary module (largest |W| among remaining, if above threshold)
gene_ann$secondary_module <- sapply(seq_len(nrow(W)), function(i) {
  w <- abs(W[i, ])
  w[gene_ann$primary_module[i]] <- 0
  if (max(w) >= W_STRONG) colnames(W)[which.max(w)] else NA_character_
})
gene_ann$secondary_weight <- sapply(seq_len(nrow(W)), function(i) {
  sm <- gene_ann$secondary_module[i]
  if (!is.na(sm)) W[i, sm] else NA_real_
})

# Category assignment
gene_ann$category <- case_when(
  gene_ann$n_strong_pos >= 1 & gene_ann$n_strong_neg >= 1 ~ "opposing",
  gene_ann$max_pos >=  W_STRONG                           ~ "activator",
  gene_ann$max_neg <= -W_STRONG                           ~ "repressor",
  TRUE                                                    ~ "weak"
)

cat("\nGene classification summary:\n")
print(table(gene_ann$category))
#activator  opposing repressor      weak 
#      378       266       420      1784 
@

The 2,848 genes in W are the significant gene set from your Welch t-tests. 
The 90th percentile threshold (|W| ≥ 0.03072) is applied to all 14,240 gene-module pairs (2,848 × 5). For each gene, we then ask: does it have any positive loading above threshold? 

378 activators (13.3\%): at least one module positive above threshold, none negative below
420 repressors (14.7\%): at least one module negative below threshold, none positive above
266 opposing (9.3\%): at least one positive AND at least one negative above threshold
1,784 weak (62.6\%): no module reaches threshold in either direction

-> 1,064 genes (37.4\%) have at least one significant module association

<<>>=
# 4. THREE-CATEGORY GENE SELECTION

# ---- Category 1: Module-defining (top N per module, per direction) ----
#
# For each module, rank genes by their W value in that module.
# Take top activators (most positive) and top repressors (most negative).
# No specificity requirement -- these define what each module IS.

cat("\n=== Category 1: Module-defining genes ===\n")
cat1_list <- list()
for (m in modules) {
  w_col <- W[, m]
  
  # Activators: positive W above threshold, ranked by W
  act_idx <- which(w_col >= W_STRONG)
  act_idx <- act_idx[order(w_col[act_idx], decreasing = TRUE)]
  act_idx <- head(act_idx, N_MODULE_DEFINING)
  
  # Repressors: negative W below -threshold, ranked by W (most negative first)
  rep_idx <- which(w_col <= -W_STRONG)
  rep_idx <- rep_idx[order(w_col[rep_idx])]
  rep_idx <- head(rep_idx, N_MODULE_DEFINING)
  
  cat1_list[[m]] <- data.frame(
    gene   = rownames(W)[c(act_idx, rep_idx)],
    module = m,
    role   = c(rep("activator", length(act_idx)),
               rep("repressor", length(rep_idx))),
    w_value = w_col[c(act_idx, rep_idx)],
    selection = "module_defining",
    stringsAsFactors = FALSE
  )
  cat(sprintf("  %s: %d activators, %d repressors\n",
              m, length(act_idx), length(rep_idx)))
}
cat1 <- bind_rows(cat1_list)
cat(sprintf("  Total module-defining gene-module pairs: %d\n", nrow(cat1)))
cat(sprintf("  Unique genes: %d\n", n_distinct(cat1$gene)))
# Total module-defining gene-module pairs: 466
# Unique genes: 407

# ---- Category 2: Module-specific (single-module, high specificity) ----
#
# Among genes with max|W| >= threshold, select those where ONLY ONE
# module passes threshold. Rank by |W| (not by specificity ratio, which
# is noisy). These are clean, unambiguous examples.

cat("\n=== Category 2: Module-specific genes ===\n")

specific_genes <- gene_ann %>%
  filter(category %in% c("activator", "repressor"),
         n_strong_any == 1) %>%            # exactly one module above threshold
  arrange(desc(primary_abs))

cat2_list <- list()
for (m in modules) {
  m_genes <- specific_genes %>%
    filter(primary_module == m) %>%
    head(N_MODULE_SPECIFIC)
  
  if (nrow(m_genes) > 0) {
    cat2_list[[m]] <- data.frame(
      gene      = m_genes$gene,
      module    = m,
      role      = ifelse(m_genes$primary_weight > 0, "activator", "repressor"),
      w_value   = m_genes$primary_weight,
      selection = "module_specific",
      stringsAsFactors = FALSE
    )
  }
  cat(sprintf("  %s: %d genes (top |W|: %.4f)\n",
              m, nrow(m_genes),
              ifelse(nrow(m_genes) > 0, max(m_genes$primary_abs), 0)))
}
cat2 <- bind_rows(cat2_list)
cat(sprintf("  Total module-specific genes: %d\n", nrow(cat2)))
  # M1: 10 genes (top |W|: 0.0532)
  # M2: 10 genes (top |W|: 0.0699)
  # M3: 10 genes (top |W|: 0.0574)
  # M4: 10 genes (top |W|: 0.0590)
  # M5: 10 genes (top |W|: 0.0582)
#   Total module-specific genes: 50

# ---- Category 3: Opposing-effect genes (multi-module transitions) ----
#
# Genes with significant loadings (above threshold) in >= 2 modules with
# opposite signs. Scored by:
#   opposing_score = |strongest_positive| * |strongest_negative|
# This naturally selects genes that are simultaneously strong activators
# of one program and strong repressors of another.

cat("\n=== Category 3: Opposing-effect genes ===\n")

opposing_genes <- gene_ann %>%
  filter(category == "opposing") %>%
  mutate(
    # strongest positive and negative loadings
    best_pos = max_pos,
    best_neg = max_neg,
    # opposing score: product of magnitudes
    opposing_score = abs(best_pos) * abs(best_neg),
    # range across modules (alternative ranking)
    w_range = best_pos - best_neg
  ) %>%
  arrange(desc(opposing_score)) %>%
  head(N_OPPOSING)

# Identify the activated and repressed modules for each
opposing_genes$act_module <- sapply(opposing_genes$gene, function(g) {
  w <- W[g, ]
  strong_pos <- which(w >= W_STRONG)
  if (length(strong_pos) > 0) {
    names(which.max(w[strong_pos]))
  } else NA_character_
})
opposing_genes$rep_module <- sapply(opposing_genes$gene, function(g) {
  w <- W[g, ]
  strong_neg <- which(w <= -W_STRONG)
  if (length(strong_neg) > 0) {
    names(which.min(w[strong_neg]))
  } else NA_character_
})

cat3 <- data.frame(
  gene      = opposing_genes$gene,
  module    = opposing_genes$primary_module,
  role      = "opposing",
  w_value   = opposing_genes$primary_weight,
  selection = "opposing",
  stringsAsFactors = FALSE
)

cat(sprintf("  Total opposing genes: %d\n", nrow(cat3)))
cat(sprintf("  Score range: %.6f to %.6f\n",
            min(opposing_genes$opposing_score),
            max(opposing_genes$opposing_score)))
# Score range: 0.001681 to 0.010684

# Print top opposing genes
cat("\n  Top 100 opposing genes (by |pos| * |neg|):\n")
cat(sprintf("  %-12s %8s %8s %8s %8s %8s  pos→  neg→  score\n",
            "Gene", "M1", "M2", "M3", "M4", "M5"))
cat(paste(rep("-", 90), collapse = ""), "\n")
for (i in 1:min(100, nrow(opposing_genes))) {
  g <- opposing_genes$gene[i]
  cat(sprintf("  %-12s %+.4f %+.4f %+.4f %+.4f %+.4f  %s  %s  %.5f\n",
              g, W[g, 1], W[g, 2], W[g, 3], W[g, 4], W[g, 5],
              opposing_genes$act_module[i],
              opposing_genes$rep_module[i],
              opposing_genes$opposing_score[i]))
}

# Summary of module-pair transitions
cat("\n  Opposing gene module-pair summary:\n")
transition_tab <- table(
  paste0(opposing_genes$act_module, "+"),
  paste0(opposing_genes$rep_module, "-")
)
print(transition_tab)
@
      M1- M2- M3- M4- M5-
  M1+   0   0  19   1   4
  M2+  11   0   1   0  21
  M3+   4   0   0   0   4
  M4+  10   1   5   0  18
  M5+   0   1   0   0   0

<<>>=
# 5. MERGE SELECTIONS
all_selected <- bind_rows(cat1, cat2, cat3) %>%
  distinct(gene, .keep_all = TRUE)

# Ensure immune/novel genes that pass threshold are included
must_include <- gene_ann %>%
  filter((is_immune | is_novel),
         category != "weak",
         !(gene %in% all_selected$gene))

if (nrow(must_include) > 0) {
  must_df <- data.frame(
    gene      = must_include$gene,
    module    = must_include$primary_module,
    role      = must_include$category,
    w_value   = must_include$primary_weight,
    selection = "must_include",
    stringsAsFactors = FALSE
  )
  all_selected <- bind_rows(all_selected, must_df)
  cat(sprintf("\nAdded %d must-include immune/novel genes\n", nrow(must_df)))
}

# Merge back full annotation
selected <- gene_ann %>%
  filter(gene %in% all_selected$gene) %>%
  left_join(
    all_selected %>% select(gene, selection) %>% distinct(gene, .keep_all = TRUE),
    by = "gene"
  )

cat(sprintf("\n=== Final selection: %d unique genes ===\n", nrow(selected)))
cat(sprintf("  Module-defining: %d\n",
            sum(selected$selection == "module_defining", na.rm = TRUE)))
cat(sprintf("  Module-specific: %d\n",
            sum(selected$selection == "module_specific", na.rm = TRUE)))
cat(sprintf("  Opposing:        %d\n",
            sum(selected$selection == "opposing", na.rm = TRUE)))
cat(sprintf("  Must-include:    %d\n",
            sum(selected$selection == "must_include", na.rm = TRUE)))
cat(sprintf("  Immune genes:    %d\n", sum(selected$is_immune)))
cat(sprintf("  Novel genes:     %d\n", sum(selected$is_novel)))
cat(sprintf("  Category breakdown:\n"))
print(table(selected$category))
@

=== Final selection: 430 unique genes ===
Module-defining: 407
